@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}



<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Register</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a asp-action="Index"><i class="bx bx-home-alt"></i></a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Create</li>
            </ol>
        </nav>
    </div>
</div>
<hr />

<div class="row">
    <div class="col-xl-9 mx-auto">
        <div class="card border-top border-0 border-4 border-info">
            <div class="card-body">
                <div class="border p-4 rounded">
                    <div class="card-title d-flex align-items-center">
                        <div>
                            <i class="bx bxs-user me-1 font-22 text-info"></i>
                        </div>
                        <h5 class="mb-0 text-info">Create a new account.</h5>
                    </div>
                    <hr />
        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            <div class="row mb-3">
                            <label class="col-sm-3 col-form-label" asp-for="Input.FirstName">FirstName</label>
             
                            <div class="col-sm-9">
                                <input asp-for="Input.FirstName" class="form-control" autocomplete="username" aria-required="true" placeholder="FirstName" />
                <span asp-validation-for="Input.FirstName" class="text-danger"></span>
                            </div>
            </div>
            <div class="row mb-3">
                            <label class="col-sm-3 col-form-label" asp-for="Input.LastName">LastName</label>
               
                                <div class="col-sm-9">
                                <input asp-for="Input.LastName" class="form-control" autocomplete="username" aria-required="true" placeholder="LastName" />
                                <span asp-validation-for="Input.LastName" class="text-danger"></span>
                            </div>
            </div>
            <div class="row mb-3">
                            <label class="col-sm-3 col-form-label" asp-for="Input.Email">Email</label>
                                    <div class="col-sm-9">
                                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                      
                <span asp-validation-for="Input.Email" class="text-danger"></span>
                            </div>
            </div>
            <div class="row mb-3">
                            <label class="col-sm-3 col-form-label" asp-for="Input.Password">Password</label>
                
                                        <div class="col-sm-9">
                                <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="password" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
                            </div>
            </div>
            <div class="row mb-3">
                            <label class="col-sm-3 col-form-label" asp-for="Input.ConfirmPassword">Confirm Password</label>
                           
                                            <div class="col-sm-9">
                                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="password" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                            </div>
            </div>
            <div class="row mb-3">
                <label class="col-sm-3 col-form-label">Roles</label>
                <div class="col-sm-9">
                    @foreach (var role in Model.AvailableRoles)
                    {
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="Input.SelectedRoles" value="@role.Name" id="role_@role.Id">
                            <label class="form-check-label" for="role_@role.Id">
                                @role.Name
                            </label>
                        </div>
                    }
                </div>
            </div>
          
            <div class="row">
                <label class="col-sm-3 col-form-label"></label>
                <div class="col-sm-9">
                   <button type="submit" class="btn btn-info px-5"> Register</button>
                </div>
                <div>
                    <a asp-action="Index">Back to List</a>
                </div>
            </div>
        </form>
    </div>
</div>
        </div>
    </div>
</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
