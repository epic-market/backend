@page
@model LoginWithRecoveryCodeModel
@{
    ViewData["Title"] = "Recovery code verification";
}
@{
    Layout = "~/Views/Shared/_LoginPartial.cshtml";
}

<div class="section-authentication-signin d-flex align-items-center justify-content-center my-5 my-lg-4">
    <div class="container-fluid">
        <div class="row row-cols-1 row-cols-lg-2 row-cols-xl-3">
            <div class="col mx-auto">
                <div class="card rounded-4">
                    <div class="card-body">
                        <div class="border p-4 rounded-4">
                            <div class="text-center">
                                <img src="assets/images/logo-icon.png" width="70" alt="" />
                                <h5 class="mt-3 mb-0">@ViewData["Title"]</h5>
                                <p class="mb-4">
                                    You have requested to log in with a recovery code. This login will not be remembered until you provide
                                    an authenticator app code at log in or disable 2FA and log in again.
                                </p>
                            </div>
                                    <form method="post">
                                        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                                        <div class="form-floating mb-3">
                                            <input asp-for="Input.RecoveryCode" class="form-control" autocomplete="off" placeholder="RecoveryCode" />
                                            <label asp-for="Input.RecoveryCode" class="form-label"></label>
                                            <span asp-validation-for="Input.RecoveryCode" class="text-danger"></span>
                                        </div>
                                        <button type="submit" class="w-100 btn btn-lg btn-primary">Log in</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>



@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}