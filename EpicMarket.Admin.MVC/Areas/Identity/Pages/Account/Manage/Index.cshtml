@page
@model IndexModel
@{
    ViewData["Title"] = "Profile";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<partial name="_StatusMessage" for="StatusMessage" />

<div class="card border-top border-0 border-4 border-info mb-4 content-fade-in">
    <div class="card-body">
        <div class="d-flex align-items-center mb-3">
            <div class="rounded-pill bg-gradient-cosmic text-white p-2 me-3">
                <i class="bx bx-user fs-4"></i>
            </div>
            <h5 class="card-title mb-0">Personal Information</h5>
        </div>
        
        <p class="text-muted mb-4">Manage your account details and contact information</p>
        
        <form id="profile-form" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            
            <div class="row mb-3">
                <label asp-for="Username" class="col-sm-3 col-form-label"></label>
                <div class="col-sm-9">
                    <input asp-for="Username" class="form-control" placeholder="Please choose your username." disabled />
                </div>
            </div>
            
            <div class="row mb-3">
                <label asp-for="Input.FirstName" class="col-sm-3 col-form-label"></label>
                <div class="col-sm-9">
                    <input asp-for="Input.FirstName" class="form-control" placeholder="Please enter your first name." />
                    <span asp-validation-for="Input.FirstName" class="text-danger"></span>
                </div>
            </div>
            
            <div class="row mb-3">
                <label asp-for="Input.LastName" class="col-sm-3 col-form-label"></label>
                <div class="col-sm-9">
                    <input asp-for="Input.LastName" class="form-control" placeholder="Please enter your last name." />
                    <span asp-validation-for="Input.LastName" class="text-danger"></span>
                </div>
            </div>
            
            <div class="row mb-3">
                <label asp-for="Input.PhoneNumber" class="col-sm-3 col-form-label"></label>
                <div class="col-sm-9">
                    <input asp-for="Input.PhoneNumber" class="form-control" placeholder="Please enter your phone number." />
                    <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                </div>
            </div>
            
            <div class="row mt-4">
                <div class="col-sm-9 offset-sm-3">
                    <button id="update-profile-button" type="submit" class="btn btn-primary">
                        <i class="bx bx-save me-1"></i> Save Changes
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-3 mt-4">
    <div class="card-body p-3">
        <div class="d-flex">
            <div class="text-info me-3">
                <i class="bx bx-info-circle fs-4"></i>
            </div>
            <div>
                <h6 class="mb-1">Profile Information</h6>
                <p class="small text-muted mb-0">
                    Your profile information is used across the platform to personalize your experience.
                    Make sure to keep your contact details up to date.
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
