@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Change password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<partial name="_StatusMessage" for="StatusMessage" />

<div class="card border-top border-0 border-4 border-info mb-4 content-fade-in">
    <div class="card-body">
        <div class="d-flex align-items-center mb-3">
            <div class="rounded-pill bg-gradient-cosmic text-white p-2 me-3">
                <i class="bx bx-lock-alt fs-4"></i>
            </div>
            <h5 class="card-title mb-0">Update Your Password</h5>
        </div>
        
        <p class="text-muted mb-4">Ensure your account remains secure by using a strong password</p>
        
        <form id="change-password-form" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            
            <div class="row mb-3">
                <label asp-for="Input.OldPassword" class="col-sm-3 col-form-label"></label>
                <div class="col-sm-9">
                    <input asp-for="Input.OldPassword" class="form-control" autocomplete="current-password" 
                           aria-required="true" placeholder="Please enter your old password." />
                    <span asp-validation-for="Input.OldPassword" class="text-danger"></span>
                </div>
            </div>
            
            <div class="row mb-3">
                <label asp-for="Input.NewPassword" class="col-sm-3 col-form-label"></label>
                <div class="col-sm-9">
                    <input asp-for="Input.NewPassword" class="form-control" autocomplete="new-password" 
                           aria-required="true" placeholder="Please enter your new password." />
                    <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
                </div>
            </div>
            
            <div class="row mb-3">
                <label asp-for="Input.ConfirmPassword" class="col-sm-3 col-form-label"></label>
                <div class="col-sm-9">
                    <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" 
                           aria-required="true" placeholder="Please confirm your new password."/>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                </div>
            </div>
            
            <div class="row mt-4">
                <div class="col-sm-9 offset-sm-3">
                    <button type="submit" class="btn btn-primary">
                        <i class="bx bx-lock me-1"></i> Update Password
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-3 mt-4">
    <div class="card-body p-3">
        <div class="d-flex">
            <div class="text-warning me-3">
                <i class="bx bx-info-circle fs-4"></i>
            </div>
            <div>
                <h6 class="mb-1">Password Requirements</h6>
                <p class="small text-muted mb-0">
                    For security, your password should be at least 8 characters long and include uppercase letters, 
                    lowercase letters, numbers, and special characters.
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
