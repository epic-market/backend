@model IEnumerable<EpicMarket.Data.Models.SupportQuerys>

@{
    ViewData["Title"] = "Support Queries";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Page Header -->
<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Support</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a asp-action="Index"><i class="bx bx-home-alt"></i></a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Support Queries</li>
            </ol>
        </nav>
    </div>
</div>

<!-- Filter Card -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <h5 class="card-title mb-0">
                <i class="bx bx-filter me-2 text-primary"></i>Search & Filter
            </h5>
            <button class="btn btn-sm btn-link text-decoration-none" type="button" data-bs-toggle="collapse" data-bs-target="#filterCollapse" aria-expanded="true">
                <i class="bx bx-chevron-down"></i>
            </button>
        </div>
        <div class="collapse show" id="filterCollapse">
            <div class="row g-3">
                <div class="col-md-5">
                    <label class="form-label small fw-semibold">Query</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bx bx-search"></i></span>
                        <input type="text" class="form-control border-start-0 ps-0" id="queryFilter" placeholder="Search query text">
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-semibold">Person Type</label>
                    <select class="form-select" id="personTypeFilter">
                        <option value="">All Person Types</option>
                        @foreach (var personType in ViewBag.PersonTypes)
                        {
                            <option value="@personType.ID">@personType.Type</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-semibold">Task Type</label>
                    <select class="form-select" id="taskTypeFilter">
                        <option value="">All Task Types</option>
                        @foreach (var taskType in ViewBag.TaskTypes)
                        {
                            <option value="@taskType.ID">@taskType.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-semibold">Actions</label>
                    <div class="d-flex">
                        <button type="button" class="btn btn-primary me-2 flex-grow-1" id="searchBtn">
                            <i class='bx bx-search me-1'></i>Search
                        </button>
                        <button type="button" class="btn btn-outline-secondary" id="resetFilter">
                            <i class='bx bx-reset'></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Table Header with Add Button -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">Support Queries</h5>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bx bx-plus me-1"></i> Add New Query
    </a>
</div>

<!-- Loading Indicator -->
<div id="loading-indicator" class="text-center py-5 d-none">
    <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
    <p class="mt-2 text-muted">Loading support queries...</p>
</div>

<!-- Data Table Card -->
<div class="card">
    <div class="card-body">
        <!-- Empty State (inside card) -->
        <div id="empty-state" class="text-center py-5 d-none">
            <div class="display-6 text-muted mb-4">
                <i class="bx bx-search-alt"></i>
            </div>
            <h5>No matching support queries found</h5>
            <p class="text-muted">Try adjusting your search or filter criteria</p>
        </div>
        
        <div class="table-responsive">
            <table id="supportQueryTable" class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th data-sort="id">
                            <div class="d-flex align-items-center">
                                ID <i class='bx bx-sort-alt-2 ms-1 text-muted'></i>
                            </div>
                        </th>
                        <th data-sort="query">
                            <div class="d-flex align-items-center">
                                Query <i class='bx bx-sort-alt-2 ms-1 text-muted'></i>
                            </div>
                        </th>
                        <th data-sort="persontype">
                            <div class="d-flex align-items-center">
                                Person Type <i class='bx bx-sort-alt-2 ms-1 text-muted'></i>
                            </div>
                        </th>
                        <th data-sort="tasktype">
                            <div class="d-flex align-items-center">
                                Task Type <i class='bx bx-sort-alt-2 ms-1 text-muted'></i>
                            </div>
                        </th>
                        <th data-sort="createdate">
                            <div class="d-flex align-items-center">
                                Created Date <i class='bx bx-sort-alt-2 ms-1 text-muted'></i>
                            </div>
                        </th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Data will be loaded here via JS -->
                </tbody>
            </table>
        </div>
        
        <!-- Pagination -->
        <div class="d-flex justify-content-between align-items-center mt-3">
            <div class="small text-muted" id="pagination-info"></div>
            <div id="pagination-controls"></div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            let currentPage = 1;
            const pageSize = 10;
            let sortColumn = 'id';
            let sortDirection = 'asc';
            let isLoading = false;

            function loadData() {
                $('#loading-indicator').removeClass('d-none');
                $('#empty-state').addClass('d-none');
                $('#supportQueryTable').addClass('d-none');
                isLoading = true;
                
                // Build filter object
                const filter = {
                    Query: $('#queryFilter').val(),
                    PersonTypeId: $('#personTypeFilter').val() ? parseInt($('#personTypeFilter').val()) : null,
                    TaskTypeId: $('#taskTypeFilter').val() ? parseInt($('#taskTypeFilter').val()) : null,
                    PageNumber: currentPage,
                    PageSize: pageSize,
                    SortColumn: sortColumn,
                    SortDirection: sortDirection
                };
                
                // AJAX request
                $.ajax({
                    url: '@Url.Action("GetFilteredData", "SupportQuerys")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(filter),
                    success: function (response) {
                        isLoading = false;
                        $('#loading-indicator').addClass('d-none');
                        
                        if (response.error) {
                            console.error('Error:', response.error);
                            $('#empty-state').removeClass('d-none');
                            return;
                        }
                        
                        // Check if we have any data
                        if (!response.data || response.data.length === 0) {
                            $('#empty-state').removeClass('d-none');
                            $('#supportQueryTable').addClass('d-none');
                            $('#pagination-info').text('No records found');
                            $('#pagination-controls').html('');
                        } else {
                            // Show table and render data
                            $('#supportQueryTable').removeClass('d-none');
                            renderQueries(response.data);
                            renderPagination(response.totalRecords);
                        }
                    },
                    error: function (xhr, status, error) {
                        isLoading = false;
                        $('#loading-indicator').addClass('d-none');
                        console.error('AJAX Error:', error);
                        $('#empty-state').removeClass('d-none');
                    }
                });
            }

            function renderQueries(queries) {
                let html = '';
                queries.forEach(query => {
                    const createdDate = query.createDate ? new Date(query.createDate).toLocaleDateString() : 'N/A';
                    
                    html += `
                        <tr>
                            <td>${query.id}</td>
                            <td class="text-wrap">${query.query}</td>
                            <td><span class="badge bg-light text-dark">${query.personTypeName || 'N/A'}</span></td>
                            <td><span class="badge bg-info text-dark">${query.taskTypeName || 'N/A'}</span></td>
                            <td>${createdDate}</td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end">
                                    <a href="@Url.Action("Edit", "SupportQuerys")/${query.id}" class="action-btn" title="Edit">
                                        <i class="bx bx-edit text-primary"></i>
                                    </a>
                                    <a href="@Url.Action("Details", "SupportQuerys")/${query.id}" class="action-btn" title="View Details">
                                        <i class="bx bx-detail text-info"></i>
                                    </a>
                                    <a href="@Url.Action("Delete", "SupportQuerys")/${query.id}" class="action-btn" title="Delete">
                                        <i class="bx bx-trash text-danger"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    `;
                });
                
                $('#supportQueryTable tbody').html(html);
            }

            function renderPagination(totalRecords) {
                const totalPages = Math.ceil(totalRecords / pageSize);
                let paginationHtml = '';
                
                // Only show pagination if we have enough records
                if (totalPages > 1) {
                    paginationHtml += '<ul class="pagination pagination-sm mb-0">';
                    
                    // Previous button
                    paginationHtml += `
                        <li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
                            <button class="page-link" data-page="${currentPage - 1}" aria-label="Previous">
                                <span aria-hidden="true">&laquo;</span>
                            </button>
                        </li>
                    `;
                    
                    // Page numbers
                    const startPage = Math.max(1, currentPage - 2);
                    const endPage = Math.min(totalPages, startPage + 4);
                    
                    for (let i = startPage; i <= endPage; i++) {
                        paginationHtml += `
                            <li class="page-item ${currentPage === i ? 'active' : ''}">
                                <button class="page-link" data-page="${i}">${i}</button>
                            </li>
                        `;
                    }
                    
                    // Next button
                    paginationHtml += `
                        <li class="page-item ${currentPage === totalPages ? 'disabled' : ''}">
                            <button class="page-link" data-page="${currentPage + 1}" aria-label="Next">
                                <span aria-hidden="true">&raquo;</span>
                            </button>
                        </li>
                    `;
                    
                    paginationHtml += '</ul>';
                }
                
                // Update pagination controls
                $('#pagination-controls').html(paginationHtml);
                
                // Update pagination info text
                const startRecord = totalRecords === 0 ? 0 : (currentPage - 1) * pageSize + 1;
                const endRecord = Math.min(currentPage * pageSize, totalRecords);
                $('#pagination-info').text(`Showing ${startRecord} to ${endRecord} of ${totalRecords} entries`);
                
                // Attach event handlers to the pagination buttons
                $('#pagination-controls button.page-link').click(function() {
                    if (!isLoading) {
                        currentPage = parseInt($(this).data('page'));
                        loadData();
                        
                        // Scroll back to top of table on page change
                        $('html, body').animate({
                            scrollTop: $("#supportQueryTable").offset().top - 100
                        }, 200);
                    }
                });
            }

            // Search button click handler
            $('#searchBtn').click(function() {
                if (!isLoading) {
                    currentPage = 1; // Reset to first page on new search
                    loadData();
                }
            });
            
            // Reset filter button click handler
            $('#resetFilter').click(function() {
                if (!isLoading) {
                    // Clear all filter inputs
                    $('#queryFilter').val('');
                    $('#personTypeFilter').val('');
                    $('#taskTypeFilter').val('');
                    
                    // Reset to first page and reload
                    currentPage = 1;
                    loadData();
                }
            });
            
            // Enter key on filter inputs
            $('.card-body input').keypress(function(e) {
                if (e.which === 13 && !isLoading) {
                    currentPage = 1;
                    loadData();
                }
            });

            // Table header sorting
            $('#supportQueryTable th[data-sort]').click(function() {
                if (isLoading) return;
                
                const newSortColumn = $(this).data('sort');
                
                // Update visual indicators
                $('#supportQueryTable th i').removeClass('text-primary').addClass('text-muted');
                $(this).find('i').removeClass('text-muted').addClass('text-primary');
                
                if (sortColumn === newSortColumn) {
                    sortDirection = sortDirection === 'asc' ? 'desc' : 'asc';
                    // Update icon
                    if (sortDirection === 'asc') {
                        $(this).find('i').removeClass('bx-sort-down').addClass('bx-sort-up');
                    } else {
                        $(this).find('i').removeClass('bx-sort-up').addClass('bx-sort-down');
                    }
                } else {
                    sortColumn = newSortColumn;
                    sortDirection = 'asc';
                    // Reset and set new icon
                    $('#supportQueryTable th i').removeClass('bx-sort-up bx-sort-down').addClass('bx-sort-alt-2');
                    $(this).find('i').removeClass('bx-sort-alt-2').addClass('bx-sort-up');
                }
                
                currentPage = 1;
                loadData();
            });

            // Initial load
            loadData();
        });
    </script>
}
