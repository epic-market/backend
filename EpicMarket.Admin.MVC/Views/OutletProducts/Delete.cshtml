@model EpicMarket.Data.Models.OutletProduct

@{
    ViewData["Title"] = "Delete Outlet Product";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Outlet Products</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a asp-action="Index"><i class="bx bx-home-alt"></i></a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Delete Outlet Product</li>
            </ol>
        </nav>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <h3 class="card-title">Confirm Outlet Product Deletion</h3>
        <p class="card-text">Are you sure you want to delete this outlet product?</p>

        <div class="table-responsive">
            <table class="table table-bordered">
                <tr>
                    <th class="bg-light" style="width: 30%;">@Html.DisplayNameFor(model => model.OutletID)</th>
                    <td>@Html.DisplayFor(model => model.OutletID)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.Product)</th>
                    <td>@Html.DisplayFor(model => model.Product.ID)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.Outlet)</th>
                    <td>@Html.DisplayFor(model => model.Outlet.ID)</td>
                </tr>
            </table>
        </div>

        <form asp-action="Delete" class="mt-4">
            <input type="hidden" asp-for="ID" />
            <div class="d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bx bx-arrow-back me-1"></i> Back to List
                </a>
                <button type="submit" class="btn btn-danger">
                    <i class="bx bx-trash me-1"></i> Delete
                </button>
            </div>
        </form>
    </div>
</div>