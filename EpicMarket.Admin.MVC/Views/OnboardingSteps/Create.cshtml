@model EpicMarket.Data.Models.OnboardingStep

@{
    ViewData["Title"] = "Create";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Onboarding Step</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a asp-action="Index"><i class="bx bx-home-alt"></i></a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Create</li>
            </ol>
        </nav>
    </div>
</div>
<hr />

<div class="row">
    <div class="col-xl-9 mx-auto">
        <div class="card border-top border-0 border-4 border-info">
            <div class="card-body">
                <div class="border p-4 rounded">
                    <div class="card-title d-flex align-items-center">
                        <div>
                            <i class="bx bxs-user me-1 font-22 text-info"></i>
                        </div>
                        <h5 class="mb-0 text-info">Onboarding Step</h5>
                    </div>
                    <hr />
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="row mb-3">
                <label asp-for="StepName" class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                <input asp-for="StepName" class="form-control" />
                <span asp-validation-for="StepName" class="text-danger"></span>
                            </div>
            </div>
            <div class="row mb-3">
                <label asp-for="StepDescription" class="col-sm-3 col-form-label"></label>
                                <div class="col-sm-9">
                <input asp-for="StepDescription" class="form-control" />
                <span asp-validation-for="StepDescription" class="text-danger"></span>
                            </div>
            </div>
            <div class="row mb-3">
                <label asp-for="PageId" class="col-sm-3 col-form-label"></label>
                <div class="col-sm-9">
                                <select asp-for="PageId" class="form-control" asp-items="ViewBag.PageId"></select>
                     <a asp-action="Create" asp-controller="Pages" asp-route-returnUrl="@Url.Action("Create", "OnboardingSteps")">Not listed? Create one</a>
                </div>
            </div>
            <div class="row mb-3">
                <label asp-for="StepOrder" class="col-sm-3 col-form-label"></label>
                                        <div class="col-sm-9">
                <input asp-for="StepOrder" class="form-control" />
                <span asp-validation-for="StepOrder" class="text-danger"></span>
                            </div>
            </div>
            <div class="row">
                <label class="col-sm-3 col-form-label"></label>
                <div class="col-sm-9">
                    <button type="submit" class="btn btn-info px-5"> Save</button>
                </div>
                <div>
                    <a asp-action="Index">Back to List</a>
                </div>
            </div>
        </form>
    </div>
</div>

