@model EpicMarket.Data.Models.HelpItem

@{
    ViewData["Title"] = "Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Help Item</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a asp-action="Index"><i class="bx bx-home-alt"></i></a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Details</li>
            </ol>
        </nav>
    </div>
</div>
<hr />

<div class="card mb-4">
    <div class="card-body">
        <div class="d-flex justify-content-end mb-3">
            <a asp-action="Edit" class="btn btn-primary px-5" asp-route-id="@Model?.ID">Edit</a>
        </div>
        <dl class="row">
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Name)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Name)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Title)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Title)
            </dd>
          
            <!-- Rest of the fields -->
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.IsShownOnPage)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.IsShownOnPage)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Pages)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Pages.Name)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.CreateDate)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.CreateDate)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.CreateBy)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.CreateBy)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.ModifiedDate)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.ModifiedDate)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.ModifiedBy)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.ModifiedBy)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.IsActive)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.IsActive)
            </dd>
        </dl>
        <div class="card">
            <div class="card-header">
                <p class="fw-bold">
                    @Html.DisplayNameFor(model => model.Description)
                </p>

            </div>
            <div class="card-body">
                <ul class="nav nav-tabs" id="descriptionTabs" role="tablist">
                    <li class="nav-item">
                        <a class="nav-link active" id="preview-tab" data-bs-toggle="tab" href="#preview" role="tab" aria-controls="preview" aria-selected="true">Preview</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" id="raw-tab" data-bs-toggle="tab" href="#raw" role="tab" aria-controls="raw" aria-selected="false">Raw HTML</a>
                    </li>
                </ul>
                <div class="tab-content mt-3">
                    <div class="tab-pane fade show active" id="preview" role="tabpanel" aria-labelledby="preview-tab">
                        <div style="overflow: auto; max-height: 400px; width: 100%;">
                            @Html.Raw(Model.Description)
                        </div>
                    </div>
                    <div class="tab-pane fade" id="raw" role="tabpanel" aria-labelledby="raw-tab">
                        <pre style="white-space: pre-wrap; max-width: 100%; overflow: auto; max-height: 400px;">@Model.Description</pre>
                    </div>
                </div>
            </div>

        </div>
    </div>
    <div class="card-footer">
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bx bx-arrow-back me-1"></i> Back to List
        </a>
    </div>
</div>