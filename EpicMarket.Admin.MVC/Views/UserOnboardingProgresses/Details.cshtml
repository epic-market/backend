@model EpicMarket.Data.Models.UserOnboardingProgress

@{
    ViewData["Title"] = "User Onboarding Progress Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-breadcrumb d-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">User Onboarding Progress</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a asp-action="Index"><i class="bx bx-home-alt"></i></a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Details</li>
            </ol>
        </nav>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="card-title mb-0">User Onboarding Progress Details</h5>
            <a asp-action="Edit" class="btn btn-primary" asp-route-id="@Model?.Id">
                <i class="bx bx-edit me-1"></i> Edit
            </a>
        </div>

        <div class="table-responsive">
            <table class="table table-bordered">
                <tr>
                    <th class="bg-light" style="width: 30%;">@Html.DisplayNameFor(model => model.CompletedAt)</th>
                    <td>@Html.DisplayFor(model => model.CompletedAt)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.IsCompleted)</th>
                    <td>@Html.DisplayFor(model => model.IsCompleted)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.User)</th>
                    <td>@Html.ActionLink(Model.User.UserName, "Details", "AppUsers", new { id = Model.User.Id }, null)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.Step)</th>
                    <td>@Html.ActionLink(Model.Step.StepName, "Details", "OnboardingSteps", new { id = Model.Step.Id }, null)</td>
                </tr>
            </table>
        </div>
    </div>
    <div class="card-footer">
       <a href="javascript:history.go(-1)" class="btn btn-secondary">
           <i class="bx bx-arrow-back me-1"></i> Back
        </a>
    </div>
</div>