@model EpicMarket.Data.Models.Inventory

@{
    ViewData["Title"] = "Delete Inventory";
}

<!-- Page Header -->
<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Inventory</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a asp-action="Index"><i class="bx bx-home-alt"></i></a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Delete</li>
            </ol>
        </nav>
    </div>
</div>

<div class="row">
    <div class="col-12 mb-4">
        <div class="card border-0 shadow-sm border-start border-danger border-4">
            <div class="card-header bg-danger text-white py-3">
                <div class="d-flex align-items-center">
                    <i class="bx bx-trash fs-4 me-2"></i>
                    <h5 class="mb-0">Confirm Deletion</h5>
                </div>
            </div>
            <div class="card-body">
                <div class="alert alert-danger mb-4">
                    <div class="d-flex">
                        <i class="bx bx-error-circle fs-3 me-3"></i>
                        <div>
                            <h5 class="alert-heading">Warning!</h5>
                            <p class="mb-0">Are you sure you want to delete this inventory record? This action cannot be undone and may affect product availability for customers.</p>
                        </div>
                    </div>
                </div>
                
                <div class="row g-4">
                    <!-- Business & Product Summary -->
                    <div class="col-md-12">
                        <div class="card border-0 shadow-sm">
                            <div class="card-body">
                                <h6 class="card-title mb-3">Record Details</h6>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="d-flex mb-3">
                                            <div class="avatar-sm bg-light rounded-circle text-center me-3" style="width: 48px; height: 48px; line-height: 48px;">
                                                <i class="bx bx-store text-primary fs-4"></i>
                                            </div>
                                            <div>
                                                <p class="text-muted mb-0 small">Business</p>
                                                <h6 class="mb-0">@Model.Outlet.Bussiness.Name</h6>
                                            </div>
                                        </div>
                                        
                                        <div class="d-flex mb-3">
                                            <div class="avatar-sm bg-light rounded-circle text-center me-3" style="width: 48px; height: 48px; line-height: 48px;">
                                                <i class="bx bx-building-house text-success fs-4"></i>
                                            </div>
                                            <div>
                                                <p class="text-muted mb-0 small">Outlet</p>
                                                <h6 class="mb-0">@Model.Outlet.Name</h6>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="col-md-6">
                                        <div class="d-flex mb-3">
                                            <div class="avatar-sm bg-light rounded-circle text-center me-3" style="width: 48px; height: 48px; line-height: 48px;">
                                                <i class="bx bx-box text-warning fs-4"></i>
                                            </div>
                                            <div>
                                                <p class="text-muted mb-0 small">Product</p>
                                                <h6 class="mb-0">@Model.ProductVariants.Product.Name</h6>
                                            </div>
                                        </div>
                                        
                                        <div class="d-flex mb-3">
                                            <div class="avatar-sm bg-light rounded-circle text-center me-3" style="width: 48px; height: 48px; line-height: 48px;">
                                                <i class="bx bx-barcode text-danger fs-4"></i>
                                            </div>
                                            <div>
                                                <p class="text-muted mb-0 small">SKU</p>
                                                <h6 class="mb-0">@Model.ProductVariants.SKU</h6>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Inventory Status Summary -->
                    <div class="col-md-12">
                        <div class="card border-0 shadow-sm">
                            <div class="card-body">
                                <h6 class="card-title mb-3">Inventory Status</h6>
                                <div class="row g-3">
                                    <div class="col-md-3">
                                        <div class="border rounded p-3 text-center">
                                            <p class="text-muted mb-1 small">Track Inventory</p>
                                            @if (Model.TrackInventory)
                                            {
                                                <span class="badge bg-success">Yes</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">No</span>
                                            }
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="border rounded p-3 text-center">
                                            <p class="text-muted mb-1 small">Stock Status</p>
                                            @if (Model.IsInStock)
                                            {
                                                <span class="badge bg-success">In Stock</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">Out of Stock</span>
                                            }
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="border rounded p-3 text-center">
                                            <p class="text-muted mb-1 small">Quantity</p>
                                            @if (Model.QuantityAvailable.HasValue)
                                            {
                                                <span class="fw-bold">@Model.QuantityAvailable.Value</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">N/A</span>
                                            }
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="border rounded p-3 text-center">
                                            <p class="text-muted mb-1 small">Back Orders</p>
                                            @if (Model.BackOrders)
                                            {
                                                <span class="badge bg-success">Allowed</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Not Allowed</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-light">
                <form asp-action="Delete" class="d-flex justify-content-between align-items-center">
                    <div>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bx bx-arrow-back me-1"></i> Cancel
                        </a>
                    </div>
                    <div>
                        <input type="hidden" asp-for="ID" />
                        <button type="submit" class="btn btn-danger">
                            <i class="bx bx-trash me-1"></i> Confirm Delete
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
