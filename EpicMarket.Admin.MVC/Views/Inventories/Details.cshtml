@model EpicMarket.Data.Models.Inventory

@{
    ViewData["Title"] = "Inventory Details";
}

<!-- Page Header -->
<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Inventory</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a asp-action="Index"><i class="bx bx-home-alt"></i></a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Details</li>
            </ol>
        </nav>
    </div>
</div>

<!-- Action Buttons -->
<div class="d-flex justify-content-end mb-3">
    <a asp-action="Edit" asp-route-id="@Model.ID" class="btn btn-primary me-2">
        <i class="bx bx-edit me-1"></i> Edit
    </a>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bx bx-arrow-back me-1"></i> Back to List
    </a>
</div>

<div class="row">
    <!-- Main Info Card -->
    <div class="col-12 mb-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-primary text-white py-3">
                <div class="d-flex align-items-center">
                    <i class="bx bx-info-circle fs-4 me-2"></i>
                    <h5 class="mb-0">Inventory Information</h5>
                </div>
            </div>
            <div class="card-body">
                <div class="row g-4">
                    <!-- Business & Outlet Info -->
                    <div class="col-md-6">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body">
                                <h6 class="card-title d-flex align-items-center mb-3">
                                    <i class="bx bx-store text-primary me-2"></i>
                                    Business & Outlet Information
                                </h6>
                                <div class="mb-3">
                                    <div class="d-flex">
                                        <div class="avatar-sm bg-light rounded-circle text-center me-3" style="width: 48px; height: 48px; line-height: 48px;">
                                            <i class="bx bx-store-alt text-primary fs-4"></i>
                                        </div>
                                        <div>
                                            <p class="text-muted mb-0">Business</p>
                                            <h5 class="mb-0">@Model.Outlet.Bussiness.Name</h5>
                                            <p class="text-muted small mb-0">ID: @Model.Outlet.BussinessID</p>
                                        </div>
                                    </div>
                                </div>
                                <hr />
                                <div class="mb-0">
                                    <div class="d-flex">
                                        <div class="avatar-sm bg-light rounded-circle text-center me-3" style="width: 48px; height: 48px; line-height: 48px;">
                                            <i class="bx bx-building-house text-success fs-4"></i>
                                        </div>
                                        <div>
                                            <p class="text-muted mb-0">Outlet</p>
                                            <h5 class="mb-0">@Model.Outlet.Name</h5>
                                            <p class="text-muted small mb-0">ID: @Model.OutletID</p>
                                            @if (!string.IsNullOrEmpty(Model.Outlet.Address?.City))
                                            {
                                                <p class="text-muted small mb-0">Location: @Model.Outlet.Address.City</p>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Product Info -->
                    <div class="col-md-6">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body">
                                <h6 class="card-title d-flex align-items-center mb-3">
                                    <i class="bx bx-package text-primary me-2"></i>
                                    Product Information
                                </h6>
                                <div class="mb-3">
                                    <div class="d-flex">
                                        <div class="avatar-sm bg-light rounded-circle text-center me-3" style="width: 48px; height: 48px; line-height: 48px;">
                                            <i class="bx bx-box text-warning fs-4"></i>
                                        </div>
                                        <div>
                                            <p class="text-muted mb-0">Product</p>
                                            <h5 class="mb-0">@Model.CatalogVariants.Catalog.Name</h5>
                                            <p class="text-muted small mb-0">Catalog ID: @Model.CatalogVariants.CatalogID</p>
                                        </div>
                                    </div>
                                </div>
                                <hr />
                                <div class="mb-0">
                                    <div class="d-flex">
                                        <div class="avatar-sm bg-light rounded-circle text-center me-3" style="width: 48px; height: 48px; line-height: 48px;">
                                            <i class="bx bx-barcode text-danger fs-4"></i>
                                        </div>
                                        <div>
                                            <p class="text-muted mb-0">Variant</p>
                                            <h5 class="mb-0">@Model.CatalogVariants.SKU</h5>
                                            <p class="text-muted small mb-0">Variant ID: @Model.ProductVariantID</p>
                                            @if (!string.IsNullOrEmpty(Model.CatalogVariants.Barcode))
                                            {
                                                <p class="text-muted small mb-0">Barcode: @Model.CatalogVariants.Barcode</p>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Inventory Status -->
                    <div class="col-md-6">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body">
                                <h6 class="card-title d-flex align-items-center mb-3">
                                    <i class="bx bx-list-check text-primary me-2"></i>
                                    Inventory Status
                                </h6>
                                <div class="row g-3">
                                    <div class="col-6">
                                        <div class="border rounded p-3 h-100">
                                            <p class="text-muted mb-1 small">Track Inventory</p>
                                            @if (Model.TrackInventory)
                                            {
                                                <div class="d-flex align-items-center">
                                                    <span class="badge bg-success me-2">Yes</span>
                                                    <span>Tracking enabled</span>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="d-flex align-items-center">
                                                    <span class="badge bg-secondary me-2">No</span>
                                                    <span>Not tracking</span>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="border rounded p-3 h-100">
                                            <p class="text-muted mb-1 small">Stock Status</p>
                                            @if (Model.IsInStock)
                                            {
                                                <div class="d-flex align-items-center">
                                                    <span class="badge bg-success me-2">In Stock</span>
                                                    <span>Available</span>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="d-flex align-items-center">
                                                    <span class="badge bg-danger me-2">Out of Stock</span>
                                                    <span>Unavailable</span>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="border rounded p-3 h-100">
                                            <p class="text-muted mb-1 small">Back Orders</p>
                                            @if (Model.BackOrders)
                                            {
                                                <div class="d-flex align-items-center">
                                                    <span class="badge bg-success me-2">Allowed</span>
                                                    <span>Can order when out of stock</span>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="d-flex align-items-center">
                                                    <span class="badge bg-secondary me-2">Not Allowed</span>
                                                    <span>Cannot order when out of stock</span>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="border rounded p-3 h-100">
                                            <p class="text-muted mb-1 small">Current Quantity</p>
                                            @if (Model.QuantityAvailable.HasValue)
                                            {
                                                <h4 class="mb-0 @(Model.QuantityAvailable.Value > 0 ? "text-success" : "text-danger")">
                                                    @Model.QuantityAvailable.Value
                                                </h4>
                                            }
                                            else
                                            {
                                                <span class="text-muted">Not tracked</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Inventory Thresholds -->
                    <div class="col-md-6">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body">
                                <h6 class="card-title d-flex align-items-center mb-3">
                                    <i class="bx bx-slider text-primary me-2"></i>
                                    Inventory Thresholds
                                </h6>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <div class="border rounded p-3 h-100">
                                            <p class="text-muted mb-1 small">Minimum Stock Level</p>
                                            @if (Model.MinimumStockLevel.HasValue)
                                            {
                                                <h4 class="mb-0">@Model.MinimumStockLevel.Value</h4>
                                                <p class="text-muted small mb-0">Don't let stock go below this</p>
                                            }
                                            else
                                            {
                                                <span class="text-muted">Not set</span>
                                            }
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="border rounded p-3 h-100">
                                            <p class="text-muted mb-1 small">Maximum Stock Level</p>
                                            @if (Model.MaximumStockLevel.HasValue)
                                            {
                                                <h4 class="mb-0">@Model.MaximumStockLevel.Value</h4>
                                                <p class="text-muted small mb-0">Don't order more than this</p>
                                            }
                                            else
                                            {
                                                <span class="text-muted">Not set</span>
                                            }
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="border rounded p-3 h-100">
                                            <p class="text-muted mb-1 small">Reorder Point</p>
                                            @if (Model.ReorderPoint.HasValue)
                                            {
                                                <h4 class="mb-0">@Model.ReorderPoint.Value</h4>
                                                <p class="text-muted small mb-0">Place new order at this level</p>
                                            }
                                            else
                                            {
                                                <span class="text-muted">Not set</span>
                                            }
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="border rounded p-3 h-100 d-flex flex-column justify-content-center">
                                            @if (Model.TrackInventory && Model.QuantityAvailable.HasValue && Model.ReorderPoint.HasValue)
                                            {
                                                @if (Model.QuantityAvailable.Value <= Model.ReorderPoint.Value)
                                                {
                                                    <div class="alert alert-warning mb-0 py-2">
                                                        <i class="bx bx-error-circle me-1"></i>
                                                        Stock is at or below reorder point
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="alert alert-success mb-0 py-2">
                                                        <i class="bx bx-check-circle me-1"></i>
                                                        Stock level is good
                                                    </div>
                                                }
                                            }
                                            else
                                            {
                                                <div class="alert alert-secondary mb-0 py-2">
                                                    <i class="bx bx-info-circle me-1"></i>
                                                    Reorder tracking not configured
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Pricing Information -->
                    <div class="col-md-12">
                        <div class="card border-0 shadow-sm">
                            <div class="card-body">
                                <h6 class="card-title d-flex align-items-center mb-3">
                                    <i class="bx bx-dollar-circle text-primary me-2"></i>
                                    Pricing Information
                                </h6>
                                <div class="row g-3">
                                    <div class="col-md-3">
                                        <div class="border rounded p-3 text-center">
                                            <p class="text-muted mb-1 small">Cost Price</p>
                                            <h4 class="mb-0">@Model.CatalogVariants.CostPrice.ToString("C")</h4>
                                            <p class="text-muted small mb-0">Purchase cost</p>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="border rounded p-3 text-center">
                                            <p class="text-muted mb-1 small">Sale Price</p>
                                            <h4 class="mb-0">@Model.CatalogVariants.SalePrice.ToString("C")</h4>
                                            <p class="text-muted small mb-0">Regular price</p>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="border rounded p-3 text-center">
                                            <p class="text-muted mb-1 small">Compare At Price</p>
                                            @if (Model.CatalogVariants.CompareAtPrice.HasValue)
                                            {
                                                <h4 class="mb-0">@Model.CatalogVariants.CompareAtPrice.Value.ToString("C")</h4>
                                                <p class="text-muted small mb-0">Original price</p>
                                            }
                                            else
                                            {
                                                <span class="text-muted">Not set</span>
                                            }
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="border rounded p-3 text-center">
                                            <p class="text-muted mb-1 small">Profit Margin</p>
                                            @{
                                                var margin = Model.CatalogVariants.SalePrice - Model.CatalogVariants.CostPrice;
                                                var marginPercent = Model.CatalogVariants.CostPrice > 0 
                                                    ? (margin / Model.CatalogVariants.CostPrice) * 100 
                                                    : 0;
                                            }
                                            <h4 class="mb-0">@marginPercent.ToString("F1")%</h4>
                                            <p class="text-muted small mb-0">@margin.ToString("C")</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-light">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="text-muted small">Inventory ID: @Model.ID</span>
                    </div>
                    <div>
                        <a asp-action="Edit" asp-route-id="@Model.ID" class="btn btn-primary btn-sm">
                            <i class="bx bx-edit me-1"></i> Edit
                        </a>
                        <a asp-action="Delete" asp-route-id="@Model.ID" class="btn btn-danger btn-sm">
                            <i class="bx bx-trash me-1"></i> Delete
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
