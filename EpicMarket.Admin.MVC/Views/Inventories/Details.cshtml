@model EpicMarket.Data.Models.Inventory

@{
    ViewData["Title"] = $"{Model.ProductVariants.Product.Name} - Inventory Details";
}

<style>
    .badge {
        padding: 0.5rem 0.75rem;
        font-weight: 500;
        border-radius: 30px;
    }
    .card {
        box-shadow: 0 2px 15px rgba(0,0,0,.04);
        border: 1px solid rgba(0,0,0,.05);
        border-radius: 0.75rem;
        overflow: hidden;
        margin-bottom: 1.5rem;
    }
    .card-header {
        background-color: rgba(0,0,0,.02);
        border-bottom: 1px solid rgba(0,0,0,.05);
    }
    .fw-medium {
        font-weight: 500;
    }
    .info-section {
        padding: 1.5rem;
    }
    .info-title {
        font-size: 1rem;
        color: #666;
        margin-bottom: 1rem;
        font-weight: 600;
        display: flex;
        align-items: center;
    }
    .info-title i {
        margin-right: 0.5rem;
        font-size: 1.1rem;
    }
    .inventory-header {
        position: relative;
        background: linear-gradient(135deg, #f5f7fa 0%, #e9ecef 100%);
        border-radius: 0.75rem;
        padding: 2rem;
        margin-bottom: 1.5rem;
    }
    .status-badge {
        transition: all 0.3s ease;
    }
    .status-badge:hover {
        transform: translateY(-2px);
    }
    .detail-card {
        transition: all 0.3s ease;
        border-radius: 0.75rem;
        overflow: hidden;
    }
    .detail-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 5px 15px rgba(0,0,0,0.08);
    }
    .avatar-sm {
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
    }
    .info-box {
        border: 1px solid rgba(0,0,0,.08);
        border-radius: 0.5rem;
        padding: 1rem;
        height: 100%;
        transition: all 0.3s ease;
    }
    .info-box:hover {
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        transform: translateY(-2px);
    }
    .key-value-item {
        display: flex;
        justify-content: space-between;
        padding: 0.5rem 0;
        border-bottom: 1px solid rgba(0,0,0,.05);
    }
    .key-value-item:last-child {
        border-bottom: none;
    }
</style>

<div class="container-fluid px-4 py-3">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Inventories")">Inventory</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.ProductVariants.Product.Name</li>
        </ol>
    </nav>

    <!-- Inventory Header -->
    <div class="inventory-header mb-4">
        <div class="d-flex flex-wrap justify-content-between align-items-center mb-3">
            <h3 class="mb-0 text-dark d-flex align-items-center">
                <div class="me-2">
                    <div class="rounded-circle d-flex justify-content-center align-items-center bg-light"
                         style="width: 40px; height: 40px; border: 1px solid #ddd;">
                        <i class="bx bx-package text-primary" style="font-size: 20px;"></i>
                    </div>
                </div>
                Inventory for @Model.ProductVariants.Product.Name
            </h3>
            <div>
                <a asp-action="Edit" asp-route-id="@Model.ID" class="btn btn-primary">
                    <i class="bx bx-edit me-1"></i> Edit
                </a>
                <a asp-action="Index" class="btn btn-outline-secondary ms-2">
                    <i class="bx bx-arrow-back me-1"></i> Back to List
                </a>
            </div>
        </div>

        <!-- Status Pills -->
        <div class="d-flex flex-wrap gap-2 mt-3">
            <span class="status-badge badge bg-@(Model.IsInStock ? "success" : "danger") text-white">
                <i class="bx bx-@(Model.IsInStock ? "check-circle" : "x-circle") me-1"></i>
                @(Model.IsInStock ? "In Stock" : "Out of Stock")
            </span>
            <span class="status-badge badge bg-@(Model.TrackInventory ? "info" : "secondary") text-white">
                <i class="bx bx-@(Model.TrackInventory ? "line-chart" : "x") me-1"></i>
                @(Model.TrackInventory ? "Tracking Enabled" : "Not Tracking")
            </span>
            <span class="status-badge badge bg-@(Model.BackOrders ? "warning" : "secondary") text-white">
                <i class="bx bx-@(Model.BackOrders ? "check" : "x") me-1"></i>
                @(Model.BackOrders ? "Back Orders Allowed" : "No Back Orders")
            </span>
            @if (Model.QuantityAvailable.HasValue)
            {
                <span class="status-badge badge bg-primary text-white">
                    <i class="bx bx-cube me-1"></i>
                    Quantity: @Model.QuantityAvailable.Value
                </span>
            }
        </div>
    </div>

    <div class="row g-4">
        <!-- Business & Outlet Info -->
        <div class="col-md-6">
            <div class="card detail-card h-100">
                <div class="card-header bg-light py-3">
                    <div class="d-flex align-items-center">
                        <i class="bx bx-store fs-4 me-2 text-primary"></i>
                        <h5 class="mb-0">Business & Outlet Information</h5>
                    </div>
                </div>
                <div class="card-body">
                    <div class="mb-4">
                        <div class="d-flex">
                            <div class="avatar-sm bg-light rounded-circle text-center me-3">
                                <i class="bx bx-store-alt text-primary fs-4"></i>
                            </div>
                            <div>
                                <p class="text-muted mb-0">Business</p>
                                <h5 class="mb-0">@Model.Outlet.Bussiness.Name</h5>
                                <p class="text-muted small mb-0">ID: @Model.Outlet.BussinessID</p>
                            </div>
                        </div>
                    </div>
                    <hr />
                    <div class="mb-0">
                        <div class="d-flex">
                            <div class="avatar-sm bg-light rounded-circle text-center me-3">
                                <i class="bx bx-building-house text-success fs-4"></i>
                            </div>
                            <div>
                                <p class="text-muted mb-0">Outlet</p>
                                <h5 class="mb-0">@Model.Outlet.Name</h5>
                                <p class="text-muted small mb-0">ID: @Model.OutletID</p>
                                @if (!string.IsNullOrEmpty(Model.Outlet.Address?.City))
                                {
                                    <p class="text-muted small mb-0">Location: @Model.Outlet.Address.City</p>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Product Info -->
        <div class="col-md-6">
            <div class="card detail-card h-100">
                <div class="card-header bg-light py-3">
                    <div class="d-flex align-items-center">
                        <i class="bx bx-package fs-4 me-2 text-primary"></i>
                        <h5 class="mb-0">Product Information</h5>
                    </div>
                </div>
                <div class="card-body">
                    <div class="mb-4">
                        <div class="d-flex">
                            <div class="avatar-sm bg-light rounded-circle text-center me-3">
                                <i class="bx bx-box text-warning fs-4"></i>
                            </div>
                            <div>
                                <p class="text-muted mb-0">Product</p>
                                <h5 class="mb-0">@Model.ProductVariants.Product.Name</h5>
                                <p class="text-muted small mb-0">Product ID: @Model.ProductVariants.ProductID</p>
                            </div>
                        </div>
                    </div>
                    <hr />
                    <div class="mb-0">
                        <div class="d-flex">
                            <div class="avatar-sm bg-light rounded-circle text-center me-3">
                                <i class="bx bx-barcode text-danger fs-4"></i>
                            </div>
                            <div>
                                <p class="text-muted mb-0">Variant</p>
                                <h5 class="mb-0">@Model.ProductVariants.SKU</h5>
                                <p class="text-muted small mb-0">Variant ID: @Model.ProductVariantID</p>
                                @if (!string.IsNullOrEmpty(Model.ProductVariants.Barcode))
                                {
                                    <p class="text-muted small mb-0">Barcode: @Model.ProductVariants.Barcode</p>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Inventory Status -->
        <div class="col-md-6">
            <div class="card detail-card">
                <div class="card-header bg-light py-3">
                    <div class="d-flex align-items-center">
                        <i class="bx bx-list-check fs-4 me-2 text-primary"></i>
                        <h5 class="mb-0">Inventory Status</h5>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-6">
                            <div class="info-box">
                                <p class="text-muted mb-1 small">Track Inventory</p>
                                @if (Model.TrackInventory)
                                {
                                    <div class="d-flex align-items-center">
                                        <span class="badge bg-success me-2">Yes</span>
                                        <span>Tracking enabled</span>
                                    </div>
                                }
                                else
                                {
                                    <div class="d-flex align-items-center">
                                        <span class="badge bg-secondary me-2">No</span>
                                        <span>Not tracking</span>
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="info-box">
                                <p class="text-muted mb-1 small">Stock Status</p>
                                @if (Model.IsInStock)
                                {
                                    <div class="d-flex align-items-center">
                                        <span class="badge bg-success me-2">In Stock</span>
                                        <span>Available</span>
                                    </div>
                                }
                                else
                                {
                                    <div class="d-flex align-items-center">
                                        <span class="badge bg-danger me-2">Out of Stock</span>
                                        <span>Unavailable</span>
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="info-box">
                                <p class="text-muted mb-1 small">Back Orders</p>
                                @if (Model.BackOrders)
                                {
                                    <div class="d-flex align-items-center">
                                        <span class="badge bg-success me-2">Allowed</span>
                                        <span>Can order when out of stock</span>
                                    </div>
                                }
                                else
                                {
                                    <div class="d-flex align-items-center">
                                        <span class="badge bg-secondary me-2">Not Allowed</span>
                                        <span>Cannot order when out of stock</span>
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="info-box">
                                <p class="text-muted mb-1 small">Current Quantity</p>
                                @if (Model.QuantityAvailable.HasValue)
                                {
                                    <h4 class="mb-0 @(Model.QuantityAvailable.Value > 0 ? "text-success" : "text-danger")">
                                        @Model.QuantityAvailable.Value
                                    </h4>
                                }
                                else
                                {
                                    <span class="text-muted">Not tracked</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Inventory Thresholds -->
        <div class="col-md-6">
            <div class="card detail-card">
                <div class="card-header bg-light py-3">
                    <div class="d-flex align-items-center">
                        <i class="bx bx-slider fs-4 me-2 text-primary"></i>
                        <h5 class="mb-0">Inventory Thresholds</h5>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="info-box">
                                <p class="text-muted mb-1 small">Minimum Stock Level</p>
                                @if (Model.MinimumStockLevel.HasValue)
                                {
                                    <h4 class="mb-0">@Model.MinimumStockLevel.Value</h4>
                                    <p class="text-muted small mb-0">Don't let stock go below this</p>
                                }
                                else
                                {
                                    <span class="text-muted">Not set</span>
                                }
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="info-box">
                                <p class="text-muted mb-1 small">Maximum Stock Level</p>
                                @if (Model.MaximumStockLevel.HasValue)
                                {
                                    <h4 class="mb-0">@Model.MaximumStockLevel.Value</h4>
                                    <p class="text-muted small mb-0">Don't order more than this</p>
                                }
                                else
                                {
                                    <span class="text-muted">Not set</span>
                                }
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="info-box">
                                <p class="text-muted mb-1 small">Reorder Point</p>
                                @if (Model.ReorderPoint.HasValue)
                                {
                                    <h4 class="mb-0">@Model.ReorderPoint.Value</h4>
                                    <p class="text-muted small mb-0">Place new order at this level</p>
                                }
                                else
                                {
                                    <span class="text-muted">Not set</span>
                                }
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="info-box">
                                @if (Model.TrackInventory && Model.QuantityAvailable.HasValue && Model.ReorderPoint.HasValue)
                                {
                                    @if (Model.QuantityAvailable.Value <= Model.ReorderPoint.Value)
                                    {
                                        <div class="alert alert-warning mb-0 py-2">
                                            <i class="bx bx-error-circle me-1"></i>
                                            Stock is at or below reorder point
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="alert alert-success mb-0 py-2">
                                            <i class="bx bx-check-circle me-1"></i>
                                            Stock level is good
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="alert alert-secondary mb-0 py-2">
                                        <i class="bx bx-info-circle me-1"></i>
                                        Reorder tracking not configured
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Pricing Information -->
        <div class="col-md-12">
            <div class="card detail-card">
                <div class="card-header bg-light py-3">
                    <div class="d-flex align-items-center">
                        <i class="bx bx-dollar-circle fs-4 me-2 text-primary"></i>
                        <h5 class="mb-0">Pricing Information</h5>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <div class="info-box text-center">
                                <p class="text-muted mb-1 small">Cost Price</p>
                                <h4 class="mb-0">@Model.ProductVariants.CostPrice.ToString("C")</h4>
                                <p class="text-muted small mb-0">Purchase cost</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="info-box text-center">
                                <p class="text-muted mb-1 small">Sale Price</p>
                                <h4 class="mb-0">@Model.ProductVariants.SalePrice.ToString("C")</h4>
                                <p class="text-muted small mb-0">Regular price</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="info-box text-center">
                                <p class="text-muted mb-1 small">Compare At Price</p>
                                @if (Model.ProductVariants.CompareAtPrice.HasValue)
                                {
                                    <h4 class="mb-0">@Model.ProductVariants.CompareAtPrice.Value.ToString("C")</h4>
                                    <p class="text-muted small mb-0">Original price</p>
                                }
                                else
                                {
                                    <span class="text-muted">Not set</span>
                                }
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="info-box text-center">
                                <p class="text-muted mb-1 small">Profit Margin</p>
                                @{
                                    var margin = Model.ProductVariants.SalePrice - Model.ProductVariants.CostPrice;
                                    var marginPercent = Model.ProductVariants.CostPrice > 0 
                                        ? (margin / Model.ProductVariants.CostPrice) * 100 
                                        : 0;
                                }
                                <h4 class="mb-0">@marginPercent.ToString("F1")%</h4>
                                <p class="text-muted small mb-0">@margin.ToString("C")</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer Card -->
    <div class="card">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <span class="text-muted">Inventory ID: @Model.ID</span>
                </div>
                <div>
                    <a asp-action="Edit" asp-route-id="@Model.ID" class="btn btn-primary">
                        <i class="bx bx-edit me-1"></i> Edit
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.ID" class="btn btn-danger ms-2">
                        <i class="bx bx-trash me-1"></i> Delete
                    </a>
                    <a asp-action="Index" class="btn btn-secondary ms-2">
                        <i class="bx bx-arrow-back me-1"></i> Back
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Animation for status badges
            $('.status-badge').each(function(index) {
                const badge = $(this);
                setTimeout(function() {
                    badge.addClass('animate__animated animate__fadeIn');
                }, index * 100);
            });
            
            // Tooltips initialization
            const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl, {
                    delay: { show: 300, hide: 100 }
                });
            });
            
            // Hover effects for info boxes
            $('.info-box').hover(
                function() { $(this).addClass('shadow-sm'); },
                function() { $(this).removeClass('shadow-sm'); }
            );
        });
    </script>
    
    <!-- Include animate.css for animations -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
}
