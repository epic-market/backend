@model EpicMarket.Admin.MVC.Models.SecurityMatrixViewModel

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Access Control</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a asp-action="Index"><i class="bx bx-home-alt"></i></a>
                </li>
            </ol>
        </nav>
    </div>
</div>
<div class="toast-container position-fixed bottom-0 end-0 p-3">
    <div id="liveToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="toast-header">
            <strong class="me-auto">Notification</strong>
            <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
        <div class="toast-body">
            <!-- Toast message will be inserted here -->
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">

            <table id="example" class="table table-striped table-bordered" style="width:100%">
                <thead>
                    <tr>
                        <th>Securable</th>
                        @foreach (var role in Model.RoleNames)
                        {
                            <th>@role</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var securable in Model.Securables)
                    {
                        <tr>
                            <td>@securable.Name</td>
                            @foreach (var role in Model.RoleNames)
                            {
                                <td>
                                    @Html.DropDownList($"AccessType_{securable.Name}_{role}",
                                             new SelectList(Model.AccessTypes, "ID", "Name", securable.RoleAccess[role]),
                                             new
                                             {
                                                 @class = "form-control access-type-dropdown",
                                                 data_securable = securable.Name,
                                                 data_role = role
                                             })
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
            </div>
    </div>
</div>



@section Scripts {
    <script>
        $(document).ready(function () {
            var toast = new bootstrap.Toast(document.getElementById('liveToast'));

            $('.access-type-dropdown').change(function () {
                var dropdown = $(this);
                var securable = dropdown.data('securable');
                var role = dropdown.data('role');
                var accessTypeId = dropdown.val();
                var accessTypeName = dropdown.find("option:selected").text();

                // Add loading indicator
                dropdown.prop('disabled', true);
                dropdown.addClass('opacity-50');

                $.ajax({
                    url: '@Url.Action("UpdateAccessType", "AccessControlLists")',
                    type: 'POST',
                    data: {
                        securable: securable,
                        role: role,
                        accessTypeId: accessTypeId
                    },
                    success: function (result) {
                        if (result.success) {
                            showToast(`Access type for ${securable} - ${role} updated to ${accessTypeName}.`, 'success');
                        } else {
                            showToast('An error occurred while updating the access type.', 'danger');
                        }
                    },
                    error: function (error) {
                        showToast('An error occurred while updating the access type.', 'danger');
                    },
                    complete: function () {
                        // Remove loading indicator
                        dropdown.prop('disabled', false);
                        dropdown.removeClass('opacity-50');
                    }
                });
            });

            function showToast(message, type = 'success') {
                var toastEl = document.getElementById('liveToast');
                var toastBody = toastEl.querySelector('.toast-body');

                // Set the message
                toastBody.textContent = message;

                // Set the color based on the type
                toastEl.className = 'toast';
                if (type === 'success') {
                    toastEl.classList.add('bg-success', 'text-white');
                } else if (type === 'danger') {
                    toastEl.classList.add('bg-danger', 'text-white');
                }

                // Show the toast
                toast.show();
            }
        });
    </script>
}