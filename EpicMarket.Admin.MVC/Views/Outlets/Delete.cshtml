@model EpicMarket.Data.Models.Outlet

@{
    ViewData["Title"] = "Delete Outlet";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Outlets</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a asp-action="Index"><i class="bx bx-home-alt"></i></a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Delete Outlet</li>
            </ol>
        </nav>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <h3 class="card-title">Confirm Outlet Deletion</h3>
        <p class="card-text">Are you sure you want to delete this outlet?</p>

        <div class="table-responsive">
            <table class="table table-bordered">
                <tr>
                    <th class="bg-light" style="width: 30%;">@Html.DisplayNameFor(model => model.Name)</th>
                    <td>@Html.DisplayFor(model => model.Name)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.Description)</th>
                    <td>@Html.DisplayFor(model => model.Description)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.ContactNumber)</th>
                    <td>@Html.DisplayFor(model => model.ContactNumber)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.ContactEmail)</th>
                    <td>@Html.DisplayFor(model => model.ContactEmail)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.Rating)</th>
                    <td>@Html.DisplayFor(model => model.Rating)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.ReviewCount)</th>
                    <td>@Html.DisplayFor(model => model.ReviewCount)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.IsOpen)</th>
                    <td>@Html.DisplayFor(model => model.IsOpen)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.Weight)</th>
                    <td>@Html.DisplayFor(model => model.Weight)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.Bussiness)</th>
                    <td>@Html.DisplayFor(model => model.Bussiness.ID)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.Address)</th>
                    <td>@Html.DisplayFor(model => model.Address.Id)</td>
                </tr>
            </table>
        </div>

        <form asp-action="Delete" class="mt-4">
            <input type="hidden" asp-for="ID" />
            <div class="d-flex justify-content-between">
               <a href="javascript:history.go(-1)" class="btn btn-secondary">
                   <i class="bx bx-arrow-back me-1"></i> Back
                </a>
                <button type="submit" class="btn btn-danger">
                    <i class="bx bx-trash me-1"></i> Delete
                </button>
            </div>
        </form>
    </div>
</div>