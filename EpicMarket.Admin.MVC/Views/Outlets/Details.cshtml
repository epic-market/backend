@model EpicMarket.Admin.MVC.Models.OutletsDetailsModel

@{
    ViewData["Title"] = $"{Model.Outlet.Name} - Outlet Details";
}

<style>
    .badge {
        padding: 0.5rem 0.75rem;
        font-weight: 500;
        border-radius: 30px;
    }
    .list-group-item {
        border-width: 0;
        padding: 0.8rem 0;
        border-bottom: 1px solid rgba(0,0,0,.1);
    }
    .card {
        box-shadow: 0 2px 15px rgba(0,0,0,.04);
        border: 1px solid rgba(0,0,0,.05);
        border-radius: 0.75rem;
        overflow: hidden;
        margin-bottom: 1.5rem;
    }
    .card-header {
        background-color: rgba(0,0,0,.02);
        border-bottom: 1px solid rgba(0,0,0,.05);
    }
    .fw-medium {
        font-weight: 500;
    }
    .outlet-image {
        height: 300px;
        object-fit: cover;
        border-radius: 0.5rem;
        transition: transform 0.3s ease;
    }
    .outlet-image:hover {
        transform: scale(1.02);
    }
    .gallery-item {
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
        border-radius: 0.5rem;
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    }
    .gallery-item:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 16px rgba(0,0,0,0.15);
    }
    .gallery-img {
        height: 180px;
        object-fit: cover;
        width: 100%;
    }
    .info-section {
        padding: 1.5rem;
        margin-bottom: 1.5rem;
    }
    .info-title {
        font-size: 1rem;
        color: #666;
        margin-bottom: 1rem;
        font-weight: 600;
        display: flex;
        align-items: center;
    }
    .info-title i {
        margin-right: 0.5rem;
        font-size: 1.1rem;
    }
    .key-value-item {
        display: flex;
        justify-content: space-between;
        padding: 0.5rem 0;
        border-bottom: 1px solid rgba(0,0,0,.05);
    }
    .key-value-item:last-child {
        border-bottom: none;
    }
    .outlet-header {
        position: relative;
        background: linear-gradient(135deg, #f5f7fa 0%, #e9ecef 100%);
        border-radius: 0.75rem;
        padding: 2rem;
        margin-bottom: 1.5rem;
    }
    .status-badge {
        transition: all 0.3s ease;
    }
    .status-badge:hover {
        transform: translateY(-2px);
    }
    .detail-section {
        background-color: #fff;
        border-radius: 0.75rem;
        box-shadow: 0 2px 10px rgba(0,0,0,.03);
        overflow: hidden;
    }
    .tab-content {
        background-color: #fff;
        border-radius: 0 0 0.75rem 0.75rem;
    }
    .nav-tabs .nav-link.active {
        border-color: transparent;
        border-bottom: 3px solid #0d6efd;
        background-color: transparent;
        color: #0d6efd;
    }
    .nav-tabs .nav-link {
        border: none;
        color: #6c757d;
        font-weight: 500;
        padding: 0.75rem 1rem;
    }
    @@media (max-width: 768px) {
        .outlet-image {
            height: 200px;
        }
        .gallery-img {
            height: 120px;
        }
    }
</style>

<div class="container-fluid px-4 py-3">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Outlets")">Outlets</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Outlet.Name</li>
        </ol>
    </nav>

    <!-- Outlet Header -->
    <div class="outlet-header mb-4">
        <div class="d-flex flex-wrap justify-content-between align-items-center mb-3">
            <h3 class="mb-0 text-dark d-flex align-items-center">
                <div class="me-2">
                    <div class="rounded-circle d-flex justify-content-center align-items-center bg-light"
                         style="width: 40px; height: 40px; border: 1px solid #ddd;">
                        <i class="bx bx-store text-primary" style="font-size: 20px;"></i>
                    </div>
                </div>
                @Html.DisplayFor(model => model.Outlet.Name)
            </h3>
            <div>
                <a asp-action="Edit" class="btn btn-primary" asp-route-id="@Model?.Outlet.ID">
                    <i class="bx bx-edit me-1"></i> Edit
                </a>
            </div>
        </div>

        <!-- Status Pills -->
        <div class="d-flex flex-wrap gap-2 mt-3">
            @{
                var isVerified = Model.Outlet.StatusOptionSets.Status.Equals("Verified", StringComparison.OrdinalIgnoreCase);
                var statusColor = isVerified ? "success" : "danger";
                var iconClass = isVerified ? "bx-check-circle" : "bx-x-circle";
                
                var isOpenIcon = Model.Outlet.IsOpen ? "bx-door-open" : "bx-door-closed";
                var isOpenColor = Model.Outlet.IsOpen ? "success" : "danger";
                var isOpenText = Model.Outlet.IsOpen ? "Open" : "Closed";
            }
            
            <span class="status-badge badge bg-@statusColor text-white">
                <i class="bx @iconClass me-1"></i>
                @Html.DisplayFor(model => model.Outlet.StatusOptionSets.Status)
            </span>
            <span class="status-badge badge bg-@isOpenColor text-white">
                <i class="bx @isOpenIcon me-1"></i>
                @isOpenText
            </span>
            <span class="status-badge badge bg-warning text-dark">
                <i class="bx bx-star me-1"></i>
                Rating: @Html.DisplayFor(model => model.Outlet.Rating)
            </span>
            <span class="status-badge badge bg-info text-white">
                <i class="bx bx-comment-dots me-1"></i>
                Reviews: @Html.DisplayFor(model => model.Outlet.ReviewCount)
            </span>
            <span class="status-badge badge bg-primary text-white">
                <i class="bx bx-weight me-1"></i>
                Weight: @Html.DisplayFor(model => model.Outlet.Weight)
            </span>
        </div>
    </div>

    <div class="row g-4">
        <!-- Outlet Image -->
        <div class="col-lg-4">
            <div class="card h-100">
                <div class="card-body p-3">
                    <div class="text-center mb-4">
                        @if (!string.IsNullOrEmpty(ViewBag.thumbnail))
                        {
                            <a href="@Url.Action("DisplayImage", "File", new { key = ViewBag.thumbnail })" 
                               target="_blank" class="d-block" data-lightbox="outlet-image">
                                <img src="@Url.Action("DisplayImage", "File", new { key = ViewBag.thumbnail })" 
                                     alt="@Model.Outlet.Name"
                                     class="outlet-image img-fluid shadow-sm mb-3" 
                                     style="width: 100%;">
                            </a>
                        }
                        else
                        {
                            <div class="text-center p-5 bg-light rounded shadow-sm mb-3">
                                <i class="bx bx-store-alt text-muted" style="font-size: 80px;"></i>
                                <p class="text-muted mb-0 mt-3">No image available</p>
                            </div>
                        }
                    </div>

                    <!-- Outlet Description -->
                    <div class="mb-4">
                        <h5 class="info-title border-bottom pb-2 mb-3">
                            <i class="bx bx-info-circle"></i> Outlet Description
                        </h5>
                        <p class="mb-0">@Html.DisplayFor(model => model.Outlet.Description)</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Outlet Details -->
        <div class="col-lg-8">
            <div class="card mb-4">
                <div class="card-body p-0">
                    <div class="row g-0">
                        <!-- Basic Info -->
                        <div class="col-md-6 info-section border-end">
                            <h5 class="info-title">
                                <i class="bx bx-store"></i> Outlet Information
                            </h5>
                            <div class="key-value-item">
                                <span class="text-muted">ID</span>
                                <span class="fw-medium">@Model.Outlet.ID</span>
                            </div>
                            <div class="key-value-item">
                                <span class="text-muted">Business ID</span>
                                <span class="fw-medium">@Html.DisplayFor(model => model.Outlet.Bussiness.ID)</span>
                            </div>
                            <div class="key-value-item">
                                <span class="text-muted">Business Name</span>
                                <span class="fw-medium">
                                    <a asp-controller="Businesses" asp-action="Details" asp-route-id="@Model.Outlet.Bussiness.ID" class="text-primary">
                                        @Html.DisplayFor(model => model.Outlet.Bussiness.Name)
                                    </a>
                                </span>
                            </div>
                            <div class="key-value-item">
                                <span class="text-muted">Contact Number</span>
                                <span class="fw-medium">@Html.DisplayFor(model => model.Outlet.ContactNumber)</span>
                            </div>
                            <div class="key-value-item">
                                <span class="text-muted">Contact Email</span>
                                <span class="fw-medium">@Html.DisplayFor(model => model.Outlet.ContactEmail)</span>
                            </div>
                        </div>

                        <!-- Additional Info -->
                        <div class="col-md-6 info-section">
                            <h5 class="info-title">
                                <i class="bx bx-map-pin"></i> Location & Timestamps
                            </h5>
                            <div class="key-value-item">
                                <span class="text-muted">Address</span>
                                <span class="fw-medium">
                                    @Html.DisplayFor(model => model.Outlet.Address.Address1),
                                    @Html.DisplayFor(model => model.Outlet.Address.City),
                                    @Html.DisplayFor(model => model.Outlet.Address.State),
                                    @Html.DisplayFor(model => model.Outlet.Address.Pincode)
                                </span>
                            </div>
                            <div class="key-value-item">
                                <span class="text-muted">Created Date</span>
                                <span class="fw-medium">@Model.Outlet.CreateDate.ToString("dd MMM yyyy HH:mm")</span>
                            </div>
                            <div class="key-value-item">
                                <span class="text-muted">Created By</span>
                                <span class="fw-medium">@Html.DisplayFor(model => model.Outlet.CreateBy)</span>
                            </div>
                            <div class="key-value-item">
                                <span class="text-muted">Modified Date</span>
                                <span class="fw-medium">@Model.Outlet.ModifiedDate?.ToString("dd MMM yyyy HH:mm") ?? "N/A"</span>
                            </div>
                            <div class="key-value-item">
                                <span class="text-muted">Modified By</span>
                                <span class="fw-medium">@Html.DisplayFor(model => model.Outlet.ModifiedBy)</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Branch Images Card -->
            <div class="card mb-4">
                <div class="card-header py-3">
                    <h5 class="mb-0">
                        <i class="bx bx-images me-2"></i>
                        Branch Images
                    </h5>
                </div>
                <div class="card-body">
                    @if (ViewBag.attachments != null && ViewBag.attachments.Count > 0)
                    {
                        <div class="row row-cols-1 row-cols-md-3 g-3">
                            @foreach (var imageKey in ViewBag.attachments)
                            {
                                <div class="col">
                                    <div class="gallery-item h-100">
                                        <a href="@Url.Action("DisplayImage", "File", new { key = imageKey })" 
                                           target="_blank" class="d-block h-100" data-lightbox="branch-images">
                                            <img src="@Url.Action("DisplayImage", "File", new { key = imageKey })"
                                                 class="gallery-img w-100 h-100"
                                                 alt="Branch Image">
                                        </a>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info mb-0">
                            <i class="bx bx-info-circle me-1"></i>
                            No branch images found.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Tabs Section -->
    <div class="card">
        <div class="card-body p-0">
            <ul class="nav nav-tabs nav-primary" role="tablist">
                <li class="nav-item" role="presentation">
                    <a class="nav-link active" data-bs-toggle="tab" href="#primaryorders" role="tab" aria-selected="true">
                        <div class="d-flex align-items-center">
                            <div class="tab-icon">
                                <i class='bx bx-cart font-18 me-1'></i>
                            </div>
                            <div class="tab-title"> Orders </div>
                        </div>
                    </a>
                </li>
                <li class="nav-item" role="presentation">
                    <a class="nav-link" data-bs-toggle="tab" href="#primaryproducts" role="tab" aria-selected="false">
                        <div class="d-flex align-items-center">
                            <div class="tab-icon">
                                <i class='bx bx-package font-18 me-1'></i>
                            </div>
                            <div class="tab-title"> Products </div>
                        </div>
                    </a>
                </li>
                <li class="nav-item" role="presentation">
                    <a class="nav-link" data-bs-toggle="tab" href="#primaryemployee" role="tab" aria-selected="false">
                        <div class="d-flex align-items-center">
                            <div class="tab-icon">
                                <i class='bx bx-user font-18 me-1'></i>
                            </div>
                            <div class="tab-title"> Employees </div>
                        </div>
                    </a>
                </li>
            </ul>
            <div class="tab-content pt-3">
                <div class="tab-pane fade show active" id="primaryorders" role="tabpanel">
                    <div class="p-3">
                        <div class="table-responsive">
                            <table id="ordersTable" class="table table-striped table-bordered" style="width:100%">
                                <thead class="table-light">
                                    <tr>
                                        <th>ID</th>
                                        <th>Order Date</th>
                                        <th>Payment Mode</th>
                                        <th>Customer</th>
                                        <th>Items</th>
                                        <th>Total</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.Orders)
                                    {
                                        <tr>
                                            <td>@Html.DisplayFor(modelItem => item.ID)</td>
                                            <td>@Html.DisplayFor(modelItem => item.OrderAt)</td>
                                            <td>@Html.DisplayFor(modelItem => item.PaymentMode)</td>
                                            <td>
                                                <span class="fw-medium text-primary">@Html.DisplayFor(modelItem => item.Person.UserName)</span>
                                            </td>
                                            <td>@Html.DisplayFor(modelItem => item.TotalItems)</td>
                                            <td>
                                                <span class="fw-medium">₹@Html.DisplayFor(modelItem => item.TotalPrice)</span>
                                            </td>
                                            <td>
                                                <div class="d-flex gap-2">
                                                    <a asp-controller="Orders" asp-action="Edit" asp-route-id="@item.ID" 
                                                       class="btn btn-sm btn-outline-primary">
                                                        <i class="bx bx-edit"></i>
                                                    </a>
                                                    <a asp-controller="Orders" asp-action="Details" asp-route-id="@item.ID" 
                                                       class="btn btn-sm btn-outline-info">
                                                        <i class="bx bx-detail"></i>
                                                    </a>
                                                    <a asp-controller="Orders" asp-action="Delete" asp-route-id="@item.ID" 
                                                       class="btn btn-sm btn-outline-danger">
                                                        <i class="bx bx-trash"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="tab-pane fade" id="primaryproducts" role="tabpanel">
                    <div class="p-3">
                        <div class="table-responsive">
                            <table id="productsTable" class="table table-striped table-bordered" style="width:100%">
                                <thead class="table-light">
                                    <tr>
                                        <th>ID</th>
                                        <th>Product Name</th>
                                        <th>Category</th>
                                        <th>Product</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.Inventorys)
                                    {
                                        <tr>
                                            <td>@Html.DisplayFor(modelItem => item.ID)</td>
                                            <td>
                                                <span class="fw-medium text-primary">@Html.DisplayFor(modelItem => item.ProductVariants.Product.Name)</span>
                                            </td>
                                            <td>@Html.DisplayFor(modelItem => item.ProductVariants.Product.Category)</td>
                                            <td>@Html.DisplayFor(modelItem => item.ProductVariants.Product)</td>
                                            <td>
                                                <div class="d-flex gap-2">
                                                    <a asp-controller="OutletProducts" asp-action="Edit" asp-route-id="@item.ID" 
                                                       class="btn btn-sm btn-outline-primary">
                                                        <i class="bx bx-edit"></i>
                                                    </a>
                                                    <a asp-controller="OutletProducts" asp-action="Details" asp-route-id="@item.ID" 
                                                       class="btn btn-sm btn-outline-info">
                                                        <i class="bx bx-detail"></i>
                                                    </a>
                                                    <a asp-controller="OutletProducts" asp-action="Delete" asp-route-id="@item.ID" 
                                                       class="btn btn-sm btn-outline-danger">
                                                        <i class="bx bx-trash"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="tab-pane fade" id="primaryemployee" role="tabpanel">
                    <div class="p-3">
                        <div class="table-responsive">
                            <table id="employeesTable" class="table table-striped table-bordered" style="width:100%">
                                <thead class="table-light">
                                    <tr>
                                        <th>ID</th>
                                        <th>Name</th>
                                        <th>Username</th>
                                        <th>Phone Number</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.OutletEmployees)
                                    {
                                        <tr>
                                            <td>@Html.DisplayFor(modelItem => item.Person.Id)</td>
                                            <td>
                                                <span class="fw-medium text-primary">@Html.DisplayFor(modelItem => item.Person.FirstName)</span>
                                            </td>
                                            <td>@Html.DisplayFor(modelItem => item.Person.UserName)</td>
                                            <td>@Html.DisplayFor(modelItem => item.Person.PhoneNumber)</td>
                                            <td>
                                                <div class="d-flex gap-2">
                                                    <a asp-controller="OutletPersons" asp-action="Edit" asp-route-id="@item.ID" 
                                                       class="btn btn-sm btn-outline-primary">
                                                        <i class="bx bx-edit"></i>
                                                    </a>
                                                    <a asp-controller="OutletPersons" asp-action="Details" asp-route-id="@item.ID" 
                                                       class="btn btn-sm btn-outline-info">
                                                        <i class="bx bx-detail"></i>
                                                    </a>
                                                    <a asp-controller="OutletPersons" asp-action="Delete" asp-route-id="@item.ID" 
                                                       class="btn btn-sm btn-outline-danger">
                                                        <i class="bx bx-trash"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="card-footer">
            <a href="javascript:history.go(-1)" class="btn btn-secondary">
                <i class="bx bx-arrow-back me-1"></i> Back
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Initialize DataTables with consistent styling
            $('#ordersTable, #productsTable, #employeesTable').DataTable({
                pageLength: 10,
                responsive: true,
                dom: '<"row mb-3"<"col-md-6"l><"col-md-6"f>><"row"<"col-md-12"t>><"row"<"col-md-6"i><"col-md-6"p>>',
                language: {
                    search: "",
                    searchPlaceholder: "Search..."
                }
            });
            
            // Animation for status badges
            $('.status-badge').each(function(index) {
                const badge = $(this);
                setTimeout(function() {
                    badge.addClass('animate__animated animate__fadeIn');
                }, index * 100);
            });
            
            // Gallery item hover effects
            $('.gallery-item').hover(
                function() { $(this).addClass('shadow'); },
                function() { $(this).removeClass('shadow'); }
            );
            
            // Tooltips initialization
            const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl, {
                    delay: { show: 300, hide: 100 }
                });
            });
        });
    </script>
    
    <!-- Optional: Include the lightbox library if not already included -->
    @if (!Context.Items.ContainsKey("LightboxIncluded"))
    {
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/lightbox2/2.11.3/css/lightbox.min.css" integrity="sha512-ZKX+BvQihRJPA8CROKBhDNvoc2aDMOdAlcm7TUQY+35XYtrd3yh95QOOhsPDQY9QnKE0Wqag9y38OIgEvb88cA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
        <script src="https://cdnjs.cloudflare.com/ajax/libs/lightbox2/2.11.3/js/lightbox.min.js" integrity="sha512-k2GFCTbp9rQU412BStrcD/rlwv1PYec9SNrkbQlo6RZCf75l6KcC3UwDY8H5n5hl4v77IDtIPwOk9Dqjs/mMBQ==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
        
        Context.Items["LightboxIncluded"] = true;
    }
    
    <!-- Include animate.css for animations -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
}