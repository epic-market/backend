@model EpicMarket.Data.Models.CommunicationQueue

@{
    ViewData["Title"] = "Delete Communication Queue";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .card {
        box-shadow: 0 2px 15px rgba(0,0,0,.04);
        border: 1px solid rgba(0,0,0,.05);
        border-radius: 0.75rem;
        overflow: hidden;
    }
    .badge {
        padding: 0.5rem 0.75rem;
        font-weight: 500;
        border-radius: 30px;
    }
    .delete-warning {
        background-color: #fff5f5;
        border-left: 4px solid #dc3545;
        padding: 1rem;
        margin-bottom: 1.5rem;
        border-radius: 0.5rem;
    }
    .key-value-item {
        display: flex;
        justify-content: space-between;
        padding: 0.5rem 0;
        border-bottom: 1px solid rgba(0,0,0,.05);
    }
    .key-value-item:last-child {
        border-bottom: none;
    }
    .message-body {
        white-space: pre-wrap;
        max-height: 200px;
        overflow-y: auto;
        padding: 1rem;
        background-color: #f8f9fa;
        border-radius: 0.5rem;
        font-size: 0.9rem;
    }
</style>

<div class="container-fluid px-4 py-3">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "CommunicationQueues")">Communication Queues</a></li>
            <li class="breadcrumb-item active" aria-current="page">Delete</li>
        </ol>
    </nav>

    <!-- Delete Warning -->
    <div class="delete-warning">
        <h5 class="text-danger mb-2"><i class="bx bx-error-circle me-2"></i>Warning</h5>
        <p class="mb-0">You are about to permanently delete this communication queue item. This action cannot be undone. Please confirm your decision.</p>
    </div>

    <div class="row g-4">
        <!-- Communication Details -->
        <div class="col-lg-5">
            <div class="card mb-4">
                <div class="card-header py-3">
                    <h5 class="mb-0"><i class="bx bx-info-circle me-1"></i> Communication Summary</h5>
                </div>
                <div class="card-body">
                    <div class="key-value-item">
                        <span class="text-muted">ID</span>
                        <span class="fw-medium">@Model.ID</span>
                    </div>
                    <div class="key-value-item">
                        <span class="text-muted">Subject</span>
                        <span class="fw-medium">@Model.Subject</span>
                    </div>
                    <div class="key-value-item">
                        <span class="text-muted">Recipient</span>
                        <span class="fw-medium">@Model.NotificationRecipient</span>
                    </div>
                    <div class="key-value-item">
                        <span class="text-muted">Contact Method</span>
                        <span class="fw-medium">
                            @if (Model.ContactMethod != null)
                            {
                                @Model.ContactMethod.Name
                            }
                            else
                            {
                                <span class="text-muted">N/A</span>
                            }
                        </span>
                    </div>
                    <div class="key-value-item">
                        <span class="text-muted">Status</span>
                        <span class="fw-medium">
                            @if (Model.CommunicationStatus != null)
                            {
                                <span class="badge bg-@GetStatusBadgeColor(Model.CommunicationStatus.Name)">
                                    @Model.CommunicationStatus.Name
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Pending</span>
                            }
                        </span>
                    </div>
                    <div class="key-value-item">
                        <span class="text-muted">Retry Count</span>
                        <span class="fw-medium">@Model.RetryCount</span>
                    </div>
                    <div class="key-value-item">
                        <span class="text-muted">Scheduled Date</span>
                        <span class="fw-medium">
                            @(Model.ScheduledDate.HasValue ? Model.ScheduledDate.Value.ToString("dd MMM yyyy HH:mm") : "N/A")
                        </span>
                    </div>
                    <div class="key-value-item">
                        <span class="text-muted">Sent Date</span>
                        <span class="fw-medium">
                            @(Model.SentDate.HasValue ? Model.SentDate.Value.ToString("dd MMM yyyy HH:mm") : "N/A")
                        </span>
                    </div>
                    <div class="key-value-item">
                        <span class="text-muted">Created</span>
                        <span class="fw-medium">@Model.CreateDate.ToString("dd MMM yyyy HH:mm")</span>
                    </div>
                    <div class="key-value-item">
                        <span class="text-muted">Created By</span>
                        <span class="fw-medium">@Model.CreateBy</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Message Preview -->
        <div class="col-lg-7">
            <div class="card mb-4">
                <div class="card-header py-3">
                    <h5 class="mb-0"><i class="bx bx-envelope me-1"></i> Message Preview</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <h6 class="text-muted mb-2">Message Content</h6>
                        <div class="message-body">
                            @if (!string.IsNullOrEmpty(Model.MessageText))
                            {
                                @Model.MessageText
                            }
                            else if (!string.IsNullOrEmpty(Model.MessageData))
                            {
                                @Model.MessageData
                            }
                            else
                            {
                                <p class="text-muted">No message content available</p>
                            }
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="mb-3">
                            <h6 class="text-muted mb-2">Error Message</h6>
                            <div class="message-body bg-danger bg-opacity-10 text-danger">
                                @Model.ErrorMessage
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Delete Form -->
    <div class="card mt-3">
        <div class="card-body">
            <form asp-action="Delete">
                <input type="hidden" asp-for="ID" />
                <div class="d-flex justify-content-between">
                    <a href="javascript:history.go(-1)" class="btn btn-secondary">
                        <i class="bx bx-arrow-back me-1"></i> Cancel
                    </a>
                    <button type="submit" class="btn btn-danger">
                        <i class="bx bx-trash me-1"></i> Confirm Delete
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@functions {
    public string GetStatusBadgeColor(string status)
    {
        if (string.IsNullOrEmpty(status))
            return "secondary";
            
        return status.ToLower() switch
        {
            "sent" => "success",
            "delivered" => "success",
            "failed" => "danger",
            "pending" => "warning",
            "processing" => "info",
            "retry" => "primary",
            "cancelled" => "dark",
            _ => "secondary"
        };
    }
}