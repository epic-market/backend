@model EpicMarket.Data.Models.Catalog

@{
    ViewData["Title"] = "Create";
}

<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Product</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a asp-action="Index"><i class="bx bx-home-alt"></i></a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Create Product</li>
            </ol>
        </nav>
    </div>
</div>
<hr />

<div class="row">
    <div class="col-xl-10 mx-auto">
        <form asp-action="Create" enctype="multipart/form-data" id="createProductForm">
            <!-- Step 1: Business Selection -->
            <div class="card border-top border-0 border-4 border-primary mb-4 shadow-sm">
                <div class="card-header bg-transparent border-0">
                    <h5 class="card-title mb-0">
                        <i class="bx bx-store-alt me-2"></i>Select Business
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <label asp-for="BusinessID" class="col-sm-3 col-form-label fw-bold">Business</label>
                        <div class="col-sm-9">
                            <select class="form-select select2" asp-for="BusinessID" asp-items="ViewBag.BusinessID" 
                                    required>
                                <option value="">Select Business</option>
                            </select>
                            <div class="form-text text-muted">Select the business this product belongs to</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Step 2: Basic Details -->
            <div class="card border-top border-0 border-4 border-primary mb-4 shadow-sm product-details-section" style="display:none">
                <div class="card-header bg-transparent border-0">
                    <h5 class="card-title mb-0">
                        <i class="bx bx-info-circle me-2"></i>Basic Details
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <label asp-for="Name" class="col-sm-3 col-form-label fw-bold">Product Name</label>
                        <div class="col-sm-9">
                            <input asp-for="Name" class="form-control" required />
                            <div class="form-text text-muted">Enter a descriptive name for your product</div>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label asp-for="Description" class="col-sm-3 col-form-label fw-bold">Description</label>
                        <div class="col-sm-9">
                            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                            <div class="form-text text-muted">Provide a detailed description of your product</div>
                        </div>
                    </div>
                    
                    <!-- Highlights Section -->
                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label fw-bold">Highlights</label>
                        <div class="col-sm-9">
                            <div id="highlightsContainer" class="mb-2">
                                <!-- Highlight entries will be added here -->
                            </div>
                            <button type="button" class="btn btn-outline-primary btn-sm" id="addHighlight">
                                <i class="bx bx-plus"></i> Add Highlight
                            </button>
                            <div class="form-text text-muted">Add key features or specifications of your product</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Step 3: Pricing & Settings -->
            <div class="card border-top border-0 border-4 border-primary mb-4 shadow-sm product-details-section" style="display:none">
                <div class="card-header bg-transparent border-0">
                    <h5 class="card-title mb-0">
                        <i class="bx bx-cog me-2"></i>Pricing & Settings
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label fw-bold">Product Settings</label>
                        <div class="col-sm-9">
                            <div class="form-check form-switch mb-2">
                                <input class="form-check-input" asp-for="RequiresRefrigeration" />
                                <label class="form-check-label">Requires Refrigeration</label>
                            </div>
                            <div class="form-check form-switch">
                                <input class="form-check-input" asp-for="IsRecommended" />
                                <label class="form-check-label">Is Recommended</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Step 4: Variants Section -->
            <div id="variantsSection" class="card border-top border-0 border-4 border-primary mb-4 shadow-sm product-details-section" style="display:none">
                <div class="card-header bg-transparent border-0">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="card-title mb-0">
                            <i class="bx bx-layer me-2"></i>Product Variants
                        </h5>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="hasVariantsToggle">
                            <label class="form-check-label" for="hasVariantsToggle">Has Variants</label>
                            <input type="hidden" name="hasVariants" id="hasVariantsField" value="false">
                            <div class="form-text text-muted small mt-1" id="variantToggleHelp">
                                Note: Single variants will automatically be set as default. Products with multiple variants require selecting one as default.
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <!-- Default Variant Card (shown when no variants) -->
                    <div id="defaultVariantCard">
                        <div class="card border shadow-sm">
                            <div class="card-body">
                                <h6 class="card-title mb-4">
                                    <i class="bx bx-package me-2"></i>Default Product Details
                                    <input type="hidden" name="variants_0_IsDefault" value="true">
                                </h6>
                                
                                <!-- Basic Info -->
                                <div class="row mb-4">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label fw-bold">SKU</label>
                                            <input type="text" class="form-control default-variant-field" name="variants_0_SKU" required>
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label fw-bold">Barcode</label>
                                            <input type="text" class="form-control default-variant-field" name="variants_0_Barcode">
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label fw-bold">Cost Price</label>
                                            <input type="number" step="0.01" class="form-control default-variant-field" 
                                                   name="variants_0_CostPrice" required>
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label fw-bold">Sale Price</label>
                                            <input type="number" step="0.01" class="form-control default-variant-field" 
                                                   name="variants_0_SalePrice" required>
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label fw-bold">Compare At Price</label>
                                            <input type="number" step="0.01" class="form-control default-variant-field" 
                                                   name="variants_0_CompareAtPrice">
                                        </div>
                                    </div>
                                </div>

                                <!-- Dimensions Toggle -->
                                <div class="mb-3">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="showDimensionsToggle">
                                        <label class="form-check-label" for="showDimensionsToggle">
                                            Show Dimensions & Weight
                                        </label>
                                    </div>
                                </div>

                                <!-- Dimensions Section (hidden by default) -->
                                <div id="dimensionsSection" style="display: none;">
                                    <!-- Order Quantities -->
                                    <div class="row mb-4">
                                        <div class="col-md-6">
                                            <label class="form-label fw-bold">Minimum Order Quantity</label>
                                            <input type="number" class="form-control" 
                                                   name="variants_0_MinimumOrderQuantity">
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label fw-bold">Maximum Order Quantity</label>
                                            <input type="number" class="form-control" 
                                                   name="variants_0_MaximumOrderQuantity">
                                        </div>
                                    </div>

                                    <!-- Dimensions -->
                                    <div class="mb-4">
                                        <label class="form-label fw-bold">Package Dimensions</label>
                                        <div class="row g-3">
                                            <div class="col-md-4">
                                                <input type="number" step="0.01" class="form-control" 
                                                       placeholder="Height" 
                                                       name="variants_0_PackedHeight">
                                            </div>
                                            <div class="col-md-4">
                                                <input type="number" step="0.01" class="form-control" 
                                                       placeholder="Width" 
                                                       name="variants_0_PackedWidth">
                                            </div>
                                            <div class="col-md-4">
                                                <input type="number" step="0.01" class="form-control" 
                                                       placeholder="Depth" 
                                                       name="variants_0_PackedDepth">
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Weight -->
                                    <div class="row mb-4">
                                        <div class="col-md-6">
                                            <label class="form-label fw-bold">Weight Unit</label>
                                            <select class="form-select" name="variants_0_WeightUnit">
                                                <option value="kg">Kilogram (kg)</option>
                                                <option value="g">Gram (g)</option>
                                                <option value="lbs">Pound (lbs)</option>
                                                <option value="oz">Ounce (oz)</option>
                                            </select>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label fw-bold">Weight</label>
                                            <input type="number" step="0.01" class="form-control" 
                                                   name="variants_0_Weight">
                                        </div>
                                    </div>
                                </div>

                                <!-- Image Uploads -->
                                <div class="row mb-4">
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold">Thumbnail Image</label>
                                        <input type="file" class="form-control" 
                                               name="variants_0_thumbnail" 
                                               accept="image/*">
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold">Product Images</label>
                                        <input type="file" class="form-control" 
                                               name="variants_0_productImages" 
                                               accept="image/*" multiple>
                                    </div>
                                </div>
                                <input type="hidden" name="variants_0_Attributes" value="{}">
                            </div>
                        </div>
                    </div>

                    <!-- Variants Section (hidden by default) -->
                    <div id="variantsContainer" style="display: none;">
                        <!-- Variant Options Definition -->
                        <div class="mb-4">
                            <button type="button" class="btn btn-primary" id="addVariantOption">
                                <i class="bx bx-plus"></i> Add Variant Option (e.g., Size, Color)
                            </button>
                            <div id="variantOptionsContainer" class="mt-3">
                                <!-- Variant options will be added here -->
                            </div>
                        </div>

                        <!-- Generated Variants -->
                        <div id="generatedVariants">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h6 class="mb-0">
                                    <i class="bx bx-list-ul me-2"></i>Generated Variants
                                </h6>
                                <button type="button" class="btn btn-success btn-sm" id="addMissingVariant">
                                    <i class="bx bx-plus"></i> Add Missing Variant
                                </button>
                            </div>
                            <div id="variantCombinations">
                                <!-- Generated variant combinations will appear here -->
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row mt-4">
                <div class="col-sm-9 offset-sm-3">
                    <button type="submit" class="btn btn-primary">
                        <i class="bx bx-save me-2"></i>Save Product
                    </button>
                    <button type="button" class="btn btn-secondary" id="saveDraft">
                        <i class="bx bx-file me-2"></i>Save Draft
                    </button>
                    <a href="@Url.Action("Index")" class="btn btn-danger">
                        <i class="bx bx-x-circle me-2"></i>Cancel
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Missing Variants Modal -->
<div class="modal fade" id="missingVariantsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bx bx-list-plus me-2"></i>Select Missing Variants
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="selectAllVariants">
                        <label class="form-check-label fw-bold" for="selectAllVariants">
                            Select All
                        </label>
                    </div>
                </div>
                <div id="missingVariantsList" class="row">
                    <!-- Missing variants will be listed here -->
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="addSelectedVariants">
                    <i class="bx bx-plus"></i> Add Selected Variants
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Copy Variant Modal -->
<div class="modal fade" id="copyVariantModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bx bx-copy me-2"></i>Copy Variant Details
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Select Source Variant</label>
                    <select id="sourceVariantSelect" class="form-select">
                        <!-- Options will be populated dynamically -->
                    </select>
                </div>
                <div class="mb-3">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="copyPrices" checked>
                        <label class="form-check-label" for="copyPrices">
                            Copy Prices (Cost, Sale, Compare)
                        </label>
                    </div>
                </div>
                <div class="mb-3">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="copyDimensions" checked>
                        <label class="form-check-label" for="copyDimensions">
                            Copy Dimensions & Weight
                        </label>
                    </div>
                </div>
                <div class="mb-3">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="copyOrderQuantities" checked>
                        <label class="form-check-label" for="copyOrderQuantities">
                            Copy Order Quantities
                        </label>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="applyVariantCopy">
                    <i class="bx bx-copy"></i> Apply to Selected Variants
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Store all possible combinations
        let allPossibleCombinations = [];

        function updateVariants() {
            const options = [];
            $('.variant-option').each(function() {
                const optionName = $(this).find('.option-name').val();
                const values = [];
                $(this).find('.option-value').each(function() {
                    const value = $(this).val();
                    if (value) values.push(value);
                });
                if (optionName && values.length > 0) {
                    options.push({ name: optionName, values: values });
                }
            });

            // Generate all possible combinations
            allPossibleCombinations = generateCombinations(options);
            
            // Get current combinations from existing variants
            const currentCombinations = [];
            $('.variant-combination').each(function() {
                currentCombinations.push(JSON.parse($(this).attr('data-combo')));
            });

            // Display current combinations
            displayVariantCombinations(currentCombinations);
        }

        function generateCombinations(options) {
            if (options.length === 0) return [];
            
            let combinations = [{}];
            
            options.forEach(option => {
                const newCombinations = [];
                combinations.forEach(combo => {
                    option.values.forEach(value => {
                        const newCombo = { ...combo };
                        newCombo[option.name] = value;
                        newCombinations.push(newCombo);
                    });
                });
                combinations = newCombinations;
            });
            
            return combinations;
        }

        function displayVariantCombinations(combinations) {
            const container = $('#variantCombinations');
            container.empty();

            combinations.forEach((combo, index) => {
                const attributes = Object.entries(combo)
                    .map(([key, value]) => `${key}: ${value}`)
                    .join(', ');
                    
                const variantHtml = `
                    <div class="card mb-3 variant-combination" data-combo='${JSON.stringify(combo)}'>
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div>
                                    <h6>Variant ${index + 1} (${attributes})</h6>
                                </div>
                                <div class="d-flex align-items-center gap-3">
                                    <div class="form-check">
                                        <input class="form-check-input set-as-default" type="radio" 
                                               name="defaultVariantIndex" value="${index}">
                                        <label class="form-check-label">Set as Default</label>
                                    </div>
                                    <button type="button" class="btn btn-danger btn-sm remove-variant">
                                        <i class="bx bx-trash"></i> Remove
                                    </button>
                                </div>
                            </div>
                            
                            <!-- Basic Info -->
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <div class="mb-2">
                                        <label>SKU</label>
                                        <input type="text" class="form-control variant-required-field" name="variants_${index}_SKU" required>
                                    </div>
                                    <div class="mb-2">
                                        <label>Barcode</label>
                                        <input type="text" class="form-control" name="variants_${index}_Barcode">
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-2">
                                        <label>Cost Price</label>
                                        <input type="number" step="0.01" class="form-control variant-required-field" 
                                               name="variants_${index}_CostPrice" required>
                                    </div>
                                    <div class="mb-2">
                                        <label>Sale Price</label>
                                        <input type="number" step="0.01" class="form-control variant-required-field" 
                                               name="variants_${index}_SalePrice" required>
                                    </div>
                                    <div class="mb-2">
                                        <label>Compare At Price</label>
                                        <input type="number" step="0.01" class="form-control" 
                                               name="variants_${index}_CompareAtPrice">
                                    </div>
                                </div>
                            </div>

                            <!-- Dimensions Section -->
                            <div class="mb-3">
                                <div class="form-check">
                                    <input class="form-check-input variant-dimensions-toggle" type="checkbox" 
                                           id="variantDimensionsToggle${index}">
                                    <label class="form-check-label" for="variantDimensionsToggle${index}">
                                        Show Dimensions & Weight
                                    </label>
                                </div>
                            </div>

                            <div class="variant-dimensions-section" style="display: none;">
                                <!-- Order Quantities -->
                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label>Minimum Order Quantity</label>
                                        <input type="number" class="form-control" 
                                               name="variants_${index}_MinimumOrderQuantity">
                                    </div>
                                    <div class="col-md-6">
                                        <label>Maximum Order Quantity</label>
                                        <input type="number" class="form-control" 
                                               name="variants_${index}_MaximumOrderQuantity">
                                    </div>
                                </div>

                                <!-- Dimensions -->
                                <div class="mb-3">
                                    <label>Package Dimensions</label>
                                    <div class="row">
                                        <div class="col-md-4">
                                            <input type="number" step="0.01" class="form-control" 
                                                   placeholder="Height" 
                                                   name="variants_${index}_PackedHeight">
                                        </div>
                                        <div class="col-md-4">
                                            <input type="number" step="0.01" class="form-control" 
                                                   placeholder="Width" 
                                                   name="variants_${index}_PackedWidth">
                                        </div>
                                        <div class="col-md-4">
                                            <input type="number" step="0.01" class="form-control" 
                                                   placeholder="Depth" 
                                                   name="variants_${index}_PackedDepth">
                                        </div>
                                    </div>
                                </div>

                                <!-- Weight -->
                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label>Weight Unit</label>
                                        <select class="form-control" name="variants_${index}_WeightUnit">
                                            <option value="kg">Kilogram (kg)</option>
                                            <option value="g">Gram (g)</option>
                                            <option value="lbs">Pound (lbs)</option>
                                            <option value="oz">Ounce (oz)</option>
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <label>Weight</label>
                                        <input type="number" step="0.01" class="form-control" 
                                               name="variants_${index}_Weight">
                                    </div>
                                </div>
                            </div>

                            <!-- Image Uploads -->
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label>Thumbnail Image</label>
                                    <input type="file" class="form-control" 
                                           name="variants_${index}_thumbnail" 
                                           accept="image/*">
                                </div>
                                <div class="col-md-6">
                                    <label>Product Images</label>
                                    <input type="file" class="form-control" 
                                           name="variants_${index}_productImages" 
                                           accept="image/*" multiple>
                                </div>
                            </div>

                            <input type="hidden" name="variants_${index}_Attributes" 
                                   value='${JSON.stringify(combo)}'>
                        </div>
                    </div>
                `;
                container.append(variantHtml);
            });
        }

        // Function to find missing combinations
        function findMissingCombinations() {
            const currentCombinations = [];
            $('.variant-combination').each(function() {
                currentCombinations.push(JSON.parse($(this).attr('data-combo')));
            });

            return allPossibleCombinations.filter(combo => 
                !currentCombinations.some(current => 
                    JSON.stringify(current) === JSON.stringify(combo)
                )
            );
        }

        // Function to display missing combinations in the modal
        function displayMissingCombinations() {
            const missingCombinations = findMissingCombinations();
            const container = $('#missingVariantsList');
            container.empty();
            
            if (missingCombinations.length === 0) {
                container.html('<div class="col-12"><p class="text-center">No missing variants found!</p></div>');
                $('#addSelectedVariants').prop('disabled', true);
                return;
            }
            
            $('#addSelectedVariants').prop('disabled', false);
            
            missingCombinations.forEach((combo, index) => {
                const attributes = Object.entries(combo)
                    .map(([key, value]) => `${key}: ${value}`)
                    .join(', ');
                
                const variantHtml = `
                    <div class="col-md-6 mb-2">
                        <div class="form-check">
                            <input class="form-check-input missing-variant-checkbox" type="checkbox" 
                                   id="missingVariant${index}" data-combo='${JSON.stringify(combo)}'>
                            <label class="form-check-label" for="missingVariant${index}">
                                ${attributes}
                            </label>
                        </div>
                    </div>
                `;
                container.append(variantHtml);
            });
        }

        $(document).ready(function() {
            // Initialize select2 if it's available
            if ($.fn.select2) {
                $('.select2').select2({
                    theme: 'bootstrap4',
                    width: '100%',
                    placeholder: "Select a business"
                });
            } else {
                // Add custom styling for the dropdown if select2 is not available
                $('.form-select').addClass('form-control-lg');
            }

            // Initialize form state
            function initializeFormState() {
                const hasVariants = $('#hasVariantsToggle').is(':checked');
                $('#hasVariantsField').val(hasVariants ? "true" : "false");
                $('#defaultVariantCard').toggle(!hasVariants);
                $('#variantsContainer').toggle(hasVariants);
                
                // Set required attributes based on current mode
                if (hasVariants) {
                    $('.default-variant-field').prop('required', false);
                } else {
                    $('input[name="variants_0_SKU"]').prop('required', true);
                    $('input[name="variants_0_CostPrice"]').prop('required', true);
                    $('input[name="variants_0_SalePrice"]').prop('required', true);
                }
            }
            
            // Call initialization function
            initializeFormState();

            // Show/hide sections based on Business ID selection
            $('#BusinessID').change(function() {
                if ($(this).val()) {
                    $('.product-details-section').show();
                } else {
                    $('.product-details-section').hide();
                }
            });

            // Highlights handling
            $('#addHighlight').click(function() {
                const highlightHtml = `
                    <div class="highlight-entry mb-2">
                        <div class="input-group">
                            <input type="text" class="form-control" placeholder="Key" name="highlightKey[]">
                            <input type="text" class="form-control" placeholder="Value" name="highlightValue[]">
                            <button type="button" class="btn btn-danger remove-highlight">×</button>
                        </div>
                    </div>
                `;
                $('#highlightsContainer').append(highlightHtml);
            });

            $(document).on('click', '.remove-highlight', function() {
                $(this).closest('.highlight-entry').remove();
            });

            // Form submission
            $('#createProductForm').submit(function(e) {
                e.preventDefault();
                
                // Basic validation
                let isValid = true;
                
                // Validate business selection
                if (!$('#BusinessID').val()) {
                    alert('Please select a business.');
                    isValid = false;
                    return false;
                }
                
                // Validate product name
                if (!$('#Name').val()) {
                    alert('Please enter a product name.');
                    isValid = false;
                    return false;
                }
                
                // Check if we're in variant mode
                const hasVariants = $('#hasVariantsToggle').is(':checked');
                $('#hasVariantsField').val(hasVariants ? "true" : "false");
                
                // Validate default variant in non-variant mode
                if (!hasVariants) {
                    if (!$('input[name="variants_0_SKU"]').val()) {
                        alert('Please enter an SKU for the default variant.');
                        isValid = false;
                        return false;
                    }
                    
                    if (!$('input[name="variants_0_CostPrice"]').val()) {
                        alert('Please enter a cost price for the default variant.');
                        isValid = false;
                        return false;
                    }
                    
                    if (!$('input[name="variants_0_SalePrice"]').val()) {
                        alert('Please enter a sale price for the default variant.');
                        isValid = false;
                        return false;
                    }
                }
                
                if (!isValid) {
                    return false;
                }
                
                // Collect highlights
                const highlights = [];
                $('.highlight-entry').each(function() {
                    const key = $(this).find('input[name="highlightKey[]"]').val();
                    const value = $(this).find('input[name="highlightValue[]"]').val();
                    if (key && value) {
                        highlights.push({ key, value });
                    }
                });

                // Add to hidden input
                $('<input>').attr({
                    type: 'hidden',
                    name: 'BaseHightlights',
                    value: JSON.stringify(highlights)
                }).appendTo(this);

                // If in variant mode, ensure we have at least one variant and one is selected as default
                if (hasVariants) {
                    // Disable validation on default variant fields when in variant mode
                    $('input[name="variants_0_SKU"]').prop('required', false);
                    $('input[name="variants_0_CostPrice"]').prop('required', false);
                    $('input[name="variants_0_SalePrice"]').prop('required', false);
                    
                    if ($('.variant-combination').length === 0) {
                        alert('Please add at least one variant before saving.');
                        return false;
                    }
                    
                    // Check if a default variant is selected
                    if ($('.set-as-default:checked').length === 0) {
                        alert('Please select one variant as default.');
                        return false;
                    }
                    
                    // Validate required fields for each variant
                    let variantValidationPassed = true;
                    $('.variant-combination').each(function(index) {
                        const sku = $(this).find(`input[name="variants_${index}_SKU"]`).val();
                        const costPrice = $(this).find(`input[name="variants_${index}_CostPrice"]`).val();
                        const salePrice = $(this).find(`input[name="variants_${index}_SalePrice"]`).val();
                        
                        if (!sku || !costPrice || !salePrice) {
                            const attributes = Object.entries(JSON.parse($(this).attr('data-combo')))
                                .map(([key, value]) => `${key}: ${value}`)
                                .join(', ');
                                
                            alert(`Please fill in all required fields for variant ${index + 1} (${attributes})`);
                            variantValidationPassed = false;
                            return false; // Break the each loop
                        }
                    });
                    
                    if (!variantValidationPassed) {
                        return false;
                    }
                    
                    const variantOptions = {};
                    
                    // Collect all option names and their values
                    $('.variant-option').each(function() {
                        const optionName = $(this).find('.option-name').val();
                        if (optionName) {
                            const values = [];
                            $(this).find('.option-value').each(function() {
                                const value = $(this).val();
                                if (value) values.push(value);
                            });
                            
                            if (values.length > 0) {
                                variantOptions[optionName] = values;
                            }
                        }
                    });
                    
                    // Only add VariantOptions if we have actual variant options and variants
                    if (Object.keys(variantOptions).length > 0 && $('.variant-combination').length > 0) {
                        $('<input>').attr({
                            type: 'hidden',
                            name: 'VariantOptions',
                            value: JSON.stringify(variantOptions)
                        }).appendTo(this);
                    }
                    
                    // Set default variant
                    const defaultVariantIndex = $('.set-as-default:checked').val() || 0;
                    
                    // Collect variants with all fields
                    const variants = [];
                    $('.variant-combination').each(function(index) {
                        const variantHighlights = [];
                        $(this).find('.highlight-entry').each(function() {
                            const key = $(this).find('input[name$="highlightKey[]"]').val();
                            const value = $(this).find('input[name$="highlightValue[]"]').val();
                            if (key && value) {
                                variantHighlights.push({ key, value });
                            }
                        });

                        const variant = {
                            SKU: $(this).find(`input[name="variants_${index}_SKU"]`).val(),
                            Barcode: $(this).find(`input[name="variants_${index}_Barcode"]`).val(),
                            CostPrice: parseFloat($(this).find(`input[name="variants_${index}_CostPrice"]`).val()) || 0,
                            SalePrice: parseFloat($(this).find(`input[name="variants_${index}_SalePrice"]`).val()) || 0,
                            CompareAtPrice: $(this).find(`input[name="variants_${index}_CompareAtPrice"]`).val() ? parseFloat($(this).find(`input[name="variants_${index}_CompareAtPrice"]`).val()) : null,
                            MinimumOrderQuantity: $(this).find(`input[name="variants_${index}_MinimumOrderQuantity"]`).val() ? parseInt($(this).find(`input[name="variants_${index}_MinimumOrderQuantity"]`).val()) : null,
                            MaximumOrderQuantity: $(this).find(`input[name="variants_${index}_MaximumOrderQuantity"]`).val() ? parseInt($(this).find(`input[name="variants_${index}_MaximumOrderQuantity"]`).val()) : null,
                            PackedHeight: $(this).find(`input[name="variants_${index}_PackedHeight"]`).val() ? parseFloat($(this).find(`input[name="variants_${index}_PackedHeight"]`).val()) : null,
                            PackedWidth: $(this).find(`input[name="variants_${index}_PackedWidth"]`).val() ? parseFloat($(this).find(`input[name="variants_${index}_PackedWidth"]`).val()) : null,
                            PackedDepth: $(this).find(`input[name="variants_${index}_PackedDepth"]`).val() ? parseFloat($(this).find(`input[name="variants_${index}_PackedDepth"]`).val()) : null,
                            WeightUnit: $(this).find(`select[name="variants_${index}_WeightUnit"]`).val(),
                            Weight: $(this).find(`input[name="variants_${index}_Weight"]`).val() ? parseFloat($(this).find(`input[name="variants_${index}_Weight"]`).val()) : null,
                            AdditionalHighlights: JSON.stringify(variantHighlights),
                            Attributes: $(this).find(`input[name="variants_${index}_Attributes"]`).val(),
                            IsDefault: index == defaultVariantIndex
                        };
                        variants.push(variant);
                    });

                    // Add variants to form
                    $('<input>').attr({
                        type: 'hidden',
                        name: 'VariantData',
                        value: JSON.stringify(variants)
                    }).appendTo(this);
                } else {
                    // In default mode, collect the single variant data
                    const defaultVariant = {
                        SKU: $('input[name="variants_0_SKU"]').val(),
                        Barcode: $('input[name="variants_0_Barcode"]').val(),
                        CostPrice: parseFloat($('input[name="variants_0_CostPrice"]').val()) || 0,
                        SalePrice: parseFloat($('input[name="variants_0_SalePrice"]').val()) || 0,
                        CompareAtPrice: $('input[name="variants_0_CompareAtPrice"]').val() ? parseFloat($('input[name="variants_0_CompareAtPrice"]').val()) : null,
                        MinimumOrderQuantity: $('input[name="variants_0_MinimumOrderQuantity"]').val() ? parseInt($('input[name="variants_0_MinimumOrderQuantity"]').val()) : null,
                        MaximumOrderQuantity: $('input[name="variants_0_MaximumOrderQuantity"]').val() ? parseInt($('input[name="variants_0_MaximumOrderQuantity"]').val()) : null,
                        PackedHeight: $('input[name="variants_0_PackedHeight"]').val() ? parseFloat($('input[name="variants_0_PackedHeight"]').val()) : null,
                        PackedWidth: $('input[name="variants_0_PackedWidth"]').val() ? parseFloat($('input[name="variants_0_PackedWidth"]').val()) : null,
                        PackedDepth: $('input[name="variants_0_PackedDepth"]').val() ? parseFloat($('input[name="variants_0_PackedDepth"]').val()) : null,
                        WeightUnit: $('select[name="variants_0_WeightUnit"]').val(),
                        Weight: $('input[name="variants_0_Weight"]').val() ? parseFloat($('input[name="variants_0_Weight"]').val()) : null,
                        Attributes: "{}",
                        IsDefault: true
                    };
                    
                    // Add the default variant to form
                    $('<input>').attr({
                        type: 'hidden',
                        name: 'VariantData',
                        value: JSON.stringify([defaultVariant])
                    }).appendTo(this);
                }

                // Submit the form
                $(this).unbind('submit').submit();
            });

            // Variant Management
            let variantOptions = [];

            $('#addVariantOption').click(function() {
                const optionId = Date.now();
                const optionHtml = `
                    <div class="variant-option mb-3" data-option-id="${optionId}">
                        <div class="card">
                            <div class="card-body">
                                <div class="row mb-2">
                                    <div class="col">
                                        <input type="text" class="form-control option-name" 
                                               placeholder="Option Name (e.g., Size, Color)">
                                    </div>
                                    <div class="col-auto">
                                        <button type="button" class="btn btn-danger btn-sm remove-option">
                                            Remove Option
                                        </button>
                                    </div>
                                </div>
                                <div class="option-values">
                                    <div class="input-group mb-2">
                                        <input type="text" class="form-control option-value" 
                                               placeholder="Option Value (e.g., Small, Red)">
                                        <button type="button" class="btn btn-outline-danger remove-value">×</button>
                                    </div>
                                </div>
                                <button type="button" class="btn btn-sm btn-outline-primary add-value">
                                    Add Value
                                </button>
                            </div>
                        </div>
                    </div>
                `;
                $('#variantOptionsContainer').append(optionHtml);
            });

            // Handle variant option changes
            $(document).on('change', '.option-name, .option-value', function() {
                updateVariants();
            });

            // Remove variant option
            $(document).on('click', '.remove-option', function() {
                $(this).closest('.variant-option').remove();
                updateVariants();
            });

            // Add value to variant option
            $(document).on('click', '.add-value', function() {
                const valueHtml = `
                    <div class="input-group mb-2">
                        <input type="text" class="form-control option-value" 
                               placeholder="Option Value (e.g., Small, Red)">
                        <button type="button" class="btn btn-outline-danger remove-value">×</button>
                    </div>
                `;
                $(this).siblings('.option-values').append(valueHtml);
            });

            // Remove value from variant option
            $(document).on('click', '.remove-value', function() {
                $(this).closest('.input-group').remove();
                updateVariants();
            });

            // Handle remove variant
            $(document).on('click', '.remove-variant', function() {
                $(this).closest('.variant-combination').remove();
            });

            // Handle add missing variant
            $('#addMissingVariant').click(function() {
                displayMissingCombinations();
                $('#missingVariantsModal').modal('show');
            });
            
            // Handle select all checkbox
            $('#selectAllVariants').change(function() {
                $('.missing-variant-checkbox').prop('checked', this.checked);
            });
            
            // Add selected variants
            $('#addSelectedVariants').click(function() {
                const selectedCombos = [];
                
                // Get current combinations
                const currentCombinations = [];
                $('.variant-combination').each(function() {
                    currentCombinations.push(JSON.parse($(this).attr('data-combo')));
                });
                
                // Add selected combinations
                $('.missing-variant-checkbox:checked').each(function() {
                    const combo = JSON.parse($(this).attr('data-combo'));
                    selectedCombos.push(combo);
                });
                
                if (selectedCombos.length > 0) {
                    // Combine current and selected combinations
                    const allCombinations = [...currentCombinations, ...selectedCombos];
                    displayVariantCombinations(allCombinations);
                    $('#missingVariantsModal').modal('hide');
                } else {
                    alert('Please select at least one variant to add.');
                }
            });

            // Handle variants toggle
            $('#hasVariantsToggle').change(function() {
                const hasVariants = this.checked;
                $('#hasVariantsField').val(hasVariants ? "true" : "false");
                $('#defaultVariantCard').toggle(!hasVariants);
                $('#variantsContainer').toggle(hasVariants);
                
                // Toggle required attribute on default variant fields
                if (hasVariants) {
                    $('input[name="variants_0_SKU"]').prop('required', false);
                    $('input[name="variants_0_CostPrice"]').prop('required', false);
                    $('input[name="variants_0_SalePrice"]').prop('required', false);
                } else {
                    $('input[name="variants_0_SKU"]').prop('required', true);
                    $('input[name="variants_0_CostPrice"]').prop('required', true);
                    $('input[name="variants_0_SalePrice"]').prop('required', true);
                }
                
                if (!hasVariants) {
                    // Clear variant options and combinations when switching to default
                    $('#variantOptionsContainer').empty();
                    $('#variantCombinations').empty();
                    allPossibleCombinations = [];
                } else {
                    // When switching to variants mode, add at least one option
                    if ($('.variant-option').length === 0) {
                        $('#addVariantOption').click();
                    }
                }
            });

            // Handle "Set as Default" radio buttons
            $(document).on('change', '.set-as-default', function() {
                $('.set-as-default').prop('checked', false);
                $(this).prop('checked', true);
            });

            // Handle dimensions toggle for default variant
            $('#showDimensionsToggle').change(function() {
                $('#dimensionsSection').toggle(this.checked);
            });

            // Handle dimensions toggle for variant combinations
            $(document).on('change', '.variant-dimensions-toggle', function() {
                $(this).closest('.variant-combination')
                    .find('.variant-dimensions-section')
                    .toggle(this.checked);
            });

            // Add a button to copy variant details to other variants
            $('#generatedVariants').prepend(`
                <div class="mb-3">
                    <button type="button" class="btn btn-info btn-sm" id="copyVariantDetails">
                        <i class="bx bx-copy"></i> Copy Variant Details to Other Variants
                    </button>
                </div>
            `);

            // Handle copy variant details button
            $(document).on('click', '#copyVariantDetails', function() {
                // Populate source variant dropdown
                const sourceSelect = $('#sourceVariantSelect');
                sourceSelect.empty();
                
                $('.variant-combination').each(function(index) {
                    const combo = JSON.parse($(this).attr('data-combo'));
                    const attributes = Object.entries(combo)
                        .map(([key, value]) => `${key}: ${value}`)
                        .join(', ');
                    
                    sourceSelect.append(`<option value="${index}">Variant ${index + 1} (${attributes})</option>`);
                });
                
                $('#copyVariantModal').modal('show');
            });

            // Handle apply variant copy
            $('#applyVariantCopy').click(function() {
                const sourceIndex = $('#sourceVariantSelect').val();
                const sourceVariant = $(`.variant-combination:eq(${sourceIndex})`);
                
                // Get values to copy
                const copyPrices = $('#copyPrices').is(':checked');
                const copyDimensions = $('#copyDimensions').is(':checked');
                const copyOrderQuantities = $('#copyOrderQuantities').is(':checked');
                
                // Get source values
                let sourceValues = {};
                
                if (copyPrices) {
                    sourceValues.CostPrice = sourceVariant.find(`input[name="variants_${sourceIndex}_CostPrice"]`).val();
                    sourceValues.SalePrice = sourceVariant.find(`input[name="variants_${sourceIndex}_SalePrice"]`).val();
                    sourceValues.CompareAtPrice = sourceVariant.find(`input[name="variants_${sourceIndex}_CompareAtPrice"]`).val();
                }
                
                if (copyDimensions) {
                    sourceValues.PackedHeight = sourceVariant.find(`input[name="variants_${sourceIndex}_PackedHeight"]`).val();
                    sourceValues.PackedWidth = sourceVariant.find(`input[name="variants_${sourceIndex}_PackedWidth"]`).val();
                    sourceValues.PackedDepth = sourceVariant.find(`input[name="variants_${sourceIndex}_PackedDepth"]`).val();
                    sourceValues.WeightUnit = sourceVariant.find(`select[name="variants_${sourceIndex}_WeightUnit"]`).val();
                    sourceValues.Weight = sourceVariant.find(`input[name="variants_${sourceIndex}_Weight"]`).val();
                }
                
                if (copyOrderQuantities) {
                    sourceValues.MinimumOrderQuantity = sourceVariant.find(`input[name="variants_${sourceIndex}_MinimumOrderQuantity"]`).val();
                    sourceValues.MaximumOrderQuantity = sourceVariant.find(`input[name="variants_${sourceIndex}_MaximumOrderQuantity"]`).val();
                }
                
                // Apply to all other variants
                $('.variant-combination').each(function(index) {
                    if (index != sourceIndex) {
                        if (copyPrices) {
                            $(this).find(`input[name="variants_${index}_CostPrice"]`).val(sourceValues.CostPrice);
                            $(this).find(`input[name="variants_${index}_SalePrice"]`).val(sourceValues.SalePrice);
                            $(this).find(`input[name="variants_${index}_CompareAtPrice"]`).val(sourceValues.CompareAtPrice);
                        }
                        
                        if (copyDimensions) {
                            $(this).find(`input[name="variants_${index}_PackedHeight"]`).val(sourceValues.PackedHeight);
                            $(this).find(`input[name="variants_${index}_PackedWidth"]`).val(sourceValues.PackedWidth);
                            $(this).find(`input[name="variants_${index}_PackedDepth"]`).val(sourceValues.PackedDepth);
                            $(this).find(`select[name="variants_${index}_WeightUnit"]`).val(sourceValues.WeightUnit);
                            $(this).find(`input[name="variants_${index}_Weight"]`).val(sourceValues.Weight);
                        }
                        
                        if (copyOrderQuantities) {
                            $(this).find(`input[name="variants_${index}_MinimumOrderQuantity"]`).val(sourceValues.MinimumOrderQuantity);
                            $(this).find(`input[name="variants_${index}_MaximumOrderQuantity"]`).val(sourceValues.MaximumOrderQuantity);
                        }
                    }
                });
                
                $('#copyVariantModal').modal('hide');
            });
        });
    </script>
}
