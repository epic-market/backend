@model EpicMarket.Data.Models.Catalog

@{
    ViewData["Title"] = "Create";
}

<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Catelog</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a asp-action="Index"><i class="bx bx-home-alt"></i></a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Create</li>
            </ol>
        </nav>
    </div>
</div>
<hr />
<div class="row">
    <div class="col-xl-9 mx-auto">
        <form asp-action="Create" enctype="multipart/form-data" id="createProductForm">
            <!-- Step 1: Business Selection -->
            <div class="card border-top border-0 border-4 border-info mb-4">
                <div class="card-body">
                    <h5 class="card-title">Select Business</h5>
                    <div class="row mb-3">
                        <label asp-for="BusinessID" class="col-sm-3 col-form-label"></label>
                        <div class="col-sm-9">
                            <select class="single-select" asp-for="BusinessID" asp-items="ViewBag.BusinessID" 
                                    data-placeholder="Select Business" required>
                                <option value="">Select Business</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Step 2: Basic Details -->
            <div class="card border-top border-0 border-4 border-info mb-4 product-details-section" style="display:none">
                <div class="card-body">
                    <h5 class="card-title">Basic Details</h5>
                    <div class="row mb-3">
                        <label asp-for="Name" class="col-sm-3 col-form-label"></label>
                        <div class="col-sm-9">
                            <input asp-for="Name" class="form-control" required />
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label asp-for="Description" class="col-sm-3 col-form-label"></label>
                        <div class="col-sm-9">
                            <textarea asp-for="Description" class="form-control"></textarea>
                        </div>
                    </div>
                    
                    <!-- Highlights Section -->
                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Highlights</label>
                        <div class="col-sm-9">
                            <div id="highlightsContainer">
                                <!-- Highlight entries will be added here -->
                            </div>
                            <button type="button" class="btn btn-sm btn-outline-info" id="addHighlight">
                                Add Highlight
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Step 3: Pricing & Settings -->
            <div class="card border-top border-0 border-4 border-info mb-4 product-details-section" style="display:none">
                <div class="card-body">
                    <h5 class="card-title">Pricing & Settings</h5>
                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label"></label>
                        <div class="col-sm-9">
                            <div class="form-check">
                                <input class="form-check-input" asp-for="RequiresRefrigeration" />
                                <label class="form-check-label">Requires Refrigeration</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" asp-for="IsRecommended" />
                                <label class="form-check-label">Is Recommended</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Step 4: Variants Section -->
            <div id="variantsSection" class="card border-top border-0 border-4 border-info mb-4 product-details-section" style="display:none">
                <div class="card-body">
                    <h5 class="card-title">Product Variants</h5>
                    
                    <!-- Variant Options Definition -->
                    <div class="mb-4">
                        <button type="button" class="btn btn-primary" id="addVariantOption">
                            Add Variant Option (e.g., Size, Color)
                        </button>
                        <div id="variantOptionsContainer">
                            <!-- Variant options will be added here -->
                        </div>
                    </div>

                    <!-- Generated Variants -->
                    <div id="generatedVariants">
                        <h6>Generated Variants</h6>
                        <div id="variantCombinations">
                            <!-- Generated variant combinations will appear here -->
                        </div>
                    </div>
                </div>
            </div>

            <div class="row mt-3">
                <div class="col-sm-9 offset-sm-3">
                    <button type="submit" class="btn btn-primary">Save Product</button>
                    <button type="button" class="btn btn-secondary" id="saveDraft">Save Draft</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        // Define these functions in global scope
        function updateVariants() {
            const options = [];
            $('.variant-option').each(function() {
                const optionName = $(this).find('.option-name').val();
                const values = [];
                $(this).find('.option-value').each(function() {
                    const value = $(this).val();
                    if (value) values.push(value);
                });
                if (optionName && values.length > 0) {
                    options.push({ name: optionName, values: values });
                }
            });

            // Generate combinations
            const combinations = generateCombinations(options);
            displayVariantCombinations(combinations);
        }

        function generateCombinations(options) {
            if (options.length === 0) return [];
            
            let combinations = [{}];
            
            options.forEach(option => {
                const newCombinations = [];
                combinations.forEach(combo => {
                    option.values.forEach(value => {
                        const newCombo = { ...combo };
                        newCombo[option.name] = value;
                        newCombinations.push(newCombo);
                    });
                });
                combinations = newCombinations;
            });
            
            return combinations;
        }

        function displayVariantCombinations(combinations) {
            const container = $('#variantCombinations');
            container.empty();

            combinations.forEach((combo, index) => {
                const attributes = Object.entries(combo)
                    .map(([key, value]) => `${key}: ${value}`)
                    .join(', ');
                    
                const variantHtml = `
                    <div class="card mb-3 variant-combination">
                        <div class="card-body">
                            <h6>Variant ${index + 1} (${attributes})</h6>
                            
                            <!-- Basic Info -->
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <div class="mb-2">
                                        <label>SKU</label>
                                        <input type="text" class="form-control" name="variants[${index}].SKU" required>
                                    </div>
                                    <div class="mb-2">
                                        <label>Barcode</label>
                                        <input type="text" class="form-control" name="variants[${index}].Barcode">
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-2">
                                        <label>Cost Price</label>
                                        <input type="number" step="0.01" class="form-control" 
                                               name="variants[${index}].CostPrice" required>
                                    </div>
                                    <div class="mb-2">
                                        <label>Sale Price</label>
                                        <input type="number" step="0.01" class="form-control" 
                                               name="variants[${index}].SalePrice" required>
                                    </div>
                                    <div class="mb-2">
                                        <label>Compare At Price</label>
                                        <input type="number" step="0.01" class="form-control" 
                                               name="variants[${index}].CompareAtPrice">
                                    </div>
                                </div>
                            </div>

                            <!-- Additional Highlights -->
                            <div class="mb-3">
                                <label>Additional Highlights</label>
                                <div class="variant-highlights-container">
                                    <div class="highlight-entry mb-2">
                                        <div class="input-group">
                                            <input type="text" class="form-control" placeholder="Key" 
                                                   name="variants[${index}].highlightKey[]">
                                            <input type="text" class="form-control" placeholder="Value" 
                                                   name="variants[${index}].highlightValue[]">
                                            <button type="button" class="btn btn-outline-danger remove-variant-highlight">×</button>
                                        </div>
                                    </div>
                                </div>
                                <button type="button" class="btn btn-sm btn-outline-info add-variant-highlight">
                                    Add Highlight
                                </button>
                            </div>

                            <!-- Order Quantities -->
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label>Minimum Order Quantity</label>
                                    <input type="number" class="form-control" 
                                           name="variants[${index}].MinimumOrderQuantity">
                                </div>
                                <div class="col-md-6">
                                    <label>Maximum Order Quantity</label>
                                    <input type="number" class="form-control" 
                                           name="variants[${index}].MaximumOrderQuantity">
                                </div>
                            </div>

                            <!-- Dimensions -->
                            <div class="mb-3">
                                <label>Package Dimensions</label>
                                <div class="row">
                                    <div class="col-md-4">
                                        <input type="number" step="0.01" class="form-control" 
                                               placeholder="Height" 
                                               name="variants[${index}].PackedHeight">
                                    </div>
                                    <div class="col-md-4">
                                        <input type="number" step="0.01" class="form-control" 
                                               placeholder="Width" 
                                               name="variants[${index}].PackedWidth">
                                    </div>
                                    <div class="col-md-4">
                                        <input type="number" step="0.01" class="form-control" 
                                               placeholder="Depth" 
                                               name="variants[${index}].PackedDepth">
                                    </div>
                                </div>
                            </div>

                            <!-- Weight -->
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label>Weight Unit</label>
                                    <select class="form-control" name="variants[${index}].WeightUnit">
                                        <option value="kg">Kilogram (kg)</option>
                                        <option value="g">Gram (g)</option>
                                        <option value="lbs">Pound (lbs)</option>
                                        <option value="oz">Ounce (oz)</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label>Weight</label>
                                    <input type="number" step="0.01" class="form-control" 
                                           name="variants[${index}].Weight">
                                </div>
                            </div>

                            <!-- Image Uploads -->
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label>Thumbnail Image</label>
                                    <input type="file" class="form-control" 
                                           name="variants[${index}].thumbnail" 
                                           accept="image/*">
                                </div>
                                <div class="col-md-6">
                                    <label>Product Images</label>
                                    <input type="file" class="form-control" 
                                           name="variants[${index}].productImages" 
                                           accept="image/*" multiple>
                                </div>
                            </div>

                            <input type="hidden" name="variants[${index}].Attributes" 
                                   value='${JSON.stringify(combo)}'>
                        </div>
                    </div>
                `;
                container.append(variantHtml);
            });
        }

        $(document).ready(function() {
            // Show/hide sections based on Business ID selection
            $('#BusinessID').change(function() {
                if ($(this).val()) {
                    $('.product-details-section').show();
                } else {
                    $('.product-details-section').hide();
                }
            });

            // Highlights handling
            $('#addHighlight').click(function() {
                const highlightHtml = `
                    <div class="highlight-entry mb-2">
                        <div class="input-group">
                            <input type="text" class="form-control" placeholder="Key" name="highlightKey[]">
                            <input type="text" class="form-control" placeholder="Value" name="highlightValue[]">
                            <button type="button" class="btn btn-danger remove-highlight">×</button>
                        </div>
                    </div>
                `;
                $('#highlightsContainer').append(highlightHtml);
            });

            $(document).on('click', '.remove-highlight', function() {
                $(this).closest('.highlight-entry').remove();
            });

            // Form submission
            $('#createProductForm').submit(function(e) {
                e.preventDefault();
                
                // Collect highlights
                const highlights = [];
                $('.highlight-entry').each(function() {
                    const key = $(this).find('input[name="highlightKey[]"]').val();
                    const value = $(this).find('input[name="highlightValue[]"]').val();
                    if (key && value) {
                        highlights.push({ key, value });
                    }
                });

                // Add to hidden input
                $('<input>').attr({
                    type: 'hidden',
                    name: 'BaseHightlights',
                    value: JSON.stringify(highlights)
                }).appendTo(this);

                // Collect variants with all fields
                const variants = [];
                $('.variant-combination').each(function(index) {
                    const variantHighlights = [];
                    $(this).find('.highlight-entry').each(function() {
                        const key = $(this).find('input[name$="highlightKey[]"]').val();
                        const value = $(this).find('input[name$="highlightValue[]"]').val();
                        if (key && value) {
                            variantHighlights.push({ key, value });
                        }
                    });

                    const variant = {
                        SKU: $(this).find('input[name$="SKU"]').val(),
                        Barcode: $(this).find('input[name$="Barcode"]').val(),
                        CostPrice: $(this).find('input[name$="CostPrice"]').val(),
                        SalePrice: $(this).find('input[name$="SalePrice"]').val(),
                        CompareAtPrice: $(this).find('input[name$="CompareAtPrice"]').val(),
                        MinimumOrderQuantity: $(this).find('input[name$="MinimumOrderQuantity"]').val(),
                        MaximumOrderQuantity: $(this).find('input[name$="MaximumOrderQuantity"]').val(),
                        PackedHeight: $(this).find('input[name$="PackedHeight"]').val(),
                        PackedWidth: $(this).find('input[name$="PackedWidth"]').val(),
                        PackedDepth: $(this).find('input[name$="PackedDepth"]').val(),
                        WeightUnit: $(this).find('select[name$="WeightUnit"]').val(),
                        Weight: $(this).find('input[name$="Weight"]').val(),
                        AdditionalHighlights: JSON.stringify(variantHighlights),
                        Attributes: $(this).find('input[name$="Attributes"]').val()
                    };
                    variants.push(variant);
                });

                // Add variants to form
                $('<input>').attr({
                    type: 'hidden',
                    name: 'VariantData',
                    value: JSON.stringify(variants)
                }).appendTo(this);

                // Submit the form
                this.submit();
            });

            // Variant Management
            let variantOptions = [];

            $('#addVariantOption').click(function() {
                const optionId = Date.now();
                const optionHtml = `
                    <div class="variant-option mb-3" data-option-id="${optionId}">
                        <div class="card">
                            <div class="card-body">
                                <div class="row mb-2">
                                    <div class="col">
                                        <input type="text" class="form-control option-name" 
                                               placeholder="Option Name (e.g., Size, Color)">
                                    </div>
                                    <div class="col-auto">
                                        <button type="button" class="btn btn-danger btn-sm remove-option">
                                            Remove Option
                                        </button>
                                    </div>
                                </div>
                                <div class="option-values">
                                    <div class="input-group mb-2">
                                        <input type="text" class="form-control option-value" 
                                               placeholder="Option Value (e.g., Small, Red)">
                                        <button type="button" class="btn btn-outline-danger remove-value">×</button>
                                    </div>
                                </div>
                                <button type="button" class="btn btn-sm btn-outline-primary add-value">
                                    Add Value
                                </button>
                            </div>
                        </div>
                    </div>
                `;
                $('#variantOptionsContainer').append(optionHtml);
            });

            // Add event delegation for option name and value changes
            $(document).on('change', '.option-name, .option-value', function() {
                updateVariants();
            });

            // Remove variant option
            $(document).on('click', '.remove-option', function() {
                $(this).closest('.variant-option').remove();
                updateVariants();
            });

            // Add value to variant option
            $(document).on('click', '.add-value', function() {
                const valueHtml = `
                    <div class="input-group mb-2">
                        <input type="text" class="form-control option-value" 
                               placeholder="Option Value (e.g., Small, Red)">
                        <button type="button" class="btn btn-outline-danger remove-value">×</button>
                    </div>
                `;
                $(this).siblings('.option-values').append(valueHtml);
            });

            // Remove value from variant option
            $(document).on('click', '.remove-value', function() {
                $(this).closest('.input-group').remove();
                updateVariants();
            });

            // Handle variant highlight additions
            $(document).on('click', '.add-variant-highlight', function() {
                const highlightHtml = `
                    <div class="highlight-entry mb-2">
                        <div class="input-group">
                            <input type="text" class="form-control" placeholder="Key" name="highlightKey[]">
                            <input type="text" class="form-control" placeholder="Value" name="highlightValue[]">
                            <button type="button" class="btn btn-outline-danger remove-variant-highlight">×</button>
                        </div>
                    </div>
                `;
                $(this).siblings('.variant-highlights-container').append(highlightHtml);
            });

            // Handle variant highlight removals
            $(document).on('click', '.remove-variant-highlight', function() {
                $(this).closest('.highlight-entry').remove();
            });
        });
    </script>
}
