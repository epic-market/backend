@model EpicMarket.Admin.MVC.Models.CatelogModel

@{
    ViewData["Title"] = "Product Details";
}

<style>
    .badge {
        padding: 8px 12px;
        font-weight: 500;
    }
    .list-group-item {
        border-width: 0;
        padding-left: 0;
        padding-right: 0;
        border-bottom: 1px solid rgba(0,0,0,.1);
    }
    .card {
        box-shadow: 0 2px 6px rgba(0,0,0,.04);
        border: 1px solid rgba(0,0,0,.075);
    }
    .fw-medium {
        font-weight: 500;
    }
</style>

<div class="container-fluid">
    <!-- Product Header -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center">
                <h4 class="mb-0">@Model.Catalog.Name</h4>
                <a asp-action="Edit" asp-route-id="@Model.Catalog.ID" class="btn btn-primary">
                    <i class="bx bx-edit me-1"></i> Edit
                </a>
            </div>

            <!-- Status Pills -->
            <div class="mt-3">
                <span class="badge rounded-pill bg-light text-dark border me-2">
                    <i class="bx bx-check-circle text-success me-1"></i>
                    IsActive: @(Model.Catalog.IsActive ? "Active" : "Inactive")
                </span>
                <span class="badge rounded-pill bg-light text-dark border me-2">
                    <i class="bx bx-badge-check text-info me-1"></i>
                    IsRecommended: @(Model.Catalog.IsRecommended ? "Recommended" : "Not Recommended")
                </span>
                <span class="badge rounded-pill bg-light text-dark border me-2">
                    <i class="bx bx-star text-warning me-1"></i>
                    Rating: @Model.Catalog.Rating
                </span>
                <span class="badge rounded-pill bg-danger text-white me-2">
                    <i class="bx bx-check-circle me-1"></i>
                    Verified
                </span>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Product Image -->
        <div class="col-md-3">
            <div class="card mb-4">
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(ViewBag.thumbnail))
                    {
                        <img src="@Url.Action("DisplayImage", "File", new { key = ViewBag.thumbnail })" 
                             alt="@Model.Catalog.Name"
                             class="img-fluid rounded" 
                             style="width: 100%; object-fit: cover;">
                    }
                    else
                    {
                        <div class="text-center p-4 bg-light rounded">
                            <i class="bx bx-image-alt" style="font-size: 48px;"></i>
                            <p class="text-muted mb-0">No thumbnail available</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Product Details -->
        <div class="col-md-9">
            <div class="card mb-4">
                <div class="card-body">
                    <div class="row g-4">
                        <!-- Basic Info -->
                        <div class="col-md-6">
                            <div class="mb-4">
                                <h6 class="text-muted mb-3">Basic Information</h6>
                                <div class="list-group list-group-flush">
                                    <div class="list-group-item px-0 d-flex justify-content-between">
                                        <span class="text-muted">ID</span>
                                        <span class="fw-medium">@Model.Catalog.ID</span>
                                    </div>
                                    <div class="list-group-item px-0 d-flex justify-content-between">
                                        <span class="text-muted">Business ID</span>
                                        <span class="fw-medium">@Model.Catalog.BusinessID</span>
                                    </div>
                                    <div class="list-group-item px-0 d-flex justify-content-between">
                                        <span class="text-muted">Category ID</span>
                                        <span class="fw-medium">@Model.Catalog.CategoryID</span>
                                    </div>
                                    <div class="list-group-item px-0 d-flex justify-content-between">
                                        <span class="text-muted">Review Count</span>
                                        <span class="fw-medium">@Model.Catalog.ReviewCount</span>
                                    </div>
                                    <div class="list-group-item px-0 d-flex justify-content-between">
                                        <span class="text-muted">Order Count</span>
                                        <span class="fw-medium">@Model.Catalog.OrderCount</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Additional Info -->
                        <div class="col-md-6">
                            <div class="mb-4">
                                <h6 class="text-muted mb-3">Additional Information</h6>
                                <div class="list-group list-group-flush">
                                    <div class="list-group-item px-0">
                                        <span class="text-muted d-block mb-1">Description</span>
                                        <p class="mb-0">@Model.Catalog.Description</p>
                                    </div>
                                    <div class="list-group-item px-0">
									<span class="text-muted d-block mb-1">Base Highlights</span>
									<div class="mb-0">
										@{
											// Check if the highlights exist
											if (!string.IsNullOrEmpty(Model.Catalog.BaseHightlights))
											{
												try
												{
													// Deserialize the JSON string to dictionary
													var highlights = Newtonsoft.Json.JsonConvert.DeserializeObject<Dictionary<string, string>>(
														Model.Catalog.BaseHightlights
													);

													// Loop through each key-value pair
													foreach (var item in highlights)
													{
														<div class="d-flex justify-content-between">
															<span>@item.Key</span>
															<span>@item.Value</span>
														</div>
													}
												}
												catch
												{
													// Fallback if JSON is invalid
													@Model.Catalog.BaseHightlights
												}
											}
											else
											{
												<span class="text-muted">No highlights available</span>
											}
										}
									</div>
								</div>
                                    <div class="list-group-item px-0 d-flex justify-content-between">
                                        <span class="text-muted">Requires Refrigeration</span>
                                        <span class="fw-medium">
                                            @(Model.Catalog.RequiresRefrigeration ? "Yes" : "No")
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Product Variants Card -->
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center py-3">
            <h5 class="mb-0">Product Variants</h5>
            <a asp-controller="CatalogVariants" asp-action="Create" asp-route-catalogId="@Model.Catalog.ID" 
               class="btn btn-primary btn-sm">
                <i class="bx bx-plus"></i> Add Variant
            </a>
        </div>
        <div class="card-body">
            @if (Model.Catalog.CatalogVariants?.Any() == true)
            {
                <div class="table-responsive">
                    <table class="table table-hover" id="variantsTable">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 80px">Image</th>
                                <th>SKU</th>
                                <th>Attributes</th>
                                <th class="text-end">Cost Price</th>
                                <th class="text-end">Sale Price</th>
                                <th class="text-end">Compare Price</th>
                                <th>Weight</th>
                                <th style="width: 120px">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var variant in Model.Catalog.CatalogVariants)
                            {
                                <tr>
                                    <td>
                                        <div class="avatar avatar-lg">
                                            @if (!string.IsNullOrEmpty(ViewBag.thumbnail))
                                            {
                                                <img src="@Url.Action("DisplayImage", "File", new { key = ViewBag.thumbnail })" 
                                                     alt="@variant.SKU"
                                                     class="rounded"
                                                     style="width: 40px; height: 40px; object-fit: cover;">
                                            }
                                            else
                                            {
                                                <div class="rounded bg-light d-flex align-items-center justify-content-center" 
                                                     style="width: 40px; height: 40px;">
                                                    <i class="bx bx-image text-muted"></i>
                                                </div>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <span class="fw-medium">@variant.SKU</span>
                                        </div>
                                    </td>
									<td>
					@{
						// Debug: Show raw value first
						<!-- <div>Raw: @variant.Attributes</div> -->
						
						if (!string.IsNullOrEmpty(variant.Attributes))
						{
							try
							{
								// Clean the JSON string by removing escape characters
								var cleanJson = variant.Attributes.Replace("\\\"", "\"");
								
								var attributes = Newtonsoft.Json.JsonConvert
									.DeserializeObject<Dictionary<string, string>>(cleanJson);
								
								<div class="d-flex flex-wrap gap-1">
									@foreach (var value in attributes.Values)
									{
										<span class="badge bg-primary me-1 mb-1">@value</span>
									}
								</div>
							}
							catch (Exception ex)
							{
								<!-- Helpful error message for debugging -->
								<div class="text-danger">
									Error: @ex.Message
									<br>
									Content: @variant.Attributes
								</div>
							}
						}
						else
						{
							<span class="text-muted">N/A</span>
						}
					}
				</td>
                                    <td class="text-end">₹@variant.CostPrice.ToString("N2")</td>
                                    <td class="text-end">₹@variant.SalePrice.ToString("N2")</td>
                                    <td class="text-end">
                                        @(variant.CompareAtPrice.HasValue ? $"₹{variant.CompareAtPrice.Value:N2}" : "-")
                                    </td>
                                    <td>
                                        @(variant.Weight.HasValue ? $"{variant.Weight:N2} {variant.WeightUnit}" : "-")
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <a asp-controller="CatalogVariants" asp-action="Edit" 
                                               asp-route-id="@variant.ID" 
                                               class="btn btn-outline-primary"
                                               title="Edit Variant">
                                                <i class="bx bx-edit"></i>
                                            </a>
                                            <button type="button" 
                                                    class="btn btn-outline-info" 
                                                    data-bs-toggle="collapse" 
                                                    data-bs-target="#inventoryCollapse-@variant.ID"
                                                    title="View Inventory">
                                                <i class="bx bx-package"></i>
                                            </button>
                                            <button type="button" 
                                                    class="btn btn-outline-secondary"
                                                    data-bs-toggle="modal" 
                                                    data-bs-target="#imagesModal-@variant.ID"
                                                    title="View Images">
                                                <i class="bx bx-images"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                                
                                <!-- Inventory Collapse Section -->
                                <tr>
                                    <td colspan="8" class="p-0">
                                        <div class="collapse" id="inventoryCollapse-@variant.ID">
                                            <div class="card card-body m-3 border">
                                                <h6 class="mb-3">Outlet Inventory for @variant.SKU</h6>
                                                @if (variant.Inventory?.Any() == true)
                                                {
                                                    <div class="table-responsive">
                                                        <table class="table table-sm table-bordered mb-0">
                                                            <thead class="table-light">
                                                                <tr>
                                                                    <th>Outlet</th>
                                                                    <th class="text-end">Available</th>
                                                                    <th class="text-end">Min Stock</th>
                                                                    <th class="text-end">Max Stock</th>
                                                                    <th class="text-end">Reorder Point</th>
                                                                    <th>Status</th>
                                                                    <th style="width: 80px">Actions</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                @foreach (var inventory in variant.Inventory)
                                                                {
                                                                    <tr>
                                                                        <td>@inventory.Outlet.Name</td>
                                                                        <td class="text-end">@inventory.QuantityAvailable</td>
                                                                        <td class="text-end">@inventory.MinimumStockLevel</td>
                                                                        <td class="text-end">@inventory.MaximumStockLevel</td>
                                                                        <td class="text-end">@inventory.ReorderPoint</td>
                                                                        <td>
                                                                            <span class="badge bg-@(inventory.IsInStock ? "success" : "danger")">
                                                                                @(inventory.IsInStock ? "In Stock" : "Out of Stock")
                                                                            </span>
                                                                        </td>
                                                                        <td class="text-center">
                                                                            <a asp-controller="Inventory" asp-action="Edit" 
                                                                               asp-route-id="@inventory.ID" 
                                                                               class="btn btn-sm btn-outline-primary">
                                                                                <i class="bx bx-edit"></i>
                                                                            </a>
                                                                        </td>
                                                                    </tr>
                                                                }
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="alert alert-info mb-0">
                                                        <i class="bx bx-info-circle me-1"></i>
                                                        No inventory records found for this variant
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                </tr>

                                <!-- Images Modal -->
                                <div class="modal fade" id="imagesModal-@variant.ID" tabindex="-1">
                                    <div class="modal-dialog modal-lg">
                                        <div class="modal-content">
                                            <div class="modal-header">
                                                <h5 class="modal-title">
                                                    <i class="bx bx-images me-1"></i>
                                                    Images for @variant.SKU
                                                </h5>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                            </div>
                                            <div class="modal-body">
                                                @if (ViewBag.attachments != null && ViewBag.attachments.Count > 0)
                                                {
                                                    <div class="row row-cols-2 row-cols-md-4 g-3">
                                                        @foreach (var imageKey in ViewBag.attachments)
                                                        {
                                                            <div class="col">
                                                                <div class="card h-100 border">
                                                                    <a href="@Url.Action("DisplayImage", "File", new { key = imageKey })" 
                                                                       target="_blank" 
                                                                       class="h-100">
                                                                        <img src="@Url.Action("DisplayImage", "File", new { key = imageKey })"
                                                                             class="card-img-top h-100"
                                                                             alt="Variant Image"
                                                                             style="object-fit: cover;">
                                                                    </a>
                                                                </div>
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="alert alert-info mb-0">
                                                        <i class="bx bx-info-circle me-1"></i>
                                                        No images available for this variant
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info mb-0">
                    <i class="bx bx-info-circle me-1"></i>
                    No variants available for this product
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#variantsTable').DataTable({
                pageLength: 10,
                order: [[1, 'asc']], // Order by SKU column
                responsive: true,
                dom: '<"row mb-3"<"col-md-6"l><"col-md-6"f>><"row"<"col-md-12"t>><"row"<"col-md-6"i><"col-md-6"p>>',
                language: {
                    search: "",
                    searchPlaceholder: "Search variants..."
                }
            });
        });
    </script>
}