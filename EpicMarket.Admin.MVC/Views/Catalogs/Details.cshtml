@model EpicMarket.Admin.MVC.Models.CatelogModel

@{
    ViewData["Title"] = "Details";
}



		<!--breadcrumb-->
<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
	<div class="breadcrumb-title pe-3">Catelog</div>
	<div class="ps-3">
		<nav aria-label="breadcrumb">
			<ol class="breadcrumb mb-0 p-0">
				<li class="breadcrumb-item">
					<a asp-action="Index"><i class="bx bx-home-alt"></i></a>
				</li>
				<li class="breadcrumb-item active" aria-current="page">Products Details</li>
			</ol>
		</nav>
	</div>
</div>
<!--end breadcrumb-->

<hr/>

<div class="card">
	<div class="row g-0">
		<div class="col-md-4 border-end">
			@if (!string.IsNullOrEmpty(ViewBag.thumbnail))
			{
				<a href="@Url.Action("DisplayImage", "File", new { key = ViewBag.thumbnail })" target="_blank" rel="noopener noreferrer">
					<img src="@Url.Action("DisplayImage", "File", new { key = ViewBag.thumbnail })" alt="Thumbnail Image"
						 style="max-width: 100%; max-height: 100%; object-fit: contain; cursor: pointer;" />
				</a>
			}
			else
			{
				<div class="d-flex justify-content-center align-items-center h-100">
					<div class="text-center">
						<i class="bx bx-image-alt" style="font-size: 48px; color: #ccc;"></i>
						<p class="mt-2 text-muted">No thumbnail available</p>
					</div>
				</div>
			}
		</div>
		<div class="col-md-8">
			<div class="card-body">
				<div class="float-end">
					<a asp-action="Edit" class="btn btn-primary px-5" asp-route-id="@Model.Catalog.ID">Edit</a>
				</div>
				<h4 class="card-title"> @Html.DisplayFor(model => model.Catalog.Name)</h4>
				<div class="d-flex flex-wrap gap-3 py-3">
					<div class="d-flex align-items-center">
						@{
							var isActiveIcon = Model.Catalog.IsActive ? "bx-check-circle text-success" : "bx-x-circle text-danger";
							var isActiveText = Model.Catalog.IsActive ? "Active" : "Inactive";
						}
						<i class="bx @isActiveIcon me-1"></i>
						<strong class="me-1">@Html.DisplayNameFor(model => model.Catalog.IsActive):</strong>
						<span>@isActiveText</span>
					</div>
@* 					<div class="d-flex align-items-center">
						@{
							var inStockIcon = Model.InStock ? "bx-package text-success" : "bx-package text-danger";
							var inStockText = Model.InStock ? "In Stock" : "Out of Stock";
						}
						<i class="bx @inStockIcon me-1"></i>
						<strong class="me-1">@Html.DisplayNameFor(model => model.InStock):</strong>
						<span>@inStockText</span>
					</div> *@
					<div class="d-flex align-items-center">
						@{
							var isRecommendedIcon = Model.Catalog.IsRecommended ? "bx-like text-primary" : "bx-dislike text-muted";
							var isRecommendedText = Model.Catalog.IsRecommended ? "Recommended" : "Not Recommended";
						}
						<i class="bx @isRecommendedIcon me-1"></i>
						<strong class="me-1">@Html.DisplayNameFor(model => model.Catalog.IsRecommended):</strong>
						<span>@isRecommendedText</span>
					</div>
					<div class="d-flex align-items-center">
						<i class="bx bx-star me-1 text-warning"></i>
						<strong class="me-1">@Html.DisplayNameFor(model => model.Catalog.Rating):</strong>
						<span>@Html.DisplayFor(model => model.Catalog.Rating)</span>
					</div>
					<div class="d-flex align-items-center">
						@{
							var statusColor = Model.Catalog.StatusOptionSets.Status.Equals("Active", StringComparison.OrdinalIgnoreCase) ? "success" : "danger";
							var statusIcon = statusColor == "success" ? "bx-check-circle" : "bx-x-circle";
						}
						<i class="bx @statusIcon me-1 text-@statusColor"></i>
						<strong class="me-1">Status:</strong>
						<span class="badge bg-@statusColor">@Html.DisplayFor(model => model.Catalog.StatusOptionSets.Status)</span>
					</div>
				</div>
				<div class="mb-3">
					<span class="price h4">₹ @Html.DisplayFor(model => model.Catalog.Rate)</span>
				</div>
				<p class="card-text fs-6"> @Html.DisplayFor(model => model.Catalog.Description)</p>
				<div class="row">
					<dl class="row col-6">
						<dt class="col-sm-4">
							@Html.DisplayNameFor(model => model.Catalog.Barcode)
						</dt>
						<dd class="col-sm-8">
							@Html.DisplayFor(model => model.Catalog.Barcode)
						</dd>
						<dt class="col-sm-4">
							@Html.DisplayNameFor(model => model.Catalog.Category)
						</dt>
						<dd class="col-sm-8">
							@Html.DisplayFor(model => model.Catalog.Category)
						</dd>

						<dt class="col-sm-4">
							@Html.DisplayNameFor(model => model.Catalog.MaximumOrderPurchase)
						</dt>
						<dd class="col-sm-8">
							@Html.DisplayFor(model => model.Catalog.MaximumOrderPurchase)
						</dd>
						<dt class="col-sm-4">
							@Html.DisplayNameFor(model => model.Catalog.ReviewCount)
						</dt>
						<dd class="col-sm-8">
							@Html.DisplayFor(model => model.Catalog.ReviewCount)
						</dd>
						<dt class="col-sm-4">
							@Html.DisplayNameFor(model => model.Catalog.OrderCount)
						</dt>
						<dd class="col-sm-8">
							@Html.DisplayFor(model => model.Catalog.OrderCount)
						</dd>
					</dl>
					<dl class="row col-6">
							<dt class="col-sm-4">
							@Html.DisplayNameFor(model => model.Catalog.Business)
							</dt>
							<dd class="col-sm-8">
							@Html.DisplayFor(model => model.Catalog.Business.ID)
							</dd>
							<dt class="col-sm-4">
							@Html.DisplayNameFor(model => model.Catalog.CreateDate)
							</dt>
							<dd class="col-sm-8">
							@Html.DisplayFor(model => model.Catalog.CreateDate)
							</dd>
							<dt class="col-sm-4">
							@Html.DisplayNameFor(model => model.Catalog.CreateBy)
							</dt>
							<dd class="col-sm-8">
							@Html.DisplayFor(model => model.Catalog.CreateBy)
							</dd>
							<dt class="col-sm-4">
							@Html.DisplayNameFor(model => model.Catalog.ModifiedDate)
							</dt>
							<dd class="col-sm-8">
							@Html.DisplayFor(model => model.Catalog.ModifiedDate)
							</dd>
							<dt class="col-sm-4">
							@Html.DisplayNameFor(model => model.Catalog.ModifiedBy)
							</dt>
							<dd class="col-sm-8">
								@Html.DisplayFor(model => model.Catalog.ModifiedBy)
							</dd>
					</dl>
				</div>
			</div>
		</div>
	</div>
</div>
<div class="card mt-4">
	<div class="card-header">
		<h5 class="card-title mb-0">Product Images</h5>
	</div>
	<div class="card-body">
		@if (ViewBag.attachments != null && ViewBag.attachments.Count > 0)
		{
			<div class="row row-cols-1 row-cols-md-4 g-4">
				@foreach (var imageKey in ViewBag.attachments)
				{
					<div class="col">
						<div class="card h-100">
							<a href="@Url.Action("DisplayImage", "File", new { key = imageKey })" target="_blank" rel="noopener noreferrer">
								<img src="@Url.Action("DisplayImage", "File", new { key = imageKey })"
									 class="card-img-top"
									 alt="Product Image"
									 style="height: 200px; object-fit: cover; cursor: pointer;">
							</a>
						</div>
					</div>
				}
			</div>
		}
		else
		{
			<div class="alert alert-info" role="alert">
				<i class="bx bx-info-circle me-1"></i>
				No images found.
			</div>
		}
	</div>
</div>

<div class="card-body">
	<ul class="nav nav-tabs nav-primary mb-0" role="tablist">
		<li class="nav-item" role="presentation">
			<a class="nav-link active" data-bs-toggle="tab" href="#primaryorders" role="tab" aria-selected="true">
				<div class="d-flex align-items-center">
					<div class="tab-icon">
						<i class='bx bx-comment-detail font-18 me-1'></i>
					</div>
					<div class="tab-title"> Orders </div>
				</div>
			</a>
		</li>
	</ul>
	<div class="tab-content pt-3">
		<div class="tab-pane fade show active" id="primaryorders" role="tabpanel">
			<div class="card">
				<div class="card-body">
					<div class="table-responsive">
						<div class="d-flex justify-content-end mb-3">
							<a asp-controller="OutletProducts" asp-action="Create" class="btn btn-primary px-5" asp-route-productID="@Model?.Catalog.ID">Add OutletProduct</a>
						</div>
						<table id="example" class="table table-striped table-bordered" style="width:100%">
							<thead>
								<tr>
									<th>
										@Html.DisplayNameFor(model => model.OutletProduct.Outlet)
									</th>
									<th>
										@Html.DisplayNameFor(model => model.OutletProduct.QuantityAvailable)
									</th>
									<th>
										@Html.DisplayNameFor(model => model.OutletProduct.MaximumStockLevel)
									</th>
									<th>
										@Html.DisplayNameFor(model => model.OutletProduct.MinimumStockLevel)
									</th>
									<th>
										@Html.DisplayNameFor(model => model.OutletProduct.ReorderPoint)
									</th>
									<th>
										@Html.DisplayNameFor(model => model.OutletProduct.BackOrders)
									</th>
									<th></th>
								</tr>
							</thead>
							<tbody>
								@foreach (var item in Model.OutletProducts)
								{
									<tr>
										<td>
											<a asp-controller="Outlet" asp-action="Details" asp-route-id="@item.OutletID"> @Html.DisplayFor(modelItem => item.OutletID)</a>
										</td>
										<td>
											@Html.DisplayFor(modelItem => item.QuantityAvailable)
										</td>
										<td>
											@Html.DisplayFor(modelItem => item.MaximumStockLevel)
										</td>
										<td>
											@Html.DisplayFor(modelItem => item.MinimumStockLevel)
										</td>
										<td>
											@Html.DisplayFor(modelItem => item.ReorderPoint)
										</td>
										<td>
											@Html.DisplayFor(modelItem => item.BackOrders)
										</td>
										<td>
											<a asp-controller="OrderDetails" asp-action="Edit" asp-route-id="@item.ID">Edit</a> |
											<a asp-controller="OrderDetails" asp-action="Details" asp-route-id="@item.ID">Details</a> |
											<a asp-controller="OrderDetails" asp-action="Delete" asp-route-id="@item.ID">Delete</a>
										</td>
									</tr>
								}
							</tbody>
						</table>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

</div>
@section Scripts {
	<script>
		$(document).ready(function () {
			$('#example').DataTable();
		});
	</script>
}