@model EpicMarket.Data.Models.Catalog

@{
    ViewData["Title"] = "Details";
}



		<!--breadcrumb-->
<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
	<div class="breadcrumb-title pe-3">Catelog</div>
	<div class="ps-3">
		<nav aria-label="breadcrumb">
			<ol class="breadcrumb mb-0 p-0">
				<li class="breadcrumb-item">
					<a asp-action="Index"><i class="bx bx-home-alt"></i></a>
				</li>
				<li class="breadcrumb-item active" aria-current="page">Products Details</li>
			</ol>
		</nav>
	</div>
</div>
<!--end breadcrumb-->

<hr/>

<div class="card">
	<div class="row g-0">
		<div class="col-md-4 border-end">
			@if (!string.IsNullOrEmpty(ViewBag.thumbnail))
			{
				<a href="@Url.Action("DisplayImage", "File", new { key = ViewBag.thumbnail })" target="_blank" rel="noopener noreferrer">
					<img src="@Url.Action("DisplayImage", "File", new { key = ViewBag.thumbnail })" alt="Thumbnail Image"
						 style="max-width: 100%; max-height: 100%; object-fit: contain; cursor: pointer;" />
				</a>
			}
			else
			{
				<div class="d-flex justify-content-center align-items-center h-100">
					<div class="text-center">
						<i class="bx bx-image-alt" style="font-size: 48px; color: #ccc;"></i>
						<p class="mt-2 text-muted">No thumbnail available</p>
					</div>
				</div>
			}
		</div>
		<div class="col-md-8">
			<div class="card-body">
				<div class="float-end">
					<a asp-action="Edit" class="btn btn-primary px-5" asp-route-id="@Model?.ID">Edit</a>
				</div>
				<h4 class="card-title"> @Html.DisplayFor(model => model.Name)</h4>
				<div class="d-flex flex-wrap gap-3 py-3">
					<div class="d-flex align-items-center">
						@{
							var isActiveIcon = Model.IsActive ? "bx-check-circle text-success" : "bx-x-circle text-danger";
							var isActiveText = Model.IsActive ? "Active" : "Inactive";
						}
						<i class="bx @isActiveIcon me-1"></i>
						<strong class="me-1">@Html.DisplayNameFor(model => model.IsActive):</strong>
						<span>@isActiveText</span>
					</div>
					<div class="d-flex align-items-center">
						@{
							var inStockIcon = Model.InStock ? "bx-package text-success" : "bx-package text-danger";
							var inStockText = Model.InStock ? "In Stock" : "Out of Stock";
						}
						<i class="bx @inStockIcon me-1"></i>
						<strong class="me-1">@Html.DisplayNameFor(model => model.InStock):</strong>
						<span>@inStockText</span>
					</div>
					<div class="d-flex align-items-center">
						@{
							var isRecommendedIcon = Model.IsRecommended ? "bx-like text-primary" : "bx-dislike text-muted";
							var isRecommendedText = Model.IsRecommended ? "Recommended" : "Not Recommended";
						}
						<i class="bx @isRecommendedIcon me-1"></i>
						<strong class="me-1">@Html.DisplayNameFor(model => model.IsRecommended):</strong>
						<span>@isRecommendedText</span>
					</div>
					<div class="d-flex align-items-center">
						<i class="bx bx-star me-1 text-warning"></i>
						<strong class="me-1">@Html.DisplayNameFor(model => model.Rating):</strong>
						<span>@Html.DisplayFor(model => model.Rating)</span>
					</div>
					<div class="d-flex align-items-center">
						@{
							var statusColor = Model.StatusOptionSets.Status.Equals("Active", StringComparison.OrdinalIgnoreCase) ? "success" : "danger";
							var statusIcon = statusColor == "success" ? "bx-check-circle" : "bx-x-circle";
						}
						<i class="bx @statusIcon me-1 text-@statusColor"></i>
						<strong class="me-1">Status:</strong>
						<span class="badge bg-@statusColor">@Html.DisplayFor(model => model.StatusOptionSets.Status)</span>
					</div>
				</div>
				<div class="mb-3">
				<span class="price h4">₹ @Html.DisplayFor(model => model.Rate)</span>
				</div>
				<p class="card-text fs-6"> @Html.DisplayFor(model => model.Description)</p>
				<div class="row">
					<dl class="row col-6">
						<dt class="col-sm-4">
							@Html.DisplayNameFor(model => model.Barcode)
						</dt>
						<dd class="col-sm-8">
							@Html.DisplayFor(model => model.Barcode)
						</dd>
						<dt class="col-sm-4">
							@Html.DisplayNameFor(model => model.Category)
						</dt>
						<dd class="col-sm-8">
							@Html.DisplayFor(model => model.Category)
						</dd>

						<dt class="col-sm-4">
							@Html.DisplayNameFor(model => model.MaximumOrderPurchase)
						</dt>
						<dd class="col-sm-8">
							@Html.DisplayFor(model => model.MaximumOrderPurchase)
						</dd>
						<dt class="col-sm-4">
							@Html.DisplayNameFor(model => model.ReviewCount)
						</dt>
						<dd class="col-sm-8">
							@Html.DisplayFor(model => model.ReviewCount)
						</dd>
						<dt class="col-sm-4">
							@Html.DisplayNameFor(model => model.OrderCount)
						</dt>
						<dd class="col-sm-8">
							@Html.DisplayFor(model => model.OrderCount)
						</dd>
					</dl>
					<dl class="row col-6">
							<dt class="col-sm-4">
								@Html.DisplayNameFor(model => model.Business)
							</dt>
							<dd class="col-sm-8">
								@Html.DisplayFor(model => model.Business.ID)
							</dd>
							<dt class="col-sm-4">
								@Html.DisplayNameFor(model => model.CreateDate)
							</dt>
							<dd class="col-sm-8">
								@Html.DisplayFor(model => model.CreateDate)
							</dd>
							<dt class="col-sm-4">
								@Html.DisplayNameFor(model => model.CreateBy)
							</dt>
							<dd class="col-sm-8">
								@Html.DisplayFor(model => model.CreateBy)
							</dd>
							<dt class="col-sm-4">
								@Html.DisplayNameFor(model => model.ModifiedDate)
							</dt>
							<dd class="col-sm-8">
								@Html.DisplayFor(model => model.ModifiedDate)
							</dd>
							<dt class="col-sm-4">
								@Html.DisplayNameFor(model => model.ModifiedBy)
							</dt>
							<dd class="col-sm-8">
								@Html.DisplayFor(model => model.ModifiedBy)
							</dd>
					</dl>
				</div>
			</div>
		</div>
	</div>
</div>
<div class="card mt-4">
	<div class="card-header">
		<h5 class="card-title mb-0">Product Images</h5>
	</div>
	<div class="card-body">
		@if (ViewBag.attachments != null && ViewBag.attachments.Count > 0)
		{
			<div class="row row-cols-1 row-cols-md-4 g-4">
				@foreach (var imageKey in ViewBag.attachments)
				{
					<div class="col">
						<div class="card h-100">
							<a href="@Url.Action("DisplayImage", "File", new { key = imageKey })" target="_blank" rel="noopener noreferrer">
								<img src="@Url.Action("DisplayImage", "File", new { key = imageKey })"
									 class="card-img-top"
									 alt="Product Image"
									 style="height: 200px; object-fit: cover; cursor: pointer;">
							</a>
						</div>
					</div>
				}
			</div>
		}
		else
		{
			<div class="alert alert-info" role="alert">
				<i class="bx bx-info-circle me-1"></i>
				No images found.
			</div>
		}
	</div>
</div>


