@model EpicMarket.Data.Models.Catalog

@{
    ViewData["Title"] = "Edit";
}

<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Catelog</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a asp-action="Index"><i class="bx bx-home-alt"></i></a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Edit</li>
            </ol>
        </nav>
    </div>
</div>
<hr />
<div class="row">
    <div class="col-xl-9 mx-auto">
        <div class="card border-top border-0 border-4 border-info">
            <div class="card-body">
                <div class="border p-4 rounded">
                    <div class="card-title d-flex align-items-center">
                        <div>
                            <i class="bx bxs-user me-1 font-22 text-info"></i>
                        </div>
                        <h5 class="mb-0 text-info">Edit Catelog Details</h5>
                    </div>
                    <hr />
                    <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="ID" />
                        <input type="hidden" asp-for="OrderCount" />
                        <input type="hidden" asp-for="Rating" />
                        <input type="hidden" asp-for="ReviewCount" />
                        <input type="hidden" asp-for="CreateDate" />
                        <input type="hidden" asp-for="CreateBy" />
                        <input type="hidden" asp-for="ModifiedDate" />
                        <input type="hidden" asp-for="ModifiedBy" />
                    <div class="row mb-3">
                        <label asp-for="BusinessID" class="col-sm-3 col-form-label"></label>
                         <div class="col-sm-9">
                            <select class="single-select" asp-for="BusinessID" asp-items="ViewBag.BusinessID"></select>
                            <span asp-validation-for="BusinessID" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label asp-for="Barcode" class="col-sm-3 col-form-label"></label>
                         <div class="col-sm-9">
                            <input asp-for="Barcode" class="form-control" />
                            <span asp-validation-for="Barcode" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label asp-for="Name" class="col-sm-3 col-form-label"></label>
                         <div class="col-sm-9">
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label asp-for="Description" class="col-sm-3 col-form-label"></label>
                         <div class="col-sm-9">
                            <textarea asp-for="Description" class="form-control"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>
                    </div>
                    @* <div class="row mb-3">
                        <label asp-for="Images" class="col-sm-3 col-form-label"></label>
                         <div class="col-sm-9">
                            <input asp-for="Images" class="form-control" />
                            <span asp-validation-for="Images" class="text-danger"></span>
                        </div>
                    </div> *@
                    <div class="row mb-3">
                        <label asp-for="Category" class="col-sm-3 col-form-label"></label>
                         <div class="col-sm-9">
                            <input asp-for="Category" class="form-control" />
                            <span asp-validation-for="Category" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label asp-for="Rate" class="col-sm-3 col-form-label"></label>
                         <div class="col-sm-9">
                            <input asp-for="Rate" class="form-control" />
                            <span asp-validation-for="Rate" class="text-danger"></span>
                        </div>
                    </div>
                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <div class="form-check">
                                    <input class="form-check-input" asp-for="IsActive" />
                                    <label class="form-check-label" for="gridCheck4"> @Html.DisplayNameFor(model => model.IsActive)</label>
                                </div>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <div class="form-check">
                                    <input class="form-check-input" asp-for="InStock" />
                                    <label class="form-check-label" for="gridCheck4"> @Html.DisplayNameFor(model => model.InStock)</label>
                                </div>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <div class="form-check">
                                    <input class="form-check-input" asp-for="IsRecommended" />
                                    <label class="form-check-label" for="gridCheck4"> @Html.DisplayNameFor(model => model.IsRecommended)</label>
                                </div>
                            </div>
                        </div>
                    <div class="row mb-3">
                        <label asp-for="MaximumOrderPurchase" class="col-sm-3 col-form-label"></label>
                         <div class="col-sm-9">
                            <input asp-for="MaximumOrderPurchase" class="form-control" />
                            <span asp-validation-for="MaximumOrderPurchase" class="text-danger"></span>
                        </div>
                    </div>
                        <div class="row mb-3">
                            <label asp-for="StatusId" class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <select class="single-select" asp-for="StatusId" asp-items="ViewBag.StatusId"></select>
                                <span asp-validation-for="StatusId" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="row">
                            <label class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <button type="submit" class="btn btn-info px-5"> Save</button>
                            </div>
                            <div>
                                <a asp-action="Index">Back to List</a>
                            </div>
                        </div>
                </form>
                </div>
            </div>
        </div>
    </div>
</div>



@section Scripts {
    <script>
        $('.single-select').select2({
            theme: 'bootstrap4',
            width: $(this).data('width') ? $(this).data('width') : $(this).hasClass('w-100') ? '100%' : 'style',
            placeholder: $(this).data('placeholder'),
            allowClear: Boolean($(this).data('allow-clear')),
        });
        $('.single-select2').select2({
            theme: 'bootstrap4',
            width: $(this).data('width') ? $(this).data('width') : $(this).hasClass('w-100') ? '100%' : 'style',
            placeholder: $(this).data('placeholder'),
            allowClear: Boolean($(this).data('allow-clear')),
        });
    </script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

}
