@model string

@{
    var featureName = Model ?? "this feature";
    var message = ViewData["AccessDeniedMessage"] as string ?? $"You do not have permission to access {featureName}.";
}

<div class="card border-0 shadow-sm">
    <div class="card-body p-4">
        <div class="text-center mb-4">
            <i class="bx bx-lock-alt text-danger" style="font-size: 4rem;"></i>
        </div>
        
        <div class="alert alert-danger">
            <div class="d-flex align-items-center">
                <i class="bx bx-error-circle me-3" style="font-size: 1.5rem;"></i>
                <div>
                    <h5 class="alert-heading">Access Denied</h5>
                    <p class="mb-0">@message</p>
                </div>
            </div>
        </div>
        
        <p class="text-muted text-center">
            If you believe you should have access to this feature, please contact your administrator.
        </p>
        
        <div class="text-center mt-4">
            <a href="javascript:history.back()" class="btn btn-outline-secondary me-2">
                <i class="bx bx-arrow-back me-1"></i>Go Back
            </a>
            <a href="/" class="btn btn-primary">
                <i class="bx bx-home-alt me-1"></i>Go to Dashboard
            </a>
        </div>
    </div>
</div> 