@model EpicMarket.Data.Models.OrderTypesOptions

@{
    ViewData["Title"] = "Delete Order Type Option";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Order Type Options</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a asp-action="Index"><i class="bx bx-home-alt"></i></a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Delete Order Type Option</li>
            </ol>
        </nav>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <h3 class="card-title">Confirm Order Type Option Deletion</h3>
        <p class="card-text">Are you sure you want to delete this order type option?</p>

        <div class="table-responsive">
            <table class="table table-bordered">
                <tr>
                    <th class="bg-light" style="width: 30%;">@Html.DisplayNameFor(model => model.Ordertype)</th>
                    <td>@Html.DisplayFor(model => model.Ordertype)</td>
                </tr>
            </table>
        </div>

        <form asp-action="Delete" class="mt-4">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex justify-content-between">
               <a href="javascript:history.go(-1)" class="btn btn-secondary">
                   <i class="bx bx-arrow-back me-1"></i> Back
                </a>
                <button type="submit" class="btn btn-danger">
                    <i class="bx bx-trash me-1"></i> Delete
                </button>
            </div>
        </form>
    </div>
</div>