@model EpicMarket.Data.Models.Notification

@{
    ViewData["Title"] = "Edit";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Notification</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a asp-action="Index"><i class="bx bx-home-alt"></i></a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Create</li>
            </ol>
        </nav>
    </div>
</div>
<hr />

<div class="row">
    <div class="col-xl-9 mx-auto">
        <div class="card border-top border-0 border-4 border-info">
            <div class="card-body">
                <div class="border p-4 rounded">
                    <div class="card-title d-flex align-items-center">
                        <div>
                            <i class="bx bxs-user me-1 font-22 text-info"></i>
                        </div>
                        <h5 class="mb-0 text-info">Notification</h5>
                    </div>
                    <hr />
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="DateCreated" />
                        <div class="row mb-3">
                            <label asp-for="Message" class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <input asp-for="Message" class="form-control" />
                                <span asp-validation-for="Message" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label asp-for="ContactMethodId" class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <select asp-for="ContactMethodId" class="form-control" asp-items="ViewBag.ContactMethodId"></select>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label asp-for="QuickLinkId" class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <select asp-for="QuickLinkId" class="form-control" asp-items="ViewBag.QuickLinkId"></select>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <div class="form-check">
                                    <input class="form-check-input" asp-for="IsRead" />
                                    <label class="form-check-label" for="gridCheck4"> @Html.DisplayNameFor(model => model.IsRead)</label>
                                </div>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <label asp-for="UserId" class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <select class="single-select" asp-for="UserId" class="form-control"
                                        data-ajax-url="@Url.Action("GetUsers", "AppUsers")"
                                        data-initial-id="@Model.UserId"
                                        data-initial-text="@ViewData["UserEmail"]">
                                </select>
                                <span asp-validation-for="UserId" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="row">
                            <label class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <button type="submit" class="btn btn-info px-5"> Save</button>
                            </div>
                            <div>
                                <a asp-action="Index">Back to List</a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            @section Scripts {
                <script>
                    $(document).ready(function () {
                        debugger
                        var $select = $('.single-select');
                        var initialId = $select.data('initial-id');
                        var initialText = $select.data('initial-text');


                        $select.select2({
                            theme: 'bootstrap4',
                            width: $(this).data('width') ? $(this).data('width') : $(this).hasClass('w-100') ? '100%' : 'style',
                            placeholder: $(this).data('placeholder'),
                            allowClear: Boolean($(this).data('allow-clear')),
                            ajax: {
                                url: $select.data('ajax-url'),
                                dataType: 'json',
                                delay: 250,
                                data: function (params) {
                                    return {
                                        search: params.term
                                    };
                                },
                                processResults: function (data) {
                                    return {
                                        results: data
                                    };
                                },
                                cache: true
                            },
                            minimumInputLength: 1
                        });

                        // If there's an initial value, fetch and set it
                        // If there's an initial value, set it
                        if (initialId && initialText) {
                            var option = new Option(initialText, initialId, true, true);
                            $select.append(option).trigger('change');
                        }
                    });
                </script>

                @{
                    await Html.RenderPartialAsync("_ValidationScriptsPartial");
                }
            }
