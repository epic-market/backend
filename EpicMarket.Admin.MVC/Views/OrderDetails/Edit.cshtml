@model EpicMarket.Data.Models.OrderDetail

@{
    ViewData["Title"] = "Edit";
}

<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Order Details</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a asp-action="Index"><i class="bx bx-home-alt"></i></a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Edit</li>
            </ol>
        </nav>
    </div>
</div>
<hr />
<div class="row">
    <div class="col-xl-9 mx-auto">
        <div class="card border-top border-0 border-4 border-info">
            <div class="card-body">
                <div class="border p-4 rounded">
                    <div class="card-title d-flex align-items-center">
                        <div>
                            <i class="bx bxs-user me-1 font-22 text-info"></i>
                        </div>
                        <h5 class="mb-0 text-info">Edit Order Details</h5>
                    </div>
                    <div class='card mb-4'>
                        <div class='card-body'>
                            <h5 class='card-title'>Order Details</h5>
                            <div class='row'>
                                <div class='col-md-6'>
                                    <p class='mb-1'><strong>Order ID:</strong> @Model.OrderID</p>
                                    <p class='mb-1'><strong>Catalog Name:</strong> @Model.Catalog.Name</p>
                                </div>
                                <div class='col-md-6'>
                                    <p class='mb-1'><strong>Rate:</strong> ₹<span id="displayRate">@Model.Rate.ToString("F2")</span></p>
                                    <p class='mb-1'><strong>Total Price:</strong> ₹<span id="displayTotalPrice">@Model.TotalPrice.ToString("F2")</span></p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <hr />
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="ID" />
            <input type="hidden" asp-for="CreateDate" />
            <input type="hidden" asp-for="CreateBy" />
            <input type="hidden" asp-for="ModifiedDate" />
            <input type="hidden" asp-for="ModifiedBy" />
             <input type="hidden" asp-for="IsActive" />
            <input type="hidden" asp-for="CatalogID" />
                        <input type="hidden" asp-for="OrderID" />
            <input type="hidden" asp-for="Rate" id="Rate" />
                        <input type="hidden" asp-for="TotalPrice" />
            <div class="row mb-3">
                <label asp-for="Quantity" class="col-sm-3 col-form-label"></label>
                <div class="col-sm-9">
                    <input asp-for="Quantity" class="form-control" oninput="updateTotalPrice()" />
                    <span asp-validation-for="Quantity" class="text-danger"></span>
                </div>
            </div>

            <div class="row mb-3">
                <label asp-for="TotalPrice" class="col-sm-3 col-form-label"></label>
                <div class="col-sm-9">
                    <input asp-for="TotalPrice" class="form-control" readonly disabled />
                    <span asp-validation-for="TotalPrice" class="text-danger"></span>
                </div>
            </div>
            <div class="row">
                <label class="col-sm-3 col-form-label"></label>
                <div class="col-sm-9">
                    <button type="submit" class="btn btn-info px-5"> Save</button>
                </div>
                <div>
                    <a asp-action="Index">Back to List</a>
                </div>
            </div>
        </form>
    </div>
</div>
</div>
</div>
</div>


@section Scripts {
    <script>
        function updateTotalPrice() {
            const quantity = parseFloat(document.getElementById('Quantity').value) || 0;
            const rate = parseFloat(document.getElementById('Rate').value) || 0;
            const totalPrice = quantity * rate;
            document.getElementById('TotalPrice').value = totalPrice.toFixed(2);
            document.getElementById('displayTotalPrice').textContent = totalPrice.toFixed(2);
        }
    </script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
