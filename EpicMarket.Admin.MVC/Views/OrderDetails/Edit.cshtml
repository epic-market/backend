@model EpicMarket.Data.Models.OrderDetail

@{
    ViewData["Title"] = "Edit";
}

<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Order Details</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a asp-action="Index"><i class="bx bx-home-alt"></i></a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Edit</li>
            </ol>
        </nav>
    </div>
</div>
<hr />
<div class="row">
    <div class="col-xl-9 mx-auto">
        <div class="card border-top border-0 border-4 border-info">
            <div class="card-body">
                <div class="border p-4 rounded">
                    <div class="card-title d-flex align-items-center">
                        <div>
                            <i class="bx bxs-user me-1 font-22 text-info"></i>
                        </div>
                        <h5 class="mb-0 text-info">Edit Order Details</h5>
                    </div>
                    <hr />
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="ID" />
            <input type="hidden" asp-for="CreateDate" />
            <input type="hidden" asp-for="CreateBy" />
            <input type="hidden" asp-for="ModifiedDate" />
            <input type="hidden" asp-for="ModifiedBy" />
            <div class="row mb-3">
                <label asp-for="OrderID" class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                <select asp-for="OrderID" class="form-control" asp-items="ViewBag.OrderID"></select>
                <span asp-validation-for="OrderID" class="text-danger"></span>
                            </div>
            </div>
            <div class="row mb-3">
                <label asp-for="CatalogID" class="col-sm-3 col-form-label"></label>
                                <div class="col-sm-9">
                <select asp-for="CatalogID" class="form-control" asp-items="ViewBag.CatalogID"></select>
                <span asp-validation-for="CatalogID" class="text-danger"></span>
                            </div>
            </div>
            <div class="row mb-3">
                <label asp-for="Quantity" class="col-sm-3 col-form-label"></label>
                                    <div class="col-sm-9">
                <input asp-for="Quantity" class="form-control" />
                <span asp-validation-for="Quantity" class="text-danger"></span>
                            </div>
            </div>
            <div class="row mb-3">
                <label asp-for="Rate" class="col-sm-3 col-form-label"></label>
                                        <div class="col-sm-9">
                <input asp-for="Rate" class="form-control" />
                <span asp-validation-for="Rate" class="text-danger"></span>
                            </div>
            </div>
            <div class="row mb-3">
                <label asp-for="TotalPrice" class="col-sm-3 col-form-label"></label>
                                            <div class="col-sm-9">
                <input asp-for="TotalPrice" class="form-control" />
                <span asp-validation-for="TotalPrice" class="text-danger"></span>
                            </div>
            </div>
            <div class="row">
                <label class="col-sm-3 col-form-label"></label>
                <div class="col-sm-9">
                    <button type="submit" class="btn btn-info px-5"> Save</button>
                </div>
                <div>
                    <a asp-action="Index">Back to List</a>
                </div>
            </div>
        </form>
    </div>
</div>
</div>
</div>
</div>


@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
