@model EpicMarket.Data.Models.AttachmentLink

@{
    ViewData["Title"] = "Attachment Link Details";
}

<div class="page-breadcrumb d-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Attachment Links</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a asp-action="Index"><i class="bx bx-home-alt"></i></a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Details</li>
            </ol>
        </nav>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="card-title mb-0">Attachment Link Details</h5>
            <a asp-action="Edit" class="btn btn-primary" asp-route-id="@Model?.ID">
                <i class="bx bx-edit me-1"></i> Edit
            </a>
        </div>

        <div class="table-responsive">
            <table class="table table-bordered">
                <tr>
                    <th class="bg-light" style="width: 30%;">@Html.DisplayNameFor(model => model.Attachments)</th>
                    <td>@Html.DisplayFor(model => model.Attachments.DocumentType)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.Entity)</th>
                    <td>@Html.DisplayFor(model => model.Entity.ID)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.AttachmentType)</th>
                    <td>@Html.DisplayFor(model => model.AttachmentType.Name)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.RecordID)</th>
                    <td>@Html.DisplayFor(model => model.RecordID)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.CreateDate)</th>
                    <td>@Html.DisplayFor(model => model.CreateDate)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.CreateBy)</th>
                    <td>@Html.DisplayFor(model => model.CreateBy)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.ModifiedDate)</th>
                    <td>@Html.DisplayFor(model => model.ModifiedDate)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.ModifiedBy)</th>
                    <td>@Html.DisplayFor(model => model.ModifiedBy)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.IsActive)</th>
                    <td>@Html.DisplayFor(model => model.IsActive)</td>
                </tr>
            </table>
        </div>
    </div>
    <div class="card-footer">
       <a href="javascript:history.go(-1)" class="btn btn-secondary">
           <i class="bx bx-arrow-back me-1"></i> Back
        </a>
    </div>
</div>
