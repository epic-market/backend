@model EpicMarket.Data.Models.AttachmentLink

@{
    ViewData["Title"] = "Edit";
}

<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Attachment Links</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a asp-action="Index"><i class="bx bx-home-alt"></i></a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Edit</li>
            </ol>
        </nav>
    </div>
</div>
<hr />

<div class="row">
    <div class="col-xl-9 mx-auto">
        <div class="card border-top border-0 border-4 border-info">
            <div class="card-body">
                <div class="border p-4 rounded">
                    <div class="card-title d-flex align-items-center">
                        <div>
                            <i class="bx bxs-user me-1 font-22 text-info"></i>
                        </div>
                        <h5 class="mb-0 text-info">Attachment Link</h5>
                    </div>
                    <hr />
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="ID" />
                        <input type="hidden" asp-for="CreateDate" />
                        <input type="hidden" asp-for="CreateBy" />
                        <input type="hidden" asp-for="ModifiedDate" />
                        <input type="hidden" asp-for="ModifiedBy" />
                        
                        <div class="row mb-3">
                            <label asp-for="AttachmentID" class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <select asp-for="AttachmentID" class="form-control" asp-items="ViewBag.AttachmentID"></select>
                                <span asp-validation-for="AttachmentID" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label asp-for="EntityID" class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <select asp-for="EntityID" class="form-control" asp-items="ViewBag.EntityID"></select>
                                <span asp-validation-for="EntityID" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label asp-for="AttachmentTypeID" class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <select asp-for="AttachmentTypeID" class="form-control" asp-items="ViewBag.AttachmentTypeID"></select>
                                <span asp-validation-for="AttachmentTypeID" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label asp-for="RecordID" class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <input asp-for="RecordID" class="form-control" />
                                <span asp-validation-for="RecordID" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label asp-for="IsActive" class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <div class="form-check">
                                    <input class="form-check-input" asp-for="IsActive" />
                                </div>
                            </div>
                        </div>
                        
                        <div class="row">
                            <label class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <button type="submit" class="btn btn-info px-5">Save</button>
                            </div>
                            <div>
                                <a asp-action="Index">Back to List</a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

