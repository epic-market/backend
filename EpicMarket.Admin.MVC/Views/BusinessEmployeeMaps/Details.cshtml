@model EpicMarket.Data.Models.BusinessEmployeeMap

@{
    ViewData["Title"] = "Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
	<div class="breadcrumb-title pe-3">Employee</div>
	<div class="ps-3">
		<nav aria-label="breadcrumb">
			<ol class="breadcrumb mb-0 p-0">
				<li class="breadcrumb-item">
					<a asp-action="Index"><i class="bx bx-home-alt"></i></a>
				</li>
				<li class="breadcrumb-item active" aria-current="page">Details</li>
			</ol>
		</nav>
	</div>
</div>
<hr />



<div class="card">
	<div class="row g-0">
		<div class="col-md-12">
			<div class="card-body">
				<div class="float-end">
					<a asp-action="Edit" class="btn btn-primary px-5" asp-route-id="@Model?.ID">Edit</a>
				</div>
				<h4 class="card-title"> @Html.DisplayFor(model => model.Employee.FirstName) @Html.DisplayFor(model => model.Employee.LastName)</h4>
				<div class="row">
					<dl class="row col-6">
						<dt class="col-sm-4">
							@Html.DisplayNameFor(model => model.Employee.Id)
						</dt>
						<dd class="col-sm-8">
							@Html.DisplayFor(model => model.Employee.Id)
						</dd>
						<dt class="col-sm-4">
							@Html.DisplayNameFor(model => model.Employee.UserName)
						</dt>
						<dd class="col-sm-8">
							@Html.DisplayFor(model => model.Employee.UserName)
						</dd>
						<dt class="col-sm-4">
							@Html.DisplayNameFor(model => model.Employee.PhoneNumber)
						</dt>
						<dd class="col-sm-8">
							@Html.DisplayFor(model => model.Employee.PhoneNumber)
						</dd>
						<dt class="col-sm-4">
							@Html.DisplayNameFor(model => model.Employee.LastActive)
						</dt>
						<dd class="col-sm-8">
							@Html.DisplayFor(model => model.Employee.LastActive)
						</dd>
					</dl>
					<dl class="row col-6">
						<dt class="col-sm-4">
							@Html.DisplayNameFor(model => model.Bussiness.ID)
						</dt>
						<dd class="col-sm-8">
							@Html.DisplayFor(model => model.Bussiness.ID)
						</dd>
						<dt class="col-sm-4">
							@Html.DisplayNameFor(model => model.Bussiness.Name)
						</dt>
						<dd class="col-sm-8">
							@Html.DisplayFor(model => model.Bussiness.Name)
						</dd>
						<dt class="col-sm-4">
							@Html.DisplayNameFor(model => model.Bussiness.ContactEmail)
						</dt>
						<dd class="col-sm-8">
							@Html.DisplayFor(model => model.Bussiness.ContactEmail)
						</dd>
						<dt class="col-sm-4">
							@Html.DisplayNameFor(model => model.Bussiness.ContactNumber)
						</dt>
						<dd class="col-sm-8">
							@Html.DisplayFor(model => model.Bussiness.ContactNumber)
						</dd>
					</dl>
				</div>
			</div>
		</div>
	</div>

</div>