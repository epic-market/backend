@model EpicMarket.Data.Models.BusinessCategoryInternal

@{
    ViewData["Title"] = "Edit";
    var categoryImages = ViewBag.CategoryImages as List<string>;
}


<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Business Category Internal</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a asp-action="Index"><i class="bx bx-home-alt"></i></a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Edit</li>
            </ol>
        </nav>
    </div>
</div>
<hr />

<div class="row">
    <div class="col-xl-9 mx-auto">
        <div class="card border-top border-0 border-4 border-info">
            <div class="card-body">
                <div class="border p-4 rounded">
                    <div class="card-title d-flex align-items-center">
                        <div>
                            <i class="bx bxs-user me-1 font-22 text-info"></i>
                        </div>
                        <h5 class="mb-0 text-info">Business Category Internal</h5>
                    </div>
                    <hr />
                    <form asp-action="Edit" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="ID" />
                        <input type="hidden" asp-for="CreateDate" />
                        <input type="hidden" asp-for="CreateBy" />
                        <input type="hidden" asp-for="ModifiedDate" />
                        <input type="hidden" asp-for="IsActive" />
                        <input type="hidden" asp-for="ModifiedBy" />
                        <input type="hidden" id="removedImagesInput" name="removedImages" value="" />
                        <div class="row mb-3">
                            <label asp-for="Name" class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <input asp-for="Name" class="form-control" />
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label asp-for="Description" class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <input asp-for="Description" class="form-control" />
                                <span asp-validation-for="Description" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label asp-for="Type" class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <input asp-for="Type" class="form-control" />
                                <span asp-validation-for="Type" class="text-danger"></span>
                            </div>
                        </div>
                        
                        <!-- Existing Images Section -->
                        @if (categoryImages != null && categoryImages.Any())
                        {
                            <div class="row mb-3">
                                <label class="col-sm-3 col-form-label">Current Images</label>
                                <div class="col-sm-9">
                                    <div class="row" id="existingImagesContainer">
                                        @foreach (var imageKey in categoryImages)
                                        {
                                            <div class="col-md-3 mb-3 position-relative image-container" data-image-key="@imageKey">
                                                <img src="@Url.Action("DisplayImage", "File", new { key = imageKey })" class="card-img-top" alt="Category Image" style="height: 150px; object-fit: cover;">
                                                <button type="button" class="btn btn-danger btn-sm position-absolute top-0 end-0" onclick="removeImage('@imageKey')">
                                                    <i class="bx bx-trash"></i>
                                                </button>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                        
                        <!-- Upload New Images Section -->
                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label">Add New Images</label>
                            <div class="col-sm-9">
                                <input type="file" name="files" class="form-control" multiple accept="image/*" />
                                <small class="text-muted">Upload one or more new images for this category</small>
                            </div>
                        </div>

                        <div class="row">
                            <label class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <button type="submit" class="btn btn-info px-5"> Save</button>
                            </div>
                            <div>
                                <a asp-action="Index">Back to List</a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>


@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        // Function to handle image removal
        function removeImage(imageKey) {
            // Add the image key to the hidden input (comma-separated)
            var currentValue = $("#removedImagesInput").val();
            if (currentValue) {
                $("#removedImagesInput").val(currentValue + ',' + imageKey);
            } else {
                $("#removedImagesInput").val(imageKey);
            }
            
            // Hide the image visually
            $(`[data-image-key="${imageKey}"]`).fadeOut();
            
            console.log("Image marked for removal: " + imageKey);
            console.log("Current removedImages value: " + $("#removedImagesInput").val());
        }
    </script>
}
