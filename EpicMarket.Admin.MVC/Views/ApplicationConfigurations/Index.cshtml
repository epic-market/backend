@model IEnumerable<EpicMarket.Data.ApplicationModels.ApplicationConfiguration>

@{
    ViewData["Title"] = "Application Configurations";
}

<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Application Configurations</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a asp-action="Index"><i class="bx bx-home-alt"></i></a>
                </li>
            </ol>
        </nav>
    </div>
</div>

<!-- Filter Card -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <h5 class="card-title mb-0">
                <i class="bx bx-filter me-2 text-primary"></i>Search & Filter
            </h5>
            <button class="btn btn-sm btn-link text-decoration-none" type="button" data-bs-toggle="collapse" data-bs-target="#filterCollapse" aria-expanded="true">
                <i class="bx bx-chevron-down"></i>
            </button>
        </div>
        <div class="collapse show" id="filterCollapse">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label small fw-semibold">Configuration ID</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bx bx-hash"></i></span>
                        <input type="text" class="form-control border-start-0 ps-0" id="configIdFilter" placeholder="Search by ID">
                    </div>
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-semibold">Configuration Name</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bx bx-cog"></i></span>
                        <input type="text" class="form-control border-start-0 ps-0" id="configNameFilter" placeholder="Search by name">
                    </div>
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-semibold">Status</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bx bx-toggle-right"></i></span>
                        <select class="form-select border-start-0 ps-0" id="statusFilter">
                            <option value="">All</option>
                            <option value="true" selected>Active</option>
                            <option value="false">Inactive</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-12 d-flex justify-content-end">
                    <button type="button" class="btn btn-primary me-2 px-4" id="searchBtn">
                        <i class='bx bx-search me-1'></i>Search
                    </button>
                    <button type="button" class="btn btn-outline-secondary" id="resetFilter">
                        <i class='bx bx-reset me-1'></i>Reset
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Main Card -->
<div class="card border-0 shadow-sm">
    <div class="card-body">
        <!-- Action Bar -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div class="d-flex align-items-center">
                <h5 class="mb-0 me-2">Configuration List</h5>
                <span class="badge bg-primary rounded-pill" id="tableRecordsCount">0</span>
            </div>
            <div>
                <a asp-action="Create" class="btn btn-primary d-flex align-items-center">
                    <i class='bx bx-plus me-1'></i>Create New
                </a>
            </div>
        </div>
        
        <!-- Table Wrapper -->
        <div class="table-responsive">
            <table id="example" class="table table-hover align-middle" style="width:100%">
                <thead class="table-light">
                    <tr>
                        <th data-sort="id" class="cursor-pointer">
                            <div class="d-flex align-items-center">
                                ID <i class="bx bx-sort-alt-2 ms-1 text-muted"></i>
                            </div>
                        </th>
                        <th data-sort="name" class="cursor-pointer">
                            <div class="d-flex align-items-center">
                                Name <i class="bx bx-sort-alt-2 ms-1 text-muted"></i>
                            </div>
                        </th>
                        <th data-sort="description" class="cursor-pointer">
                            <div class="d-flex align-items-center">
                                Description <i class="bx bx-sort-alt-2 ms-1 text-muted"></i>
                            </div>
                        </th>
                        <th data-sort="isactive" class="cursor-pointer">
                            <div class="d-flex align-items-center">
                                Status <i class="bx bx-sort-alt-2 ms-1 text-muted"></i>
                            </div>
                        </th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Table data will be loaded dynamically -->
                </tbody>
            </table>
            
            <!-- Loading Indicator -->
            <div id="loading-indicator" class="text-center py-5 d-none">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="mt-2">Loading configurations...</p>
            </div>
            
            <!-- Empty State -->
            <div id="empty-state" class="text-center py-5 d-none">
                <i class="bx bx-cog text-muted" style="font-size: 4rem;"></i>
                <h5 class="mt-3">No configurations found</h5>
                <p class="text-muted">Try adjusting your search criteria or add a new configuration</p>
                <a asp-action="Create" class="btn btn-primary mt-2">
                    <i class='bx bx-plus me-1'></i>Create New
                </a>
            </div>
        </div>
        
        <!-- Pagination Info and Controls -->
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mt-4">
            <div id="pagination-info" class="text-muted mb-3 mb-md-0">
                Showing 0 to 0 of 0 entries
            </div>
            <div id="pagination-controls"></div>
        </div>
    </div>
</div>

<!-- Custom CSS -->
<style>
    .cursor-pointer { cursor: pointer; }
    .table th { font-weight: 600; }
    .status-badge {
        padding: 5px 10px;
        border-radius: 30px;
        font-size: 12px;
        font-weight: 500;
    }
    .status-active {
        background-color: rgba(25, 135, 84, 0.1);
        color: rgb(25, 135, 84);
    }
    .status-inactive {
        background-color: rgba(108, 117, 125, 0.1);
        color: rgb(108, 117, 125);
    }
    .action-btn {
        padding: 5px;
        margin-right: 5px;
        border-radius: 4px;
    }
    .action-btn:hover {
        background-color: rgba(0, 0, 0, 0.05);
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function () {
            let currentPage = 1;
            let pageSize = 10;
            let sortColumn = 'id';
            let sortDirection = 'asc';
            let isLoading = false;

            // Check URL parameters and set filter values
            const urlParams = new URLSearchParams(window.location.search);
            if (urlParams.has('configId')) {
                $('#configIdFilter').val(urlParams.get('configId'));
            }
            if (urlParams.has('configName')) {
                $('#configNameFilter').val(urlParams.get('configName'));
            }
            if (urlParams.has('status')) {
                $('#statusFilter').val(urlParams.get('status'));
            }
            if (urlParams.has('page')) {
                currentPage = parseInt(urlParams.get('page')) || 1;
            }
            if (urlParams.has('sort')) {
                sortColumn = urlParams.get('sort');
            }
            if (urlParams.has('dir')) {
                sortDirection = urlParams.get('dir');
            }

            function updateUrl() {
                const params = new URLSearchParams();
                const configId = $('#configIdFilter').val();
                const configName = $('#configNameFilter').val();
                const status = $('#statusFilter').val();
                
                if (configId) params.set('configId', configId);
                if (configName) params.set('configName', configName);
                if (status) params.set('status', status);
                if (currentPage > 1) params.set('page', currentPage);
                if (sortColumn !== 'id') params.set('sort', sortColumn);
                if (sortDirection !== 'asc') params.set('dir', sortDirection);
                
                const newUrl = window.location.pathname + (params.toString() ? '?' + params.toString() : '');
                history.pushState({}, '', newUrl);
            }

            function loadData() {
                // Show loading indicator
                $('#loading-indicator').removeClass('d-none');
                $('#empty-state').addClass('d-none');
                $('#example tbody').empty();
                
                isLoading = true;
                
                $.ajax({
                    url: '/ApplicationConfigurations/GetFilteredData',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({
                        configId: $('#configIdFilter').val(),
                        configName: $('#configNameFilter').val(),
                        value: '', // Still sending empty value for backend compatibility
                        isActive: $('#statusFilter').val(),
                        pageNumber: currentPage,
                        pageSize: pageSize,
                        sortColumn: sortColumn,
                        sortDirection: sortDirection
                    }),
                    success: function (response) {
                        isLoading = false;
                        $('#loading-indicator').addClass('d-none');
                        
                        if (response.error) {
                            console.error(response.error);
                            showToast('Error loading data: ' + response.error, 'error');
                            return;
                        }
                        
                        // Update record count
                        $('#tableRecordsCount').text(response.totalRecords);
                        
                        if (response.data && response.data.length > 0) {
                            updateTable(response.data);
                            updatePagination(response.totalRecords);
                        } else {
                            $('#empty-state').removeClass('d-none');
                            $('#pagination-info').text('Showing 0 to 0 of 0 entries');
                            $('#pagination-controls').empty();
                        }
                        
                        // Update URL with current filters
                        updateUrl();
                    },
                    error: function (xhr, status, error) {
                        isLoading = false;
                        $('#loading-indicator').addClass('d-none');
                        console.error('Error:', error);
                        showToast('Failed to load data. Please try again.', 'error');
                    }
                });
            }

            function updateTable(data) {
                const tbody = $('#example tbody');
                tbody.empty();

                data.forEach(function (item) {
                    // Determine status class
                    let statusClass = item.isActive ? 'status-active' : 'status-inactive';
                    let statusText = item.isActive ? 'Active' : 'Inactive';
                    
                    const row = `
                    <tr data-id="${item.id}">
                        <td><span class="fw-medium">${item.id}</span></td>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="avatar-sm bg-light rounded-circle text-center me-2" style="width: 32px; height: 32px; line-height: 32px;">
                                    <i class="bx bx-cog text-primary"></i>
                                </div>
                                <div>
                                    <span class="fw-medium">${item.name || ''}</span>
                                </div>
                            </div>
                        </td>
                        <td>${item.description || '-'}</td>
                        <td><span class="status-badge ${statusClass}">${statusText}</span></td>
                        <td>
                            <div class="d-flex justify-content-end">
                                <a href="/ApplicationConfigurations/Details/${item.id}" class="action-btn text-primary" title="View Details">
                                    <i class="bx bx-show"></i>
                                </a>
                                <a href="/ApplicationConfigurations/Edit/${item.id}" class="action-btn text-warning" title="Edit">
                                    <i class="bx bx-edit"></i>
                                </a>
                                <a href="/ApplicationConfigurations/Delete/${item.id}" class="action-btn text-danger" title="Delete">
                                    <i class="bx bx-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>`;
                    tbody.append(row);
                });
            }

            function updatePagination(totalRecords) {
                const totalPages = Math.ceil(totalRecords / pageSize);
                const start = ((currentPage - 1) * pageSize) + 1;
                const end = Math.min(currentPage * pageSize, totalRecords);

                $('#pagination-info').text(`Showing ${start} to ${end} of ${totalRecords} entries`);

                let paginationHtml = '<ul class="pagination pagination-sm mb-0 justify-content-end">';

                // Previous button
                paginationHtml += `
                    <li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
                        <a class="page-link" href="#" data-page="${currentPage - 1}" aria-label="Previous">
                            <span aria-hidden="true">&laquo;</span>
                        </a>
                    </li>`;

                // Determine page range to show
                let startPage = Math.max(1, currentPage - 2);
                let endPage = Math.min(totalPages, startPage + 4);
                
                if (endPage - startPage < 4) {
                    startPage = Math.max(1, endPage - 4);
                }

                // First page if not in range
                if (startPage > 1) {
                    paginationHtml += `
                        <li class="page-item">
                            <a class="page-link" href="#" data-page="1">1</a>
                        </li>`;
                    
                    if (startPage > 2) {
                        paginationHtml += `
                            <li class="page-item disabled">
                                <a class="page-link" href="#">...</a>
                            </li>`;
                    }
                }
                
                // Page numbers
                for (let i = startPage; i <= endPage; i++) {
                    paginationHtml += `
                        <li class="page-item ${currentPage === i ? 'active' : ''}">
                            <a class="page-link" href="#" data-page="${i}">${i}</a>
                        </li>`;
                }
                
                // Last page if not in range
                if (endPage < totalPages) {
                    if (endPage < totalPages - 1) {
                        paginationHtml += `
                            <li class="page-item disabled">
                                <a class="page-link" href="#">...</a>
                            </li>`;
                    }
                    
                    paginationHtml += `
                        <li class="page-item">
                            <a class="page-link" href="#" data-page="${totalPages}">${totalPages}</a>
                        </li>`;
                }

                // Next button
                paginationHtml += `
                    <li class="page-item ${currentPage === totalPages ? 'disabled' : ''}">
                        <a class="page-link" href="#" data-page="${currentPage + 1}" aria-label="Next">
                            <span aria-hidden="true">&raquo;</span>
                        </a>
                    </li>`;

                paginationHtml += '</ul>';
                $('#pagination-controls').html(paginationHtml);
            }

            // Toast notification
            function showToast(message, type = 'info') {
                console.log(`Toast (${type}): ${message}`);
                
                // Simple bootstrap toast implementation
                const toastHtml = `
                <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 11">
                    <div class="toast align-items-center text-white bg-${type === 'error' ? 'danger' : type === 'success' ? 'success' : 'primary'}" role="alert" aria-live="assertive" aria-atomic="true">
                        <div class="d-flex">
                            <div class="toast-body">
                                ${message}
                            </div>
                            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                        </div>
                    </div>
                </div>`;
                
                const toastElement = $(toastHtml);
                $('body').append(toastElement);
                
                const toast = new bootstrap.Toast(toastElement.find('.toast')[0], {
                    delay: 5000
                });
                toast.show();
                
                // Remove toast element after it's hidden
                toastElement.find('.toast').on('hidden.bs.toast', function () {
                    toastElement.remove();
                });
            }

            // Event handlers
            $('#searchBtn').click(function () {
                if (isLoading) return;
                currentPage = 1;
                loadData();
            });

            $('#resetFilter').click(function () {
                if (isLoading) return;
                $('#configIdFilter, #configNameFilter').val('');
                $('#statusFilter').val('true'); // Reset to Active by default
                currentPage = 1;
                loadData();
            });

            // Handle Enter key in filter inputs
            $('#configIdFilter, #configNameFilter').keypress(function(e) {
                if (e.which === 13) {
                    e.preventDefault();
                    $('#searchBtn').click();
                }
            });

            $(document).on('click', '.page-link', function (e) {
                e.preventDefault();
                if (isLoading) return;
                
                const newPage = $(this).data('page');
                if (newPage >= 1) {
                    currentPage = newPage;
                    loadData();
                    // Scroll back to top of table on page change
                    $('html, body').animate({
                        scrollTop: $("#example").offset().top - 100
                    }, 200);
                }
            });

            $('#example th[data-sort]').click(function () {
                if (isLoading) return;
                
                const newSortColumn = $(this).data('sort');
                
                // Update visual indicators
                $('#example th i').removeClass('text-primary').addClass('text-muted');
                $(this).find('i').removeClass('text-muted').addClass('text-primary');
                
                if (sortColumn === newSortColumn) {
                    sortDirection = sortDirection === 'asc' ? 'desc' : 'asc';
                    // Update icon
                    if (sortDirection === 'asc') {
                        $(this).find('i').removeClass('bx-sort-down').addClass('bx-sort-up');
                    } else {
                        $(this).find('i').removeClass('bx-sort-up').addClass('bx-sort-down');
                    }
                } else {
                    sortColumn = newSortColumn;
                    sortDirection = 'asc';
                    // Reset and set new icon
                    $('#example th i').removeClass('bx-sort-up bx-sort-down').addClass('bx-sort-alt-2');
                    $(this).find('i').removeClass('bx-sort-alt-2').addClass('bx-sort-up');
                }
                
                currentPage = 1;
                loadData();
            });

            // Initial load
            loadData();
        });
    </script>
}