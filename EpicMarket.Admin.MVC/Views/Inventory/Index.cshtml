@model IEnumerable<EpicMarket.Data.Models.Inventory>

@{
    ViewData["Title"] = "Index";
}

<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Oultet Products</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a asp-action="Index"><i class="bx bx-home-alt"></i></a>
                </li>
            </ol>
        </nav>
    </div>
</div>

<p class="d-flex justify-content-end">
    <a asp-action="Create" class="btn btn-primary px-5"><i class='bx bx-plus mr-1'></i>Create New</a>
</p>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table id="example" class="table table-striped table-bordered" style="width:100%">
                <thead>
                    <tr>
                        <th>
                            @Html.DisplayNameFor(model => model.Outlet.Name)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.Outlet.Bussiness.Name)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.ProductVariants.Catalog.Name)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.Outlet)
                        </th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @Html.DisplayFor(modelItem => item.Outlet.Name)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Outlet.Bussiness.Name)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.ProductVariants.Catalog.Name)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.ProductVariants.Catalog.Category)
                            </td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.ID">Edit</a> |
                                <a asp-action="Details" asp-route-id="@item.ID">Details</a> |
                                <a asp-action="Delete" asp-route-id="@item.ID">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        $(document).ready(function () {
            $('#example').DataTable();
        });
    </script>
}