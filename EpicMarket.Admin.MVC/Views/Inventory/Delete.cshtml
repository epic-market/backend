@model EpicMarket.Data.Models.Inventory

@{
    ViewData["Title"] = "Delete Outlet Product";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Outlet Products</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a asp-action="Index"><i class="bx bx-home-alt"></i></a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Delete Outlet Product</li>
            </ol>
        </nav>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div class="d-flex align-items-center mb-3">
            <i class="bx bx-error-circle text-danger me-2 font-24"></i>
            <h3 class="card-title mb-0">Confirm Outlet Product Deletion</h3>
        </div>
        <p class="card-text alert alert-danger">Are you sure you want to delete this outlet product? This action cannot be undone.</p>

        <div class="table-responsive">
            <table class="table table-bordered">
                <tr>
                    <th class="bg-light" style="width: 30%;">@Html.DisplayNameFor(model => model.Outlet)</th>
                    <td>@Html.DisplayFor(model => model.Outlet.Name)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.CatalogVariants.Catalog)</th>
                    <td>@Html.DisplayFor(model => model.CatalogVariants.Catalog.Name)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.QuantityAvailable)</th>
                    <td>@Html.DisplayFor(model => model.QuantityAvailable)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.MinimumStockLevel)</th>
                    <td>@Html.DisplayFor(model => model.MinimumStockLevel)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.MaximumStockLevel)</th>
                    <td>@Html.DisplayFor(model => model.MaximumStockLevel)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.ReorderPoint)</th>
                    <td>@Html.DisplayFor(model => model.ReorderPoint)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.BackOrders)</th>
                    <td>
                        @if (Model.BackOrders)
                        {
                            <span class="badge bg-success">Yes</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">No</span>
                        }
                    </td>
                </tr>
            </table>
        </div>

        <form asp-action="Delete" class="mt-4">
            <input type="hidden" asp-for="ID" />
            <div class="d-flex justify-content-between">
                <a href="javascript:history.go(-1)" class="btn btn-secondary">
                    <i class="bx bx-arrow-back me-1"></i> Back
                </a>
                <button type="submit" class="btn btn-danger">
                    <i class="bx bx-trash me-1"></i> Delete
                </button>
            </div>
        </form>
    </div>
</div>