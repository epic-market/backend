@model EpicMarket.Data.Models.Inventory

@{
    ViewData["Title"] = "Outlet Product Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-breadcrumb d-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Outlet Products</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a asp-action="Index"><i class="bx bx-home-alt"></i></a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Details</li>
            </ol>
        </nav>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="card-title mb-0">Outlet Product Details</h5>
            <a asp-action="Edit" class="btn btn-primary" asp-route-id="@Model?.ID">
                <i class="bx bx-edit me-1"></i> Edit
            </a>
        </div>

        <div class="table-responsive">
            <table class="table table-bordered">
                <tr>
                    <th class="bg-light" style="width: 30%;">@Html.DisplayNameFor(model => model.Outlet)</th>
                    <td>@Html.DisplayFor(model => model.Outlet.Name)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.ProductVariants.Catalog)</th>
                    <td>@Html.DisplayFor(model => model.ProductVariants.Catalog.Name)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.QuantityAvailable)</th>
                    <td>@Html.DisplayFor(model => model.QuantityAvailable)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.MinimumStockLevel)</th>
                    <td>@Html.DisplayFor(model => model.MinimumStockLevel)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.MaximumStockLevel)</th>
                    <td>@Html.DisplayFor(model => model.MaximumStockLevel)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.ReorderPoint)</th>
                    <td>@Html.DisplayFor(model => model.ReorderPoint)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.BackOrders)</th>
                    <td>
                        @if (Model.BackOrders)
                        {
                            <span class="badge bg-success">Yes</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">No</span>
                        }
                    </td>
                </tr>
            </table>
        </div>
    </div>
    <div class="card-footer">
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bx bx-arrow-back me-1"></i> Back to List
        </a>
    </div>
</div>