@model EpicMarket.Data.Models.Inventory

@{
    ViewData["Title"] = "Create";
}



<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Oultet Products</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a asp-action="Index"><i class="bx bx-home-alt"></i></a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Create</li>
            </ol>
        </nav>
    </div>
</div>
<hr />

<div class="row">
    <div class="col-xl-9 mx-auto">
        <div class="card border-top border-0 border-4 border-info">
            <div class="card-body">
                <div class="border p-4 rounded">
                    <div class="card-title d-flex align-items-center">
                        <div>
                            <i class="bx bxs-user me-1 font-22 text-info"></i>
                        </div>
                        <h5 class="mb-0 text-info">Create Oultet Product Map</h5>
                    </div>
                    <hr />
                    @using (Html.BeginForm("CreateOutletProduct", "OutletProducts", new { productID = ViewBag.productID, redirectUrl = ViewBag.redirectUrl }, FormMethod.Post))
                    {
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="row mb-3">
                            <label asp-for="OutletID" class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <select asp-for="OutletID" class="form-control" asp-items="ViewBag.Outlets"></select>
                                <span asp-validation-for="OutletID" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <input type="hidden" asp-for="CatalogVariants.Catalog.ID" />
                            <label asp-for="CatalogVariants.Catalog.ID" class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <select asp-for="CatalogVariants.Catalog.ID" class="form-control" asp-items="ViewBag.Products" disabled></select>
                                <span asp-validation-for="CatalogVariants.Catalog.ID" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <label asp-for="QuantityAvailable" class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <input asp-for="QuantityAvailable" class="form-control" />
                                <span asp-validation-for="QuantityAvailable" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <label asp-for="MinimumStockLevel" class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <input asp-for="MinimumStockLevel" class="form-control" />
                                <span asp-validation-for="MinimumStockLevel" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <label asp-for="MaximumStockLevel" class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <input asp-for="MaximumStockLevel" class="form-control" />
                                <span asp-validation-for="MaximumStockLevel" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <label asp-for="ReorderPoint" class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <input asp-for="ReorderPoint" class="form-control" />
                                <span asp-validation-for="ReorderPoint" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <label asp-for="BackOrders" class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <div class="form-check">
                                    <input asp-for="BackOrders" class="form-check-input" />
                                    <label class="form-check-label" asp-for="BackOrders"></label>
                                </div>
                                <span asp-validation-for="BackOrders" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <label class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <a href="javascript:history.go(-1)" class="btn btn-secondary">
                                    <i class="bx bx-arrow-back me-1"></i> Back
                                </a>
                                <button type="submit" class="btn btn-info px-5">Save</button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
