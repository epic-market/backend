			</div> *@
		</div>
	</div>
	<div class="card-footer">
		<a href="javascript:history.go(-1)" class="btn btn-secondary">
			<i class="bx bx-arrow-back me-1"></i> Back
		</a>
	</div>
</div>
@section Scripts {
	<script>
		$(document).ready(function () {
			$('#example').DataTable();
			$('#example1').DataTable();
			$('#example2').DataTable();
		});
	</script>
}