@using EpicMarket.Data.Models
@model EpicMarket.Admin.MVC.Models.BusinessDetailModel

@{
    ViewData["Title"] = $"{Model.Business.Name} - Business Details";
}

<style>
    .badge {
        padding: 0.5rem 0.75rem;
        font-weight: 500;
        border-radius: 30px;
    }
    .list-group-item {
        border-width: 0;
        padding: 0.8rem 0;
        border-bottom: 1px solid rgba(0,0,0,.1);
    }
    .card {
        box-shadow: 0 2px 15px rgba(0,0,0,.04);
        border: 1px solid rgba(0,0,0,.05);
        border-radius: 0.75rem;
        overflow: hidden;
    }
    .card-header {
        background-color: rgba(0,0,0,.02);
        border-bottom: 1px solid rgba(0,0,0,.05);
    }
    .fw-medium {
        font-weight: 500;
    }
    .business-image {
        height: 300px;
        object-fit: cover;
        border-radius: 0.5rem;
        transition: transform 0.3s ease;
    }
    .business-image:hover {
        transform: scale(1.02);
    }
    .gallery-item {
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
        border-radius: 0.5rem;
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    }
    .gallery-item:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 16px rgba(0,0,0,0.15);
    }
    .gallery-img {
        height: 180px;
        object-fit: cover;
        width: 100%;
    }
    .info-section {
        padding: 1.5rem;
        margin-bottom: 1.5rem;
    }
    .info-title {
        font-size: 1rem;
        color: #666;
        margin-bottom: 1rem;
        font-weight: 600;
        display: flex;
        align-items: center;
    }
    .info-title i {
        margin-right: 0.5rem;
        font-size: 1.1rem;
    }
    .key-value-item {
        display: flex;
        justify-content: space-between;
        padding: 0.5rem 0;
        border-bottom: 1px solid rgba(0,0,0,.05);
    }
    .key-value-item:last-child {
        border-bottom: none;
    }
    .business-header {
        position: relative;
        background: linear-gradient(135deg, #f5f7fa 0%, #e9ecef 100%);
        border-radius: 0.75rem;
        padding: 2rem;
        margin-bottom: 1.5rem;
    }
    .status-badge {
        transition: all 0.3s ease;
    }
    .status-badge:hover {
        transform: translateY(-2px);
    }
    .detail-section {
        background-color: #fff;
        border-radius: 0.75rem;
        box-shadow: 0 2px 10px rgba(0,0,0,.03);
        overflow: hidden;
    }
    .tab-content {
        background-color: #fff;
        border-radius: 0 0 0.75rem 0.75rem;
    }
    .nav-tabs .nav-link.active {
        border-color: transparent;
        border-bottom: 3px solid #0d6efd;
        background-color: transparent;
        color: #0d6efd;
    }
    .nav-tabs .nav-link {
        border: none;
        color: #6c757d;
        font-weight: 500;
        padding: 0.75rem 1rem;
    }
    .attachment-card {
        transition: all 0.3s ease;
    }
    .attachment-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 5px 15px rgba(0,0,0,0.08);
    }
    @@media (max-width: 768px) {
        .business-image {
            height: 200px;
        }
        .gallery-img {
            height: 120px;
        }
    }
</style>

<div class="container-fluid px-4 py-3">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Businesses")">Businesses</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Business.Name</li>
        </ol>
    </nav>

    <!-- Business Header -->
    <div class="business-header mb-4">
        <div class="d-flex flex-wrap justify-content-between align-items-center mb-3">
            <h3 class="mb-0 text-dark d-flex align-items-center">
                @if (!string.IsNullOrEmpty(ViewBag.AttachmentLogo))
                {
                    <a href="@Url.Action("DisplayImage", "File", new { key = ViewBag.AttachmentLogo })" target="_blank" class="me-2">
                        <img src="@Url.Action("DisplayImage", "File", new { key = ViewBag.AttachmentLogo })"
                             alt="Business Logo"
                             class="rounded-circle p-1"
                             style="width: 40px; height: 40px; object-fit: cover; border: 1px solid #ddd;" />
                    </a>
                }
                else
                {
                    <div class="me-2">
                        <div class="rounded-circle d-flex justify-content-center align-items-center bg-light"
                             style="width: 40px; height: 40px; border: 1px solid #ddd;">
                            <i class="bx bx-building-house text-muted" style="font-size: 20px;"></i>
                        </div>
                    </div>
                }
                @Html.DisplayFor(model => model.Business.Name)
            </h3>
            <div>
                <a asp-action="UploadProducts" class="btn btn-success me-2" asp-route-id="@Model?.Business.ID">
                    <i class="bx bx-upload me-1"></i> Upload Products
                </a>
                <a asp-action="Edit" class="btn btn-primary" asp-route-id="@Model?.Business.ID">
                    <i class="bx bx-edit me-1"></i> Edit
                </a>
            </div>
        </div>

        <!-- Status Pills -->
        <div class="d-flex flex-wrap gap-2 mt-3">
            @{
                var isVerified = Model.Business.Status.Status.Equals("Verified", StringComparison.OrdinalIgnoreCase);
                var statusColor = isVerified ? "success" : "danger";
                var iconClass = isVerified ? "bx-check-circle" : "bx-x-circle";
                
                var isOpenIcon = Model.Business.IsOpen ? "bx-door-open" : "bx-door-closed";
                var isOpenColor = Model.Business.IsOpen ? "success" : "danger";
                var isOpenText = Model.Business.IsOpen ? "Open" : "Closed";
            }
            
            <span class="status-badge badge bg-@statusColor text-white">
                <i class="bx @iconClass me-1"></i>
                @Html.DisplayFor(model => model.Business.Status.Status)
            </span>
            <span class="status-badge badge bg-@isOpenColor text-white">
                <i class="bx @isOpenIcon me-1"></i>
                @isOpenText
            </span>
            <span class="status-badge badge bg-warning text-dark">
                <i class="bx bx-star me-1"></i>
                Rating: @Html.DisplayFor(model => model.Business.Rating)
            </span>
            <span class="status-badge badge bg-info text-white">
                <i class="bx bx-comment-dots me-1"></i>
                Reviews: @Html.DisplayFor(model => model.Business.ReviewCount)
            </span>
            <span class="status-badge badge bg-primary text-white">
                <i class="bx bx-weight me-1"></i>
                Weight: @Html.DisplayFor(model => model.Business.Weight)
            </span>
        </div>
    </div>

    <div class="row g-4">
        <!-- Business Image & Attachments -->
        <div class="col-lg-4">
            <div class="card mb-4">
                <div class="card-body p-3">
                    <div class="text-center mb-4">
                        @if (!string.IsNullOrEmpty(ViewBag.AttachmentLogo))
                        {
                            <a href="@Url.Action("DisplayImage", "File", new { key = ViewBag.AttachmentLogo })" target="_blank" 
                               class="d-block" data-lightbox="business-image">
                                <img src="@Url.Action("DisplayImage", "File", new { key = ViewBag.AttachmentLogo })" 
                                     alt="@Model.Business.Name"
                                     class="business-image img-fluid shadow-sm mb-3" 
                                     style="width: 100%;">
                            </a>
                        }
                        else
                        {
                            <div class="text-center p-5 bg-light rounded shadow-sm mb-3">
                                <i class="bx bx-building-house text-muted" style="font-size: 80px;"></i>
                                <p class="text-muted mb-0 mt-3">No logo available</p>
                            </div>
                        }
                    </div>

                    <!-- Business Description -->
                    <div class="mb-4">
                        <h5 class="info-title border-bottom pb-2 mb-3">
                            <i class="bx bx-info-circle"></i> Business Description
                        </h5>
                        <p class="mb-0">@Html.DisplayFor(model => model.Business.Description)</p>
                    </div>

                    <!-- Attachments Section -->
                    @{
                        var attachmentProof = ViewBag.AttachmentProof as List<AttachmentProof>; 
                    }
                    <div class="mt-4">
                        <h5 class="info-title border-bottom pb-2 mb-3">
                            <i class="bx bx-paperclip"></i> Attachments
                        </h5>

                        @if (attachmentProof != null && attachmentProof.Count > 0)
                        {
                            <div class="row row-cols-1 g-3">
                                @foreach(var attachment in attachmentProof)
                                {
                                    <div class="col">
                                        <div class="card attachment-card border">
                                            <div class="card-body p-3 d-flex align-items-center">
                                                <i class="bx bx-file me-3 text-primary" style="font-size: 24px;"></i>
                                                <div>
                                                    <h6 class="mb-1">@attachment.Name</h6>
                                                    <a href="@Url.Action("DisplayImage", "File", new { key = attachment.ImagePath })"
                                                       target="_blank"
                                                       class="btn btn-sm btn-outline-primary">
                                                        <i class="bx bx-show me-1"></i> View
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info" role="alert">
                                <i class="bx bx-info-circle me-1"></i>
                                No Attachments found.
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Business Details -->
        <div class="col-lg-8">
            <div class="card mb-4">
                <div class="card-body p-0">
                    <div class="row g-0">
                        <!-- Basic Info -->
                        <div class="col-md-6 info-section border-end">
                            <h5 class="info-title">
                                <i class="bx bx-building"></i> Business Information
                            </h5>
                            <div class="key-value-item">
                                <span class="text-muted">ID</span>
                                <span class="fw-medium">@Model.Business.ID</span>
                            </div>
                            <div class="key-value-item">
                                <span class="text-muted">Business Category</span>
                                <span class="fw-medium">@Html.DisplayFor(model => model.Business.BusinessCategory.Name)</span>
                            </div>
                            <div class="key-value-item">
                                <span class="text-muted">Contact Number</span>
                                <span class="fw-medium">@Html.DisplayFor(model => model.Business.ContactNumber)</span>
                            </div>
                            <div class="key-value-item">
                                <span class="text-muted">Contact Email</span>
                                <span class="fw-medium">@Html.DisplayFor(model => model.Business.ContactEmail)</span>
                            </div>
                            <div class="key-value-item">
                                <span class="text-muted">Owner</span>
                                <span class="fw-medium">@Html.DisplayFor(model => model.Business.Person.UserName)</span>
                            </div>
                            <div class="key-value-item">
                                <span class="text-muted">Banner</span>
                                <span class="fw-medium">@Html.DisplayFor(model => model.Business.Banner)</span>
                            </div>
                            <div class="key-value-item">
                                <span class="text-muted">Logo</span>
                                <span class="fw-medium">@Html.DisplayFor(model => model.Business.Logo)</span>
                            </div>
                        </div>

                        <!-- Additional Info -->
                        <div class="col-md-6 info-section">
                            <h5 class="info-title">
                                <i class="bx bx-map-pin"></i> Location & Timestamps
                            </h5>
                            <div class="key-value-item">
                                <span class="text-muted">Address</span>
                                <span class="fw-medium">
                                    @Html.DisplayFor(model => model.Business.Address.Address1),
                                    @Html.DisplayFor(model => model.Business.Address.City),
                                    @Html.DisplayFor(model => model.Business.Address.State),
                                    @Html.DisplayFor(model => model.Business.Address.Pincode)
                                </span>
                            </div>
                            <div class="key-value-item">
                                <span class="text-muted">Created Date</span>
                                <span class="fw-medium">@Model.Business.CreateDate.ToString("dd MMM yyyy HH:mm")</span>
                            </div>
                            <div class="key-value-item">
                                <span class="text-muted">Created By</span>
                                <span class="fw-medium">@Html.DisplayFor(model => model.Business.CreateBy)</span>
                            </div>
                            <div class="key-value-item">
                                <span class="text-muted">Modified Date</span>
                                <span class="fw-medium">@Model.Business.ModifiedDate?.ToString("dd MMM yyyy HH:mm") ?? "N/A"</span>
                            </div>
                            <div class="key-value-item">
                                <span class="text-muted">Modified By</span>
                                <span class="fw-medium">@Html.DisplayFor(model => model.Business.ModifiedBy)</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tabs Section -->
            <div class="card">
                <div class="card-body p-0">
                    <ul class="nav nav-tabs nav-primary" role="tablist">
                        <li class="nav-item" role="presentation">
                            <a class="nav-link active" data-bs-toggle="tab" href="#primaryoutlets" role="tab" aria-selected="true">
                                <div class="d-flex align-items-center">
                                    <div class="tab-icon">
                                        <i class='bx bx-store font-18 me-1'></i>
                                    </div>
                                    <div class="tab-title"> Outlets </div>
                                </div>
                            </a>
                        </li>
                        <li class="nav-item" role="presentation">
                            <a class="nav-link" data-bs-toggle="tab" href="#primaryproducts" role="tab" aria-selected="false">
                                <div class="d-flex align-items-center">
                                    <div class="tab-icon">
                                        <i class='bx bx-package font-18 me-1'></i>
                                    </div>
                                    <div class="tab-title"> Products </div>
                                </div>
                            </a>
                        </li>
                        <li class="nav-item" role="presentation">
                            <a class="nav-link" data-bs-toggle="tab" href="#primaryemployee" role="tab" aria-selected="false">
                                <div class="d-flex align-items-center">
                                    <div class="tab-icon">
                                        <i class='bx bx-user font-18 me-1'></i>
                                    </div>
                                    <div class="tab-title"> Employees </div>
                                </div>
                            </a>
                        </li>
                    </ul>
                    <div class="tab-content pt-3">
                        <div class="tab-pane fade show active" id="primaryoutlets" role="tabpanel">
                            <div class="p-3">
                                <div class="table-responsive">
                                    <table id="outletsTable" class="table table-striped table-bordered" style="width:100%">
                                        <thead class="table-light">
                                            <tr>
                                                <th>ID</th>
                                                <th>Name</th>
                                                <th>Description</th>
                                                <th>Contact Number</th>
                                                <th>Contact Email</th>
                                                <th>City</th>
                                                <th>Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in Model.Outlets)
                                            {
                                                <tr>
                                                    <td>@Html.DisplayFor(modelItem => item.ID)</td>
                                                    <td>
                                                        <span class="fw-medium text-primary">@Html.DisplayFor(modelItem => item.Name)</span>
                                                    </td>
                                                    <td>@Html.DisplayFor(modelItem => item.Description)</td>
                                                    <td>@Html.DisplayFor(modelItem => item.ContactNumber)</td>
                                                    <td>@Html.DisplayFor(modelItem => item.ContactEmail)</td>
                                                    <td>@Html.DisplayFor(modelItem => item.Address.City)</td>
                                                    <td>
                                                        <div class="d-flex gap-2">
                                                            <a asp-controller="Outlets" asp-action="Edit" asp-route-id="@item.ID" 
                                                               class="btn btn-sm btn-outline-primary">
                                                                <i class="bx bx-edit"></i>
                                                            </a>
                                                            <a asp-controller="Outlets" asp-action="Details" asp-route-id="@item.ID" 
                                                               class="btn btn-sm btn-outline-info">
                                                                <i class="bx bx-detail"></i>
                                                            </a>
                                                            <a asp-controller="Outlets" asp-action="Delete" asp-route-id="@item.ID" 
                                                               class="btn btn-sm btn-outline-danger">
                                                                <i class="bx bx-trash"></i>
                                                            </a>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                        <div class="tab-pane fade" id="primaryproducts" role="tabpanel">
                            <div class="p-3">
                                <div class="table-responsive">
                                    <table id="productsTable" class="table table-striped table-bordered" style="width:100%">
                                        <thead class="table-light">
                                            <tr>
                                                <th>ID</th>
                                                <th>Name</th>
                                                <th>Category</th>
                                                <th>Status</th>
                                                <th>Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in Model.Products)
                                            {
                                                <tr>
                                                    <td>@Html.DisplayFor(modelItem => item.ID)</td>
                                                    <td>
                                                        <span class="fw-medium text-primary">@Html.DisplayFor(modelItem => item.Name)</span>
                                                    </td>
                                                    <td>@Html.DisplayFor(modelItem => item.Category)</td>
                                                    <td>
                                                        <span class="badge bg-@(item.IsActive ? "success" : "secondary")">
                                                            @(item.IsActive ? "Active" : "Inactive")
                                                        </span>
                                                    </td>
                                                    <td>
                                                        <div class="d-flex gap-2">
                                                            <a asp-controller="Products" asp-action="Edit" asp-route-id="@item.ID" 
                                                               class="btn btn-sm btn-outline-primary">
                                                                <i class="bx bx-edit"></i>
                                                            </a>
                                                            <a asp-controller="Products" asp-action="Details" asp-route-id="@item.ID" 
                                                               class="btn btn-sm btn-outline-info">
                                                                <i class="bx bx-detail"></i>
                                                            </a>
                                                            <a asp-controller="Products" asp-action="Delete" asp-route-id="@item.ID" 
                                                               class="btn btn-sm btn-outline-danger">
                                                                <i class="bx bx-trash"></i>
                                                            </a>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                        <div class="tab-pane fade" id="primaryemployee" role="tabpanel">
                            <div class="p-3">
                                <div class="table-responsive">
                                    <table id="employeesTable" class="table table-striped table-bordered" style="width:100%">
                                        <thead class="table-light">
                                            <tr>
                                                <th>ID</th>
                                                <th>Name</th>
                                                <th>Username</th>
                                                <th>Phone Number</th>
                                                <th>Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in Model.employees)
                                            {
                                                <tr>
                                                    <td>@Html.DisplayFor(modelItem => item.Employee.Id)</td>
                                                    <td>
                                                        <span class="fw-medium text-primary">@Html.DisplayFor(modelItem => item.Employee.FirstName)</span>
                                                    </td>
                                                    <td>@Html.DisplayFor(modelItem => item.Employee.UserName)</td>
                                                    <td>@Html.DisplayFor(modelItem => item.Employee.PhoneNumber)</td>
                                                    <td>
                                                        <div class="d-flex gap-2">
                                                            <a asp-controller="BusinessEmployeeMaps" asp-action="Edit" asp-route-id="@item.ID" 
                                                               class="btn btn-sm btn-outline-primary">
                                                                <i class="bx bx-edit"></i>
                                                            </a>
                                                            <a asp-controller="BusinessEmployeeMaps" asp-action="Details" asp-route-id="@item.ID" 
                                                               class="btn btn-sm btn-outline-info">
                                                                <i class="bx bx-detail"></i>
                                                            </a>
                                                            <a asp-controller="BusinessEmployeeMaps" asp-action="Delete" asp-route-id="@item.ID" 
                                                               class="btn btn-sm btn-outline-danger">
                                                                <i class="bx bx-trash"></i>
                                                            </a>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer">
                    <a href="javascript:history.go(-1)" class="btn btn-secondary">
                        <i class="bx bx-arrow-back me-1"></i> Back
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Initialize DataTables with consistent styling
            $('#outletsTable, #productsTable, #employeesTable').DataTable({
                pageLength: 10,
                responsive: true,
                dom: '<"row mb-3"<"col-md-6"l><"col-md-6"f>><"row"<"col-md-12"t>><"row"<"col-md-6"i><"col-md-6"p>>',
                language: {
                    search: "",
                    searchPlaceholder: "Search..."
                }
            });
            
            // Animation for status badges
            $('.status-badge').each(function(index) {
                const badge = $(this);
                setTimeout(function() {
                    badge.addClass('animate__animated animate__fadeIn');
                }, index * 100);
            });
            
            // Auto-hide alerts after 5 seconds
            setTimeout(function() {
                $('.alert').fadeOut('slow');
            }, 5000);
            
            // Tooltips initialization
            const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl, {
                    delay: { show: 300, hide: 100 }
                });
            });
        });
    </script>
    
    <!-- Optional: Include the lightbox library if not already included -->
    @if (!Context.Items.ContainsKey("LightboxIncluded"))
    {
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/lightbox2/2.11.3/css/lightbox.min.css" integrity="sha512-ZKX+BvQihRJPA8CROKBhDNvoc2aDMOdAlcm7TUQY+35XYtrd3yh95QOOhsPDQY9QnKE0Wqag9y38OIgEvb88cA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
        <script src="https://cdnjs.cloudflare.com/ajax/libs/lightbox2/2.11.3/js/lightbox.min.js" integrity="sha512-k2GFCTbp9rQU412BStrcD/rlwv1PYec9SNrkbQlo6RZCf75l6KcC3UwDY8H5n5hl4v77IDtIPwOk9Dqjs/mMBQ==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
        
        Context.Items["LightboxIncluded"] = true;
    }
    
    <!-- Include animate.css for animations -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
}