@model EpicMarket.Admin.MVC.Models.BusinessDetailModel

@{
    ViewData["Title"] = "Details";
}
<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
	<div class="breadcrumb-title pe-3">Bussiness</div>
	<div class="ps-3">
		<nav aria-label="breadcrumb">
			<ol class="breadcrumb mb-0 p-0">
				<li class="breadcrumb-item">
					<a asp-action="Index"><i class="bx bx-home-alt"></i></a>
				</li>
				<li class="breadcrumb-item active" aria-current="page">Details</li>
			</ol>
		</nav>
	</div>
</div>
<hr />


<div class="card">
	<div class="row g-0">
		<div class="col-md-12">
			<div class="card-body">
				<div class="float-end">
					<a asp-action="UploadProducts" class="btn btn-success me-2" asp-route-id="@Model?.Business.ID">Upload Products</a>
					<a asp-action="Edit" class="btn btn-primary" asp-route-id="@Model?.Business.ID">Edit</a>
				</div>
				<h4 class="card-title d-flex align-items-center">
					@if (!string.IsNullOrEmpty(ViewBag.AttachmentLogo))
					{
						<a href="@Url.Action("DisplayImage", "File", new { key = ViewBag.AttachmentLogo })" target="_blank" class="me-2">
							<img src="@Url.Action("DisplayImage", "File", new { key = ViewBag.AttachmentLogo })"
								 alt="Business Logo"
								 class="rounded-circle p-1"
								 style="width: 40px; height: 40px; object-fit: cover; border: 1px solid #ddd;" />
						</a>
					}
					else
					{
						<div class="me-2">
							<div class="rounded-circle d-flex justify-content-center align-items-center bg-light"
								 style="width: 40px; height: 40px; border: 1px solid #ddd;">
								<i class="bx bx-building-house text-muted" style="font-size: 20px;"></i>
							</div>
						</div>
					}
					@Html.DisplayFor(model => model.Business.Name)
				</h4>
				<div class="d-flex flex-wrap gap-3 py-3">
					<div class="d-flex align-items-center">
						<i class="bx bx-star me-1 text-warning"></i>
						<strong class="me-1">@Html.DisplayNameFor(model => model.Business.Rating):</strong>
						<span>@Html.DisplayFor(model => model.Business.Rating)</span>
					</div>
					<div class="d-flex align-items-center">
						<i class="bx bx-comment-dots me-1 text-info"></i>
						<strong class="me-1">@Html.DisplayNameFor(model => model.Business.ReviewCount):</strong>
						<span>@Html.DisplayFor(model => model.Business.ReviewCount)</span>
					</div>
					<div class="d-flex align-items-center">
						@{
							var isOpenIcon =
							Model.Business.IsOpen ? "bx-door-open text-success" : "bx-door-closed text-danger";
							var isOpenText =
							Model.Business.IsOpen ? "Open" : "Closed";

						}
						<i class="bx @isOpenIcon me-1"></i>
						<strong class="me-1">@Html.DisplayNameFor(model => model.Business.IsOpen):</strong>
						<span>@isOpenText</span>
					</div>
					<div class="d-flex align-items-center">
						<i class="bx bx-weight me-1 text-primary"></i>
						<strong class="me-1">@Html.DisplayNameFor(model => model.Business.Weight):</strong>
						<span>@Html.DisplayFor(model => model.Business.Weight)</span>
					</div>
					<div class="d-flex align-items-center">
						@{
							var isVerified = Model.Business.Status.Status.Equals("Verified", StringComparison.OrdinalIgnoreCase);
							var statusColor = isVerified ? "success" : "danger";
							var iconClass = isVerified ? "bx-check-circle" : "bx-x-circle";
						}
						<i class="bx @iconClass me-1 text-@statusColor"></i>
						<strong class="me-1">Status:</strong>
						<span class="badge bg-@statusColor">@Html.DisplayFor(model => model.Business.Status.Status)</span>
					</div>
				</div>
				<p class="card-text fs-6"> @Html.DisplayFor(model => model.Business.Description) </p>
				<div class="row">
					<dl class="row col-6">
						<dt class="col-sm-4">
							@Html.DisplayNameFor(model => model.Business.Banner)
						</dt>
						<dd class="col-sm-8">
							@Html.DisplayFor(model => model.Business.Banner)
						</dd>
						<dt class="col-sm-4">
							@Html.DisplayNameFor(model => model.Business.Logo)
						</dt>
						<dd class="col-sm-8">
							@Html.DisplayFor(model => model.Business.Logo)
						</dd>
						<dt class="col-sm-4">
							@Html.DisplayNameFor(model => model.Business.ContactNumber)
						</dt>
						<dd class="col-sm-8">
							@Html.DisplayFor(model => model.Business.ContactNumber)
						</dd>
						<dt class="col-sm-4">
							@Html.DisplayNameFor(model => model.Business.ContactEmail)
						</dt>
						<dd class="col-sm-8">
							@Html.DisplayFor(model => model.Business.ContactEmail)
						</dd>
						<dt class="col-sm-4">
							@Html.DisplayNameFor(model => model.Business.Person)
						</dt>
						<dd class="col-sm-8">
							@Html.DisplayFor(model => model.Business.Person.UserName)
						</dd>
						<dt class="col-sm-4">
							@Html.DisplayNameFor(model => model.Business.BusinessCategory)
						</dt>
						<dd class="col-sm-8">
							@Html.DisplayFor(model => model.Business.BusinessCategory.Name)
						</dd>
					</dl>
					<dl class="row col-6">
					
						<dt class="col-sm-4">
							@Html.DisplayNameFor(model => model.Business.Address)
						</dt>
						<dd class="col-sm-8">
							@Html.DisplayFor(model => model.Business.Address.Address1),
							@Html.DisplayFor(model => model.Business.Address.City),
							@Html.DisplayFor(model => model.Business.Address.State),
							@Html.DisplayFor(model => model.Business.Address.Pincode)
						</dd>
						<dt class="col-sm-4">
							@Html.DisplayNameFor(model => model.Business.CreateDate)
						</dt>
						<dd class="col-sm-8">
							@Html.DisplayFor(model => model.Business.CreateDate)
						</dd>
						<dt class="col-sm-4">
							@Html.DisplayNameFor(model => model.Business.CreateBy)
						</dt>
						<dd class="col-sm-8">
							@Html.DisplayFor(model => model.Business.CreateBy)
						</dd>
						<dt class="col-sm-4">
							@Html.DisplayNameFor(model => model.Business.ModifiedDate)
						</dt>
						<dd class="col-sm-8">
							@Html.DisplayFor(model => model.Business.ModifiedDate)
						</dd>
						<dt class="col-sm-4">
							@Html.DisplayNameFor(model => model.Business.ModifiedBy)
						</dt>
						<dd class="col-sm-8">
							@Html.DisplayFor(model => model.Business.ModifiedBy)
						</dd>
					</dl>
				</div>
			</div>
		</div>
	</div>
	<hr />
	<div class="card mt-4">
		<div class="card-header">
			<h5 class="card-title mb-0">Attachments</h5>
		</div>
		<div class="card-body">
			@if (ViewBag.AttachmentProof != null && ViewBag.AttachmentProof.Count > 0)
			{
				<ul class="list-group list-group-flush">
					@foreach (var attachment in ViewBag.AttachmentProof)
					{
						<li class="list-group-item d-flex align-items-center">
							<i class="fas fa-paperclip me-2"></i>
							<a href="@Url.Action("DisplayImage", "File", new { key = attachment.ImagePath })"
							   target="_blank"
							   class="text-decoration-none">
								<span class="badge bg-secondary ms-2">@attachment.Name</span>
							</a>
						</li>
					}
				</ul>

			}
			else
			{
				<div class="alert alert-info" role="alert">
					<i class="bx bx-info-circle me-1"></i>
					No Attachments found.
				</div>
			}
		</div>
	</div>
	<div class="card-body">
		<ul class="nav nav-tabs nav-primary mb-0" role="tablist">
			<li class="nav-item" role="presentation">
				<a class="nav-link active" data-bs-toggle="tab" href="#primaryorders" role="tab" aria-selected="true">
					<div class="d-flex align-items-center">
						<div class="tab-icon">
							<i class='bx bx-comment-detail font-18 me-1'></i>
						</div>
						<div class="tab-title"> Outlets </div>
					</div>
				</a>
			</li>
			<li class="nav-item" role="presentation">
				<a class="nav-link" data-bs-toggle="tab" href="#primaryproducts" role="tab" aria-selected="false">
					<div class="d-flex align-items-center">
						<div class="tab-icon">
							<i class='bx bx-bookmark-alt font-18 me-1'></i>
						</div>
						<div class="tab-title"> Products </div>
					</div>
				</a>
			</li>
			<li class="nav-item" role="presentation">
				<a class="nav-link" data-bs-toggle="tab" href="#primaryemployee" role="tab" aria-selected="false">
					<div class="d-flex align-items-center">
						<div class="tab-icon">
							<i class='bx bx-star font-18 me-1'></i>
						</div>
						<div class="tab-title"> Employees </div>
					</div>
				</a>
			</li>
	@* 		<li class="nav-item" role="presentation">
				<a class="nav-link" data-bs-toggle="tab" href="#primaryactivity" role="tab" aria-selected="false">
					<div class="d-flex align-items-center">
						<div class="tab-icon">
							<i class='bx bx-star font-18 me-1'></i>
						</div>
						<div class="tab-title"> Activity </div>
					</div>
				</a>
			</li> *@
		</ul>
		<div class="tab-content pt-3">
			<div class="tab-pane fade show active" id="primaryorders" role="tabpanel">
				<div class="card">
					<div class="card-body">
						<div class="table-responsive">
							<table id="example" class="table table-striped table-bordered" style="width:100%">
								<thead>
									<tr>
										<th>
											@Html.DisplayNameFor(model => model.Outlet.ID)
										</th>
										<th>
											@Html.DisplayNameFor(model => model.Outlet.Name)
										</th>
										<th>
											@Html.DisplayNameFor(model => model.Outlet.Description)
										</th>
										<th>
											@Html.DisplayNameFor(model => model.Outlet.ContactNumber)
										</th>
										<th>
											@Html.DisplayNameFor(model => model.Outlet.ContactEmail)
										</th>
										<th>
											@Html.DisplayNameFor(model => model.Outlet.Address.City)
										</th>
										<th></th>
									</tr>
								</thead>
								<tbody>
									@foreach (var item in Model.Outlets)
									{
										<tr>
											<td>
												@Html.DisplayFor(modelItem => item.ID)
											</td>
											<td>
												@Html.DisplayFor(modelItem => item.Name)
											</td>
											<td>
												@Html.DisplayFor(modelItem => item.Description)
											</td>
											<td>
												@Html.DisplayFor(modelItem => item.ContactNumber)
											</td>
											<td>
												@Html.DisplayFor(modelItem => item.ContactEmail)
											</td>
											<td>
												@Html.DisplayFor(modelItem => item.Address.City)
											</td>
											<td>
												<a asp-controller="Outlets" asp-action="Edit" asp-route-id="@item.ID">Edit</a> |
												<a asp-controller="Outlets" asp-action="Details" asp-route-id="@item.ID">Details</a> |
												<a asp-controller="Outlets" asp-action="Delete" asp-route-id="@item.ID">Delete</a>
											</td>
										</tr>
									}
								</tbody>
							</table>
						</div>
					</div>
				</div>
			</div>
			<div class="tab-pane fade" id="primaryproducts" role="tabpanel">
				<div class="card">
					<div class="card-body">
						<div class="table-responsive">
							<table id="example1" class="table table-striped table-bordered" style="width:100%">
								<thead>
									<tr>
										<th>
											@Html.DisplayNameFor(model => model.Catalog.ID)
										</th>
										<th>
											@Html.DisplayNameFor(model => model.Catalog.Name)
										</th>
										<th>
											@Html.DisplayNameFor(model => model.Catalog.Category)
										</th>
										<th>
											@Html.DisplayNameFor(model => model.Catalog.IsActive)
										</th>
									@* 	<th>
											@Html.DisplayNameFor(model => model.Catalog.InStock)
										</th> *@
										<th></th>
									</tr>
								</thead>
								<tbody>
									@foreach (var item in Model.Catalogs)
									{
										<tr>
											<td>
												@Html.DisplayFor(modelItem => item.ID)
											</td>
											<td>
												@Html.DisplayFor(modelItem => item.Name)
											</td>
											<td>
												@Html.DisplayFor(modelItem => item.Category)
											</td>
											<td>
												@Html.DisplayFor(modelItem => item.IsActive)
											</td>
											@* <td>
												@Html.DisplayFor(modelItem => item.InStock)
											</td> *@
											<td>
												<a asp-controller="Catalogs" asp-action="Edit" asp-route-id="@item.ID">Edit</a> |
												<a asp-controller="Catalogs" asp-action="Details" asp-route-id="@item.ID">Details</a> |
												<a asp-controller="Catalogs" asp-action="Delete" asp-route-id="@item.ID">Delete</a>
											</td>
										</tr>
									}
								</tbody>
							</table>
						</div>
					</div>
				</div>
			</div>
			<div class="tab-pane fade" id="primaryemployee" role="tabpanel">
				<div class="card">
					<div class="card-body">
						<div class="table-responsive">
							<table id="example2" class="table table-striped table-bordered" style="width:100%">
								<thead>
									<tr>
										<th>
											@Html.DisplayNameFor(model => model.employee.Employee.Id)
										</th>
										<th>
											@Html.DisplayNameFor(model => model.employee.Employee.FirstName)
										</th>
										<th>
											@Html.DisplayNameFor(model => model.employee.Employee.UserName)
										</th>
										<th>
											@Html.DisplayNameFor(model => model.employee.Employee.PhoneNumber)
										</th>
										<th></th>
									</tr>
								</thead>
								<tbody>
									@foreach (var item in Model.employees)
									{
										<tr>
											<td>
												@Html.DisplayFor(modelItem => item.Employee.Id)
											</td>
											<td>
												@Html.DisplayFor(modelItem => item.Employee.FirstName)
											</td>
											<td>
												@Html.DisplayFor(modelItem => item.Employee.UserName)
											</td>
											<td>
												@Html.DisplayFor(modelItem => item.Employee.PhoneNumber)
											</td>
											
											<td>
												<a asp-controller="BusinessEmployeeMaps" asp-action="Edit" asp-route-id="@item.ID">Edit</a> |
												<a asp-controller="BusinessEmployeeMaps" asp-action="Details" asp-route-id="@item.ID">Details</a> |
												<a asp-controller="BusinessEmployeeMaps" asp-action="Delete" asp-route-id="@item.ID">Delete</a>
											</td>
										</tr>
									}
								</tbody>
							</table>
						</div>
					</div>
				</div>
			</div>
