@model IEnumerable<EpicMarket.Data.Models.Business>

@{
    ViewData["Title"] = "Index";
}

<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Business</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a asp-action="Index"><i class="bx bx-home-alt"></i></a>
                </li>
            </ol>
        </nav>
    </div>
</div>

<!-- Filter Card -->
<div class="card mb-4">
    <div class="card-body">
        <h5 class="card-title">Filter Business</h5>
        <div class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Business ID</label>
                <input type="text" class="form-control" id="businessIdFilter" placeholder="Enter Business ID">
            </div>
            <div class="col-md-3">
                <label class="form-label">Business Owner</label>
                <input type="text" class="form-control" id="ownerFilter" placeholder="Enter Owner Username">
            </div>
            <div class="col-md-3">
                <label class="form-label">Contact Number</label>
                <input type="text" class="form-control" id="contactFilter" placeholder="Enter Contact Number">
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button type="button" class="btn btn-primary me-2" id="searchBtn">Search</button>
                <button type="button" class="btn btn-secondary" id="resetFilter">Reset</button>
            </div>
        </div>
    </div>
</div>





<div class="card">
    <div class="card-body">
        <p class="d-flex justify-content-end">
            <a asp-action="Create" class="btn btn-primary px-5"><i class='bx bx-plus mr-1'></i>Create New</a>
        </p>
        <div class="table-responsive">
            <table id="example" class="table table-striped table-bordered" style="width:100%">
                <thead>
                    <tr>
                        <th>
                            @Html.DisplayNameFor(model => model.ID)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.Name)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.ContactNumber)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.ContactEmail)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.Status)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.Person)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.BusinessCategory)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.Address.City)
                        </th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @Html.DisplayFor(modelItem => item.ID)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Name)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.ContactNumber)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.ContactEmail)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Status.Status)
                            </td>
                            <td>
                                <a asp-controller="AppUsers" asp-action="Details" asp-route-id="@item.Person.Id"> @Html.DisplayFor(modelItem =>  item.Person.UserName)</a>

                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.BusinessCategory.Name)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Address.City)
                            </td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.ID">Edit</a> |
                                <a asp-action="Details" asp-route-id="@item.ID">Details</a> |
                                <a asp-action="Delete" asp-route-id="@item.ID">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        $(document).ready(function () {
            var table = $('#example').DataTable({
                "searching": false, // Disable the default search box
                "dom": 'lrtip'     // This will remove the search box from the DOM
            });
        });
    </script>
}