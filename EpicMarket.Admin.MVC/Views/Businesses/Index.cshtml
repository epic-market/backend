@model IEnumerable<EpicMarket.Data.Models.Business>
@{
    ViewData["Title"] = "Index";
}

<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Business</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a asp-action="Index"><i class="bx bx-home-alt"></i></a>
                </li>
            </ol>
        </nav>
    </div>
</div>

<!-- Filter Card -->
<div class="card mb-4">
    <div class="card-body">
        <h5 class="card-title">Filter Business</h5>
        <div class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Business ID</label>
                <input type="text" class="form-control" id="businessIdFilter" placeholder="Enter Business ID">
            </div>
            <div class="col-md-3">
                <label class="form-label">Business Owner</label>
                <input type="text" class="form-control" id="ownerFilter" placeholder="Enter Owner Username">
            </div>
            <div class="col-md-3">
                <label class="form-label">Contact Number</label>
                <input type="text" class="form-control" id="contactFilter" placeholder="Enter Contact Number">
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button type="button" class="btn btn-primary me-2" id="searchBtn">Search</button>
                <button type="button" class="btn btn-secondary" id="resetFilter">Reset</button>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <p class="d-flex justify-content-end">
            <a asp-action="Create" class="btn btn-primary px-5"><i class='bx bx-plus mr-1'></i>Create New</a>
        </p>
        <div class="table-responsive">
            <table id="example" class="table table-striped table-bordered" style="width:100%">
                <thead>
                    <tr>
                        <th data-sort="id">ID</th>
                        <th data-sort="name">Name</th>
                        <th data-sort="contactnumber">Contact Number</th>
                        <th data-sort="contactemail">Contact Email</th>
                        <th data-sort="status">Status</th>
                        <th data-sort="person">Person</th>
                        <th data-sort="businesscategory">Business Category</th>
                        <th data-sort="city">City</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                </tbody>
            </table>
            <div id="pagination-info" class="mt-3"></div>
            <div id="pagination-controls" class="mt-3"></div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            let currentPage = 1;
            let pageSize = 10;
            let sortColumn = 'id';
            let sortDirection = 'asc';

            function loadData() {
                $.ajax({
                    url: '/Business/GetFilteredData',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({
                        businessId: $('#businessIdFilter').val(),
                        ownerUsername: $('#ownerFilter').val(),
                        contactNumber: $('#contactFilter').val(),
                        pageNumber: currentPage,
                        pageSize: pageSize,
                        sortColumn: sortColumn,
                        sortDirection: sortDirection
                    }),
                    success: function (response) {
                        if (response.error) {
                            console.error(response.error);
                            return;
                        }
                        updateTable(response.data);
                        updatePagination(response.totalRecords);
                    },
                    error: function (xhr, status, error) {
                        console.error('Error:', error);
                    }
                });
            }

            function updateTable(data) {
                const tbody = $('#example tbody');
                tbody.empty();

                data.forEach(function (item) {
                    const row = `
                    <tr>
                        <td>${item.id}</td>
                        <td>${item.name || ''}</td>
                        <td>${item.contactNumber || ''}</td>
                        <td>${item.contactEmail || ''}</td>
                        <td>${item.statusName || ''}</td>
                        <td><a href="/AppUsers/Details/${item.personId || ''}">${item.personUserName || ''}</a></td>
                        <td>${item.businessCategoryName || ''}</td>
                        <td>${item.city || ''}</td>
                        <td>
                            <a href="/Businesses/Edit/${item.id}">Edit</a> |
                            <a href="/Businesses/Details/${item.id}">Details</a> |
                            <a href="/Businesses/Delete/${item.id}">Delete</a>
                        </td>
                    </tr>`;
                    tbody.append(row);
                });
            }

            function updatePagination(totalRecords) {
                const totalPages = Math.ceil(totalRecords / pageSize);
                const start = ((currentPage - 1) * pageSize) + 1;
                const end = Math.min(currentPage * pageSize, totalRecords);

                $('#pagination-info').text(`Showing ${start} to ${end} of ${totalRecords} entries`);

                let paginationHtml = '<ul class="pagination justify-content-end">';

                // Previous button
                paginationHtml += `
                            <li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
                                <a class="page-link" href="#" data-page="${currentPage - 1}">Previous</a>
                            </li>`;

                // Page numbers
                for (let i = 1; i <= totalPages; i++) {
                    paginationHtml += `
                                <li class="page-item ${currentPage === i ? 'active' : ''}">
                                    <a class="page-link" href="#" data-page="${i}">${i}</a>
                                </li>`;
                }

                // Next button
                paginationHtml += `
                            <li class="page-item ${currentPage === totalPages ? 'disabled' : ''}">
                                <a class="page-link" href="#" data-page="${currentPage + 1}">Next</a>
                            </li>`;

                paginationHtml += '</ul>';
                $('#pagination-controls').html(paginationHtml);
            }

            // Event handlers
            $('#searchBtn').click(function () {
                currentPage = 1;
                loadData();
            });

            $('#resetFilter').click(function () {
                $('#businessIdFilter, #ownerFilter, #contactFilter').val('');
                currentPage = 1;
                loadData();
            });

            $(document).on('click', '.page-link', function (e) {
                e.preventDefault();
                const newPage = $(this).data('page');
                if (newPage >= 1) {
                    currentPage = newPage;
                    loadData();
                }
            });

            $('#example th[data-sort]').click(function () {
                const newSortColumn = $(this).data('sort');
                if (sortColumn === newSortColumn) {
                    sortDirection = sortDirection === 'asc' ? 'desc' : 'asc';
                } else {
                    sortColumn = newSortColumn;
                    sortDirection = 'asc';
                }
                loadData();
            });

            // Initial load
            loadData();
        });
    </script>
}