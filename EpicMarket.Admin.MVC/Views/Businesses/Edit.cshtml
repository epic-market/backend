@model EpicMarket.Data.Models.Business

@{
    ViewData["Title"] = "Edit";
}

<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Bussiness</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a asp-action="Index"><i class="bx bx-home-alt"></i></a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Edit</li>
            </ol>
        </nav>
    </div>
</div>
<hr />

<div class="row">
    <div class="col-xl-9 mx-auto">
        <div class="card border-top border-0 border-4 border-info">
            <div class="card-body">
                <div class="border p-4 rounded">
                    <div class="card-title d-flex align-items-center">
                        <div>
                            <i class="bx bxs-user me-1 font-22 text-info"></i>
                        </div>
                        <h5 class="mb-0 text-info">Edit Business Details</h5>
                    </div>
                    <hr />
                    <form asp-action="Edit" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="ID" />
                        <input type="hidden" asp-for="AddressID" />
                        <input type="hidden" asp-for="Rating" />
                        <input type="hidden" asp-for="ReviewCount" />
                        <input type="hidden" asp-for="Weight" />
                        <input type="hidden" asp-for="CreateDate" />
                        <input type="hidden" asp-for="CreateBy" />
                        <input type="hidden" asp-for="ModifiedDate" />
                        <input type="hidden" asp-for="ModifiedBy" />
                        <input type="hidden" asp-for="IsActive" />
                        <div class="row mb-3">
                            <label asp-for="PersonID" class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <select class="single-select"  asp-for="PersonID" class="form-control" asp-items="ViewBag.PersonID"></select>
                                <span asp-validation-for="PersonID" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="row mb-3">
                                <label asp-for="BusinessCategoryID" class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <select class="single-select" asp-for="BusinessCategoryID" class="form-control" asp-items="ViewBag.BusinessCategoryID"></select>
                                <span asp-validation-for="BusinessCategoryID" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <label asp-for="Name" class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <input asp-for="Name" class="form-control" />
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>
                        </div>
                    <div class="row mb-3">
                            <label asp-for="Description" class="col-sm-3 col-form-label"></label>
                        <div class="col-sm-9">
                                <textarea asp-for="Description" class="form-control"></textarea>
                                <span asp-validation-for="Description" class="text-danger"></span>
                        </div>
                    </div>
                        <div class="row mb-3">
                            <label asp-for="ContactNumber" class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <input asp-for="ContactNumber" class="form-control" />
                                <span asp-validation-for="ContactNumber" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label asp-for="ContactEmail" class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <input asp-for="ContactEmail" class="form-control" />
                                <span asp-validation-for="ContactEmail" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label asp-for="Address.Address1" class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <input asp-for="Address.Address1" class="form-control" />
                                <span asp-validation-for="Address.Address1" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label asp-for="Address.State" class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <input asp-for="Address.State" class="form-control" />
                                <span asp-validation-for="Address.State" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label asp-for="Address.City" class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <input asp-for="Address.City" class="form-control" />
                                <span asp-validation-for="Address.City" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label asp-for="Address.Pincode" class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <input asp-for="Address.Pincode" class="form-control" />
                                <span asp-validation-for="Address.Pincode" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label asp-for="StatusId" class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <select asp-for="StatusId" class="form-control" asp-items="ViewBag.StatusID"></select>
                                <span asp-validation-for="StatusId" class="text-danger"></span>
                            </div>
                        </div>
                        <!-- Existing Images -->
                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label">Existing LOGO</label>
                            <div class="col-sm-9">
                                <div class="row" id="existingImagesContainer">
                                    @if (ViewBag.attachments != null)
                                    {
                                        foreach (var imageKey in ViewBag.attachments as List<string>)
                                        {
                                            <div class="col-md-3 mb-3 position-relative" data-image-key="@imageKey">
                                                <img src="@Url.Action("DisplayImage", "File", new { key = imageKey })" width="100%" height="150" class="img-fluid" />
                                            </div>
                                        }
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- Upload New Images -->
                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label">Upload New Logo</label>
                            <div class="col-sm-9">
                                <input type="file" class="form-control" id="newLogo" name="newLogo" />
                            </div>
                        </div>
                        <input type="hidden" id="addedLogos" name="addedLogos" />
                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label">Existing Proofs</label>
                            <div class="col-sm-9">
                                <ul class="list-group" id="existingProofsContainer">
                                    @if (ViewBag.Proofs != null)
                                    {
                                        foreach (var imageKey in ViewBag.Proofs as List<string>)
                                        {
                                            <li class="list-group-item d-flex justify-content-between align-items-center" data-image-key="@imageKey">
                                                <a href="@Url.Action("DisplayImage", "File", new { key = imageKey })" target="_blank" class="text-decoration-none">
                                                    <i class="bx bx-file me-2"></i>Proof @(((List<string>)ViewBag.Proofs).IndexOf(imageKey) + 1)
                                                </a>
                                                <button type="button" class="btn btn-link text-danger p-0" onclick="removedProof('@imageKey')">
                                                    <i class="bx bx-x"></i>
                                                </button>
                                            </li>
                                        }
                                    }
                                </ul>
                            </div>
                        </div>

                        <!-- Upload New Images -->
                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label">Upload New Proofs</label>
                            <div class="col-sm-9">
                                <input multiple type="file" class="form-control" id="newProofs" name="newProofs" />
                            </div>
                        </div>
                        <!-- Hidden Fields for Removed and Added Images -->
                        <input type="hidden" id="removedProofs" name="removedProofs" />
                        <input type="hidden" id="addedProofs" name="addedProofs" />


                        <div class="row mb-3">
                            <label  class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <div class="form-check">
                                    <input class="form-check-input" asp-for="IsOpen" /> 
                                    <label class="form-check-label" for="gridCheck4">@Html.DisplayNameFor(model => model.IsOpen)</label>
                                </div>
                            </div>
                        </div>
                    <div class="row">
                        <label class="col-sm-3 col-form-label"></label>
                        <div class="col-sm-9">
                             <button type="submit" class="btn btn-info px-5"> Save</button>
                        </div>
                        <div>
                            <a href="javascript:history.go(-1)" class="btn btn-secondary">
                                <i class="bx bx-arrow-back me-1"></i> Back
                            </a>
                        </div>
                    </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>




@section Scripts {
    <script>
  
        document.getElementById('newLogo').addEventListener('change', function () {
            const addedLogosInput = document.getElementById('addedLogos');
            const files = this.files;
            const fileNames = Array.from(files).map(file => file.name);
            addedLogosInput.value = fileNames.join(',');
        });

        //proofs
        function removedProof(imageKey) {
            const removedProofsInput = document.getElementById('removedProofs');
            const existingImages =removedProofsInput.value.split(',');

            if (existingImages[0] === '') {
                existingImages.shift();
            }

            if (!existingImages.includes(imageKey)) {
                existingImages.push(imageKey);
            }
           removedProofsInput.value = existingImages.join(',');
            // Remove the image element from the DOM
            const listItem = document.querySelector(`#existingProofsContainer li[data-image-key="${imageKey}"]`);
            if (listItem) {
                listItem.remove();
            }
        }

        document.getElementById('newProofs').addEventListener('change', function () {
            const addedProofsInput = document.getElementById('addedProofs');
            const files = this.files;
            const fileNames = Array.from(files).map(file => file.name);
            addedProofsInput.value = fileNames.join(',');
        });


        $('.single-select').select2({
            theme: 'bootstrap4',
            width: $(this).data('width') ? $(this).data('width') : $(this).hasClass('w-100') ? '100%' : 'style',
            placeholder: $(this).data('placeholder'),
            allowClear: Boolean($(this).data('allow-clear')),
        });
    </script>

    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
