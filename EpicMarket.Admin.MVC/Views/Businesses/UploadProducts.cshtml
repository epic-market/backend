@{
    ViewData["Title"] = "Upload Products";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Products</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a asp-action="Index"><i class="bx bx-home-alt"></i></a>
                </li>
                <li class="breadcrumb-item">
                    <a asp-action="Details" asp-route-id="@ViewBag.BusinessId">Business Details</a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Upload Products</li>
            </ol>
        </nav>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <h5 class="card-title">Upload Products for @ViewBag.BusinessName</h5>
        
        <div class="mb-3">
            <a asp-action="DownloadProductSample" class="btn btn-outline-primary">
                <i class="bx bx-download"></i> Download Sample CSV
            </a>
        </div>
        
        <form asp-action="UploadProducts" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" name="id" value="@ViewBag.BusinessId" />
            
            <div class="mb-3">
                <label for="file" class="form-label">Select CSV File</label>
                <input type="file" class="form-control" id="file" name="file" accept=".csv" required />
                <div class="form-text">
                    The file should contain product details in the format shown in the sample CSV.
                </div>
            </div>
            
            <div class="mb-3">
                <h6>Required Fields:</h6>
                <p>Product Name, Description, Category, SKU, and Barcode are required.</p>
                <p>First row should contain headers as shown in the sample file.</p>
            </div>
            
            <div class="d-flex justify-content-between">
                <a asp-action="Details" asp-route-id="@ViewBag.BusinessId" class="btn btn-secondary">Back to Details</a>
                <button type="submit" class="btn btn-primary">Upload</button>
            </div>
        </form>
    </div>
</div> 