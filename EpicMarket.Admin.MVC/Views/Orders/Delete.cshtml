@model EpicMarket.Data.Models.Order

@{
    ViewData["Title"] = "Delete Order";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Orders</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a asp-action="Index"><i class="bx bx-home-alt"></i></a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Delete Order</li>
            </ol>
        </nav>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <h3 class="card-title">Confirm Order Deletion</h3>
        <p class="card-text">Are you sure you want to delete this order?</p>

        <div class="table-responsive">
            <table class="table table-bordered">
                <tr>
                    <th class="bg-light" style="width: 30%;">@Html.DisplayNameFor(model => model.TotalPrice)</th>
                    <td>@Html.DisplayFor(model => model.TotalPrice)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.TotalItems)</th>
                    <td>@Html.DisplayFor(model => model.TotalItems)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.OrderAt)</th>
                    <td>@Html.DisplayFor(model => model.OrderAt)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.PaymentMode)</th>
                    <td>@Html.DisplayFor(model => model.PaymentMode)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.Person)</th>
                    <td>@Html.DisplayFor(model => model.Person.Id)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.Outlet)</th>
                    <td>@Html.DisplayFor(model => model.Outlet.ID)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.Address)</th>
                    <td>@Html.DisplayFor(model => model.Address.Id)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.CreateDate)</th>
                    <td>@Html.DisplayFor(model => model.CreateDate)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.CreateBy)</th>
                    <td>@Html.DisplayFor(model => model.CreateBy)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.ModifiedDate)</th>
                    <td>@Html.DisplayFor(model => model.ModifiedDate)</td>
                </tr>
                <tr>
                    <th class="bg-light">@Html.DisplayNameFor(model => model.ModifiedBy)</th>
                    <td>@Html.DisplayFor(model => model.ModifiedBy)</td>
                </tr>
            </table>
        </div>

        <form asp-action="Delete" class="mt-4">
            <input type="hidden" asp-for="ID" />
            <div class="d-flex justify-content-between">
               <a href="javascript:history.go(-1)" class="btn btn-secondary">
                   <i class="bx bx-arrow-back me-1"></i> Back
                </a>
                <button type="submit" class="btn btn-danger">
                    <i class="bx bx-trash me-1"></i> Delete
                </button>
            </div>
        </form>
    </div>
</div>