@model List<BusinessModel>
<style>
    body {
        background-color: #f8f9fa;
    }

    .card {
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
    }

    .table thead th {
        background-color: #343a40;
        color: white;
    }

</style>

<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Orders</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a asp-action="Index"><i class="bx bx-home-alt"></i></a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Details</li>
            </ol>
        </nav>
    </div>
</div>
<hr />

<div class="container mt-4">
    <h2 class="mb-4 text-center">POS System</h2>

    <div class="row">
        <div class="col-md-6 mb-3">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Business Selection</h5>
                    <div class="form-group">
                        <label for="businessSelect">Select Business:</label>
                        <select id="businessSelect" class="form-control">
                            <option value="">-- Select Business --</option>
                            @foreach (var business in Model)
                            {
                                <option value="@business.Id">@business.Name</option>
                            }
                        </select>
                    </div>
                    <div class="form-group mt-3">
                        <label for="OutletID">Select Branch:</label>
                        <select id="OutletID" class="form-control" disabled>
                            <option value="">-- Select Branch --</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-3">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Customer Details</h5>
                    <div class="form-group">
                        <input type="text" id="customerName" class="form-control mb-2" placeholder="Name">
                        <input type="email" id="customerEmail" class="form-control mb-2" placeholder="Email">
                        <input type="tel" id="customerPhone" class="form-control mb-2" placeholder="Phone">
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card mt-4">
        <div class="card-body">
            <h5 class="card-title">Product Selection</h5>
            <div class="table-responsive">
                <table id="productTable" class="table table-striped table-hover">
                    <thead class="thead-dark">
                        <tr>
                            <th>Product</th>
                            <th>Price</th>
                            <th>Quantity</th>
                            <th>Total</th>
                        </tr>
                    </thead>
                    <tbody>
                    </tbody>
                    <tfoot>
                        <tr class="table-info">
                            <td colspan="2"></td>
                            <td><strong>Total Items:</strong></td>
                            <td id="totalItems">0</td>
                        </tr>
                        <tr class="table-info">
                            <td colspan="2"></td>
                            <td><strong>Total Amount:</strong></td>
                            <td id="totalAmount">$0.00</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-6">
            <div class="form-group">
                <label for="paymentMode">Payment Mode:</label>
                <select id="paymentMode" class="form-control">
                    <option value="cash">Cash</option>
                    <option value="card">Card</option>
                    <option value="upi">UPI</option>
                </select>
            </div>
        </div>
        <div class="col-md-6">
            <button id="placeOrderBtn" class="btn btn-primary btn-lg">
                <i class="fas fa-shopping-cart mr-2"></i>Place Order
            </button>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        $(document).ready(function () {
            debugger
            $('#businessSelect').change(function () {
                var businessId = $(this).val();
                if (businessId) {
                    $.get('/Orders/GetBranches', { businessId: businessId }, function (data) {
                        $('#OutletID').prop('disabled', false).empty().append('<option value="">-- Select Branch --</option>');
                        $.each(data, function (index, branch) {
                            $('#OutletID').append($('<option></option>').val(branch.id).text(branch.name));
                        });
                    });
                } else {
                    $('#OutletID').prop('disabled', true).empty().append('<option value="">-- Select Branch --</option>');
                }
                $('#productTable tbody').empty();
                updateTotals();
            });
            $('#OutletID').change(function () {
                var branchId = $(this).val();
                if (branchId) {
                    $.get('/Orders/GetProducts', { branchId: branchId }, function (data) {
                        $('#productTable tbody').empty();
                        $.each(data, function (index, product) {
                            var price = parseFloat(product.price);
                            var formattedPrice = isNaN(price) ? 'Invalid' : '₹' + price.toFixed(2);
                            var row = `<tr data-product-id="${product.id}">
                            <td>${product.name}</td>
                            <td class="price-cell">${formattedPrice}</td>
                            <td>
                                <select class="quantity-select form-control">
                                    ${[0, 1, 2, 3, 4, 5].map(q => `<option value="${q}">${q}</option>`).join('')}
                                </select>
                            </td>
                            <td class="total">$0.00</td>
                        </tr>`;
                            $('#productTable tbody').append(row);
                        });
                    });
                } else {
                    $('#productTable tbody').empty();
                }
                updateTotals();
            });

            $(document).on('change', '.quantity-select', function () {
                var row = $(this).closest('tr');
                var priceText = row.find('.price-cell').text().replace('₹', '').trim();
                var price = parseFloat(priceText);
                var quantity = parseInt($(this).val());
                var total = price * quantity;
                if (!isNaN(total)) {
                    row.find('.total').text('₹' + total.toFixed(2));
                } else {
                    row.find('.total').text('Invalid');
                }
                updateTotals();
            });

            function updateTotals() {
                var totalItems = 0;
                var totalAmount = 0;
                $('#productTable tbody tr').each(function () {
                    var quantity = parseInt($(this).find('.quantity-select').val()) || 0;
                    var totalText = $(this).find('.total').text().replace('₹', '').trim();
                    var total = parseFloat(totalText) || 0;
                    totalItems += quantity;
                    if (!isNaN(total)) {
                        totalAmount += total;
                    }
                });
                $('#totalItems').text(totalItems);
                $('#totalAmount').text('₹' + totalAmount.toFixed(2));
            }

            $('#placeOrderBtn').click(function () {
                var order = {
                    items: [],
                    totalAmount: parseFloat($('#totalAmount').text().replace('₹', '')),
                    totalItems: parseInt($('#totalItems').text()),
                    paymentMode: $('#paymentMode').val(),
                    customerDetails: {
                        name: $('#customerName').val(),
                        email: $('#customerEmail').val(),
                        phone: $('#customerPhone').val()
                    },
                    OutletID: $('#OutletID').val()
                };

                $('#productTable tbody tr').each(function () {
                    var quantity = parseInt($(this).find('.quantity-select').val());
                    if (quantity > 0) {
                        order.items.push({
                            productId: $(this).data('product-id'),
                            productName: $(this).find('td:eq(0)').text(),
                            price: parseFloat($(this).find('td:eq(1)').text().replace('₹', '')),
                            quantity: quantity,
                            totalPrice: parseFloat($(this).find('.total').text().replace('₹', ''))
                        });
                    }
                });

                $.ajax({
                    url: '/Orders/PlaceOrder',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(order),
                    success: function (response) {
                        alert('Order placed successfully!');
                        // Reset the form or redirect to a new page
                    },
                    error: function () {
                        alert('Error placing order. Please try again.');
                    }
                });
            });
        });
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
