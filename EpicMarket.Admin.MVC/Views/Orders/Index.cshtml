@model IEnumerable<EpicMarket.Data.Models.Order>

@{
    ViewData["Title"] = "Orders";
}

<!-- Page Header -->
<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Orders</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a asp-action="Index"><i class="bx bx-home-alt"></i></a>
                </li>
            </ol>
        </nav>
    </div>
</div>

<!-- Filter Card -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <h5 class="card-title mb-0">
                <i class="bx bx-filter me-2 text-primary"></i>Search & Filter
            </h5>
            <button class="btn btn-sm btn-link text-decoration-none" type="button" data-bs-toggle="collapse" data-bs-target="#filterCollapse" aria-expanded="true">
                <i class="bx bx-chevron-down"></i>
            </button>
        </div>
        <div class="collapse show" id="filterCollapse">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label small fw-semibold">Order ID</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bx bx-hash"></i></span>
                        <input type="text" class="form-control border-start-0 ps-0" id="orderIdFilter" placeholder="Search by ID">
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-semibold">Customer Name</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bx bx-user"></i></span>
                        <input type="text" class="form-control border-start-0 ps-0" id="customerNameFilter" placeholder="Search by customer">
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-semibold">Outlet Name</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bx bx-store"></i></span>
                        <input type="text" class="form-control border-start-0 ps-0" id="outletNameFilter" placeholder="Search by outlet">
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-semibold">Order Status</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bx bx-check-circle"></i></span>
                        <select class="form-select border-start-0 ps-0" id="orderStatusFilter">
                            <option value="">All Statuses</option>
                            <!-- Status options will be loaded dynamically -->
                        </select>
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-semibold">Order Type</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bx bx-purchase-tag"></i></span>
                        <select class="form-select border-start-0 ps-0" id="orderTypeFilter">
                            <option value="">All Types</option>
                            <!-- Order type options will be loaded dynamically -->
                        </select>
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-semibold">Payment Mode</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bx bx-credit-card"></i></span>
                        <select class="form-select border-start-0 ps-0" id="paymentModeFilter">
                            <option value="">All Payment Modes</option>
                            <option value="Cash">Cash</option>
                            <option value="Card">Card</option>
                            <option value="Online">Online</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-semibold">Date From</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bx bx-calendar"></i></span>
                        <input type="date" class="form-control border-start-0 ps-0" id="dateFromFilter">
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-semibold">Date To</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bx bx-calendar"></i></span>
                        <input type="date" class="form-control border-start-0 ps-0" id="dateToFilter">
                    </div>
                </div>
                <div class="col-md-12 d-flex justify-content-end">
                    <button type="button" class="btn btn-primary me-2 px-4" id="searchBtn">
                        <i class='bx bx-search me-1'></i>Search
                    </button>
                    <button type="button" class="btn btn-outline-secondary" id="resetFilter">
                        <i class='bx bx-reset me-1'></i>Reset
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Main Card -->
<div class="card border-0 shadow-sm">
    <div class="card-body">
        <!-- Action Bar -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div class="d-flex align-items-center">
                <h5 class="mb-0 me-2">Order List</h5>
                <span class="badge bg-primary rounded-pill" id="tableRecordsCount">0</span>
            </div>
            <a asp-action="Create" class="btn btn-primary d-flex align-items-center">
                <i class='bx bx-plus me-1'></i>Create New Order
            </a>
        </div>
        
        <!-- Table Wrapper -->
        <div class="table-responsive">
            <table id="example" class="table table-hover align-middle" style="width:100%">
                <thead class="table-light">
                    <tr>
                        <th data-sort="id" class="cursor-pointer">
                            <div class="d-flex align-items-center">
                                ID <i class="bx bx-sort-alt-2 ms-1 text-muted"></i>
                            </div>
                        </th>
                        <th data-sort="ordertype" class="cursor-pointer">
                            <div class="d-flex align-items-center">
                                Order Type <i class="bx bx-sort-alt-2 ms-1 text-muted"></i>
                            </div>
                        </th>
                        <th data-sort="customername" class="cursor-pointer">
                            <div class="d-flex align-items-center">
                                Customer <i class="bx bx-sort-alt-2 ms-1 text-muted"></i>
                            </div>
                        </th>
                        <th data-sort="outletname" class="cursor-pointer">
                            <div class="d-flex align-items-center">
                                Outlet <i class="bx bx-sort-alt-2 ms-1 text-muted"></i>
                            </div>
                        </th>
                        <th data-sort="totalprice" class="cursor-pointer">
                            <div class="d-flex align-items-center">
                                Total Price <i class="bx bx-sort-alt-2 ms-1 text-muted"></i>
                            </div>
                        </th>
                        <th data-sort="totalitems">Items</th>
                        <th data-sort="orderat" class="cursor-pointer">
                            <div class="d-flex align-items-center">
                                Order Date <i class="bx bx-sort-alt-2 ms-1 text-muted"></i>
                            </div>
                        </th>
                        <th data-sort="status" class="cursor-pointer">
                            <div class="d-flex align-items-center">
                                Status <i class="bx bx-sort-alt-2 ms-1 text-muted"></i>
                            </div>
                        </th>
                        <th data-sort="paymentmode">Payment</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Table data will be loaded dynamically -->
                </tbody>
            </table>
            
            <!-- Loading Indicator -->
            <div id="loading-indicator" class="text-center py-5 d-none">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="mt-2">Loading orders...</p>
            </div>
            
            <!-- Empty State -->
            <div id="empty-state" class="text-center py-5 d-none">
                <i class="bx bx-cart text-muted" style="font-size: 4rem;"></i>
                <h5 class="mt-3">No orders found</h5>
                <p class="text-muted">Try adjusting your search criteria or create a new order</p>
                <a asp-action="Create" class="btn btn-primary mt-2">
                    <i class='bx bx-plus me-1'></i>Create New Order
                </a>
            </div>
        </div>
        
        <!-- Pagination Info and Controls -->
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mt-4">
            <div id="pagination-info" class="text-muted mb-3 mb-md-0">
                Showing 0 to 0 of 0 entries
            </div>
            <div id="pagination-controls"></div>
        </div>
    </div>
</div>

<!-- Custom CSS -->
<style>
    .cursor-pointer { cursor: pointer; }
    .table th { font-weight: 600; }
    .status-badge {
        padding: 5px 10px;
        border-radius: 30px;
        font-size: 12px;
        font-weight: 500;
    }
    .status-pending {
        background-color: rgba(255, 193, 7, 0.1);
        color: rgb(255, 193, 7);
    }
    .status-processing {
        background-color: rgba(13, 110, 253, 0.1);
        color: rgb(13, 110, 253);
    }
    .status-completed {
        background-color: rgba(25, 135, 84, 0.1);
        color: rgb(25, 135, 84);
    }
    .status-cancelled {
        background-color: rgba(220, 53, 69, 0.1);
        color: rgb(220, 53, 69);
    }
    .status-delivered {
        background-color: rgba(25, 135, 84, 0.1);
        color: rgb(25, 135, 84);
    }
    .action-btn {
        padding: 5px;
        margin-right: 5px;
        border-radius: 4px;
    }
    .action-btn:hover {
        background-color: rgba(0, 0, 0, 0.05);
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function () {
            let currentPage = 1;
            let pageSize = 10;
            let sortColumn = 'id';
            let sortDirection = 'desc'; // Default to newest orders first
            let isLoading = false;
            
            // Load order statuses and types for filter dropdowns
            loadFilterOptions();

            // Check URL parameters and set filter values
            const urlParams = new URLSearchParams(window.location.search);
            if (urlParams.has('orderId')) {
                $('#orderIdFilter').val(urlParams.get('orderId'));
            }
            if (urlParams.has('customerName')) {
                $('#customerNameFilter').val(urlParams.get('customerName'));
            }
            if (urlParams.has('outletName')) {
                $('#outletNameFilter').val(urlParams.get('outletName'));
            }
            if (urlParams.has('orderStatus')) {
                $('#orderStatusFilter').val(urlParams.get('orderStatus'));
            }
            if (urlParams.has('orderType')) {
                $('#orderTypeFilter').val(urlParams.get('orderType'));
            }
            if (urlParams.has('paymentMode')) {
                $('#paymentModeFilter').val(urlParams.get('paymentMode'));
            }
            if (urlParams.has('dateFrom')) {
                $('#dateFromFilter').val(urlParams.get('dateFrom'));
            }
            if (urlParams.has('dateTo')) {
                $('#dateToFilter').val(urlParams.get('dateTo'));
            }
            if (urlParams.has('page')) {
                currentPage = parseInt(urlParams.get('page')) || 1;
            }
            if (urlParams.has('sort')) {
                sortColumn = urlParams.get('sort');
            }
            if (urlParams.has('dir')) {
                sortDirection = urlParams.get('dir');
            }
            
            function loadFilterOptions() {
                // Load order statuses
                $.ajax({
                    url: '/Order/GetOrderStatuses',
                    type: 'GET',
                    success: function(statuses) {
                        const statusSelect = $('#orderStatusFilter');
                        statuses.forEach(function(status) {
                            statusSelect.append(`<option value="${status.id}">${status.orderStatus}</option>`);
                        });
                        
                        // Set selected value if in URL
                        if (urlParams.has('orderStatus')) {
                            statusSelect.val(urlParams.get('orderStatus'));
                        }
                    }
                });
                
                // Load order types
                $.ajax({
                    url: '/Order/GetOrderTypes',
                    type: 'GET',
                    success: function(types) {
                        const typeSelect = $('#orderTypeFilter');
                        types.forEach(function(type) {
                            typeSelect.append(`<option value="${type.id}">${type.ordertype}</option>`);
                        });
                        
                        // Set selected value if in URL
                        if (urlParams.has('orderType')) {
                            typeSelect.val(urlParams.get('orderType'));
                        }
                    }
                });
            }

            function updateUrl() {
                const params = new URLSearchParams();
                const orderId = $('#orderIdFilter').val();
                const customerName = $('#customerNameFilter').val();
                const outletName = $('#outletNameFilter').val();
                const orderStatus = $('#orderStatusFilter').val();
                const orderType = $('#orderTypeFilter').val();
                const paymentMode = $('#paymentModeFilter').val();
                const dateFrom = $('#dateFromFilter').val();
                const dateTo = $('#dateToFilter').val();
                
                if (orderId) params.set('orderId', orderId);
                if (customerName) params.set('customerName', customerName);
                if (outletName) params.set('outletName', outletName);
                if (orderStatus) params.set('orderStatus', orderStatus);
                if (orderType) params.set('orderType', orderType);
                if (paymentMode) params.set('paymentMode', paymentMode);
                if (dateFrom) params.set('dateFrom', dateFrom);
                if (dateTo) params.set('dateTo', dateTo);
                if (currentPage > 1) params.set('page', currentPage);
                if (sortColumn !== 'id') params.set('sort', sortColumn);
                if (sortDirection !== 'desc') params.set('dir', sortDirection);
                
                const newUrl = window.location.pathname + (params.toString() ? '?' + params.toString() : '');
                history.pushState({}, '', newUrl);
            }

            function loadData() {
                // Show loading indicator
                $('#loading-indicator').removeClass('d-none');
                $('#empty-state').addClass('d-none');
                $('#example tbody').empty();
                
                isLoading = true;
                
                $.ajax({
                    url: '/Order/GetFilteredData',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({
                        orderId: $('#orderIdFilter').val(),
                        customerName: $('#customerNameFilter').val(),
                        outletName: $('#outletNameFilter').val(),
                        orderStatus: $('#orderStatusFilter').val(),
                        orderType: $('#orderTypeFilter').val(),
                        paymentMode: $('#paymentModeFilter').val(),
                        dateFrom: $('#dateFromFilter').val(),
                        dateTo: $('#dateToFilter').val(),
                        pageNumber: currentPage,
                        pageSize: pageSize,
                        sortColumn: sortColumn,
                        sortDirection: sortDirection
                    }),
                    success: function (response) {
                        isLoading = false;
                        $('#loading-indicator').addClass('d-none');
                        
                        if (response.error) {
                            console.error(response.error);
                            showToast('Error loading data: ' + response.error, 'error');
                            return;
                        }
                        
                        // Update record count
                        $('#tableRecordsCount').text(response.totalRecords);
                        
                        if (response.data && response.data.length > 0) {
                            updateTable(response.data);
                            updatePagination(response.totalRecords);
                        } else {
                            $('#empty-state').removeClass('d-none');
                            $('#pagination-info').text('Showing 0 to 0 of 0 entries');
                            $('#pagination-controls').empty();
                        }
                        
                        // Update URL with current filters
                        updateUrl();
                    },
                    error: function (xhr, status, error) {
                        isLoading = false;
                        $('#loading-indicator').addClass('d-none');
                        console.error('Error:', error);
                        showToast('Failed to load data. Please try again.', 'error');
                    }
                });
            }

            function updateTable(data) {
                const tbody = $('#example tbody');
                tbody.empty();

                data.forEach(function (item) {
                    // Determine status class based on status name
                    let statusClass = 'status-pending';
                    if (item.statusName) {
                        const status = item.statusName.toLowerCase();
                        if (status.includes('complete') || status.includes('delivered')) {
                            statusClass = 'status-completed';
                        } else if (status.includes('process') || status.includes('preparing')) {
                            statusClass = 'status-processing';
                        } else if (status.includes('cancel')) {
                            statusClass = 'status-cancelled';
                        } else if (status.includes('deliver')) {
                            statusClass = 'status-delivered';
                        }
                    }
                    
                    // Format date
                    const orderDate = new Date(item.orderAt);
                    const formattedDate = orderDate.toLocaleDateString() + ' ' + 
                                         orderDate.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
                    
                    const row = `
                    <tr>
                        <td><span class="fw-medium">${item.id}</span></td>
                        <td>
                            <span class="badge bg-light text-dark">
                                ${item.orderTypeName || '-'}
                            </span>
                        </td>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="avatar-sm bg-light rounded-circle text-center me-2" style="width: 32px; height: 32px; line-height: 32px;">
                                    <i class="bx bx-user text-primary"></i>
                                </div>
                                <div>
                                    <span class="fw-medium">${item.customerName || '-'}</span>
                                </div>
                            </div>
                        </td>
                        <td>
                            <a href="/Outlets/Details/${item.outletId}" class="text-decoration-none">
                                <div class="d-flex align-items-center">
                                    <div class="avatar-sm bg-light rounded-circle text-center me-2" style="width: 28px; height: 28px; line-height: 28px;">
                                        <i class="bx bx-store text-secondary"></i>
                                    </div>
                                    <span>${item.outletName || '-'}</span>
                                </div>
                            </a>
                        </td>
                        <td>
                            <span class="fw-medium">$${item.totalPrice.toFixed(2)}</span>
                        </td>
                        <td>${item.totalItems}</td>
                        <td>${formattedDate}</td>
                        <td><span class="status-badge ${statusClass}">${item.statusName || ''}</span></td>
                        <td>
                            <span class="badge bg-light text-dark">
                                ${item.paymentMode || '-'}
                            </span>
                        </td>
                        <td>
                            <div class="d-flex justify-content-end">
                                <a href="/Orders/Details/${item.id}" class="action-btn text-primary" title="View Details">
                                    <i class="bx bx-show"></i>
                                </a>
                                <a href="/Orders/Edit/${item.id}" class="action-btn text-warning" title="Edit">
                                    <i class="bx bx-edit"></i>
                                </a>
                            </div>
                        </td>
                    </tr>`;
                    tbody.append(row);
                });
            }

            function updatePagination(totalRecords) {
                const totalPages = Math.ceil(totalRecords / pageSize);
                const start = ((currentPage - 1) * pageSize) + 1;
                const end = Math.min(currentPage * pageSize, totalRecords);

                $('#pagination-info').text(`Showing ${start} to ${end} of ${totalRecords} entries`);

                let paginationHtml = '<ul class="pagination pagination-sm mb-0 justify-content-end">';

                // Previous button
                paginationHtml += `
                    <li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
                        <a class="page-link" href="#" data-page="${currentPage - 1}" aria-label="Previous">
                            <span aria-hidden="true">&laquo;</span>
                        </a>
                    </li>`;

                // Determine page range to show
                let startPage = Math.max(1, currentPage - 2);
                let endPage = Math.min(totalPages, startPage + 4);
                
                if (endPage - startPage < 4) {
                    startPage = Math.max(1, endPage - 4);
                }

                // First page if not in range
                if (startPage > 1) {
                    paginationHtml += `
                        <li class="page-item">
                            <a class="page-link" href="#" data-page="1">1</a>
                        </li>`;
                    
                    if (startPage > 2) {
                        paginationHtml += `
                            <li class="page-item disabled">
                                <a class="page-link" href="#">...</a>
                            </li>`;
                    }
                }
                
                // Page numbers
                for (let i = startPage; i <= endPage; i++) {
                    paginationHtml += `
                        <li class="page-item ${currentPage === i ? 'active' : ''}">
                            <a class="page-link" href="#" data-page="${i}">${i}</a>
                        </li>`;
                }
                
                // Last page if not in range
                if (endPage < totalPages) {
                    if (endPage < totalPages - 1) {
                        paginationHtml += `
                            <li class="page-item disabled">
                                <a class="page-link" href="#">...</a>
                            </li>`;
                    }
                    
                    paginationHtml += `
                        <li class="page-item">
                            <a class="page-link" href="#" data-page="${totalPages}">${totalPages}</a>
                        </li>`;
                }

                // Next button
                paginationHtml += `
                    <li class="page-item ${currentPage === totalPages ? 'disabled' : ''}">
                        <a class="page-link" href="#" data-page="${currentPage + 1}" aria-label="Next">
                            <span aria-hidden="true">&raquo;</span>
                        </a>
                    </li>`;

                paginationHtml += '</ul>';
                $('#pagination-controls').html(paginationHtml);
            }

            // Toast notification
            function showToast(message, type = 'info') {
                // Implementation depends on your toast library
                console.log(`Toast (${type}): ${message}`);
            }

            // Event handlers
            $('#searchBtn').click(function () {
                if (isLoading) return;
                currentPage = 1;
                loadData();
            });

            $('#resetFilter').click(function () {
                if (isLoading) return;
                $('#orderIdFilter, #customerNameFilter, #outletNameFilter').val('');
                $('#orderStatusFilter, #orderTypeFilter, #paymentModeFilter').val('');
                $('#dateFromFilter, #dateToFilter').val('');
                currentPage = 1;
                loadData();
            });

            // Handle Enter key in filter inputs
            $('#orderIdFilter, #customerNameFilter, #outletNameFilter').keypress(function(e) {
                if (e.which === 13) {
                    e.preventDefault();
                    $('#searchBtn').click();
                }
            });

            $(document).on('click', '.page-link', function (e) {
                e.preventDefault();
                if (isLoading) return;
                
                const newPage = $(this).data('page');
                if (newPage >= 1) {
                    currentPage = newPage;
                    loadData();
                    // Scroll back to top of table on page change
                    $('html, body').animate({
                        scrollTop: $("#example").offset().top - 100
                    }, 200);
                }
            });

            $('#example th[data-sort]').click(function () {
                if (isLoading) return;
                
                const newSortColumn = $(this).data('sort');
                
                // Update visual indicators
                $('#example th i').removeClass('text-primary').addClass('text-muted');
                $(this).find('i').removeClass('text-muted').addClass('text-primary');
                
                if (sortColumn === newSortColumn) {
                    sortDirection = sortDirection === 'asc' ? 'desc' : 'asc';
                    // Update icon
                    if (sortDirection === 'asc') {
                        $(this).find('i').removeClass('bx-sort-down').addClass('bx-sort-up');
                    } else {
                        $(this).find('i').removeClass('bx-sort-up').addClass('bx-sort-down');
                    }
                } else {
                    sortColumn = newSortColumn;
                    sortDirection = 'desc'; // Default to descending for orders (newest first)
                    // Reset and set new icon
                    $('#example th i').removeClass('bx-sort-up bx-sort-down').addClass('bx-sort-alt-2');
                    $(this).find('i').removeClass('bx-sort-alt-2').addClass('bx-sort-down');
                }
                
                currentPage = 1;
                loadData();
            });

            // Initial load
            loadData();
        });
    </script>
}