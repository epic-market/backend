@model EpicMarket.Data.Models.Order

@{
    ViewData["Title"] = "Edit";
}
<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Orders</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a asp-action="Index"><i class="bx bx-home-alt"></i></a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Edit</li>
            </ol>
        </nav>
    </div>
</div>
<hr />
<div class="row">
    <div class="col-xl-9 mx-auto">
        <div class="card border-top border-0 border-4 border-info">
            <div class="card-body">
                <div class="border p-4 rounded">
                    <div class="card-title d-flex align-items-center">
                        <div>
                            <i class="bx bxs-user me-1 font-22 text-info"></i>
                        </div>
                        <h5 class="mb-0 text-info">Edit Order Details</h5>

                    </div>
                    <hr />
                    <div class='card mb-4'>
                        <div class='card-body'>
                            <h5 class='card-title'>Order Details</h5>
                            <div class='row'>
                                <div class='col-md-6'>
                                    <p class='mb-1'><strong>Person Email:</strong> @Model.Person.Email</p>
                                    <p class='mb-1'><strong>Outlet Name:</strong> @Model.Outlet.Name</p>
                                    <p class='mb-1'><strong>Order At:</strong> @Model.OrderAt</p>
                                </div>
                                <div class='col-md-6'>
                                    <p class='mb-1'><strong>Order Type Name:</strong> @Model.OrderTypesOptions.Ordertype</p>
                                    <p class='mb-1'><strong>Total Items:</strong> ₹<span id="displayRate">@Model.TotalItems</span></p>
                                    <p class='mb-1'><strong>Total Price:</strong> ₹<span id="displayTotalPrice">@Model.TotalPrice.ToString("F2")</span></p>
                                </div>
                            </div>
                        </div>
                    </div>
                     <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="ID" />
                <input type="hidden" asp-for="CreateDate" />
                <input type="hidden" asp-for="CreateBy" />
                <input type="hidden" asp-for="ModifiedDate" />
                <input type="hidden" asp-for="ModifiedBy" />
                <input type="hidden" asp-for="AddressID" />
                 <input type="hidden" asp-for="IsActive" />
                 <input type="hidden" asp-for="OrderAt" />
                 <input type="hidden" asp-for="OutletID" />
                <input type="hidden" asp-for="PersonID" />
                <input type="hidden" asp-for="TotalPrice" />
                 <input type="hidden" asp-for="TotalItems" />
                  <input type="hidden" asp-for="OrderTypeId" />
            
        
                <div class="row mb-3">
                    <label asp-for="StatusId" class="col-sm-3 col-form-label"></label>
                    <div class="col-sm-9">
                       <select asp-for="StatusId" class="form-control" asp-items="ViewBag.OrderStatusID"></select>
                    </div>
                </div>
                <div class="row mb-3">
                    <label asp-for="PaymentMode" class="col-sm-3 col-form-label"></label>
                    <div class="col-sm-9">
                        <select asp-for="PaymentMode" class="form-select">
                            <option value="Cash">Cash</option>
                            <option value="UPI">UPI</option>
                            <option value="Card">Card</option>
                        </select>
                        <span asp-validation-for="PaymentMode" class="text-danger"></span>
                    </div>
                </div>
                <div class="row mb-3">
                    <label asp-for="Address.Address1" class="col-sm-3 col-form-label"></label>
                    <div class="col-sm-9">
                        <input asp-for="Address.Address1" class="form-control" />
                        <span asp-validation-for="Address.Address1" class="text-danger"></span>
                    </div>
                </div>
                <div class="row mb-3">
                    <label asp-for="Address.State" class="col-sm-3 col-form-label"></label>
                    <div class="col-sm-9">
                        <input asp-for="Address.State" class="form-control" />
                        <span asp-validation-for="Address.State" class="text-danger"></span>
                    </div>
                </div>
                <div class="row mb-3">
                    <label asp-for="Address.City" class="col-sm-3 col-form-label"></label>
                    <div class="col-sm-9">
                        <input asp-for="Address.City" class="form-control" />
                        <span asp-validation-for="Address.City" class="text-danger"></span>
                    </div>
                </div>
                <div class="row mb-3">
                    <label asp-for="Address.Pincode" class="col-sm-3 col-form-label"></label>
                    <div class="col-sm-9">
                        <input asp-for="Address.Pincode" class="form-control" />
                        <span asp-validation-for="Address.Pincode" class="text-danger"></span>
                    </div>
                </div>
            <div class="row">
                <label class="col-sm-3 col-form-label"></label>
                <div class="col-sm-9">
                    <button type="submit" class="btn btn-info px-5"> Save</button>
                </div>
                <div>
                    <a asp-action="Index">Back to List</a>
                </div>
            </div>
        </form>
                </div>
            </div>
        </div>
    </div>
</div>



    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
