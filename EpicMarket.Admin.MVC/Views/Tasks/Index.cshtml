@model IEnumerable<EpicMarket.Data.Models.Tasks>

@{
    ViewData["Title"] = "Tasks";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Page Header -->
<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Tasks</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a asp-action="Index"><i class="bx bx-home-alt"></i></a>
                </li>
            </ol>
        </nav>
    </div>
</div>

<!-- Stats Summary -->
<div class="row mb-4">
    <div class="col-12 col-md-3 mb-3 mb-md-0">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center">
                <div class="rounded-circle bg-primary p-3 me-3" style="width: 60px; height: 60px; display: flex; align-items: center; justify-content: center;">
                    <i class="bx bx-task fs-3 text-white"></i>
                </div>
                <div>
                    <h6 class="mb-0 text-secondary">Total Tasks</h6>
                    <h3 class="mb-0 mt-2 fw-bold" id="totalTasksCount">--</h3>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-3 mb-3 mb-md-0">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center">
                <div class="rounded-circle bg-info p-3 me-3" style="width: 60px; height: 60px; display: flex; align-items: center; justify-content: center;">
                    <i class="bx bx-refresh fs-3 text-white"></i>
                </div>
                <div>
                    <h6 class="mb-0 text-secondary">Open Tasks</h6>
                    <h3 class="mb-0 mt-2 fw-bold" id="openTasksCount">--</h3>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-3 mb-3 mb-md-0">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center">
                <div class="rounded-circle bg-danger p-3 me-3" style="width: 60px; height: 60px; display: flex; align-items: center; justify-content: center;">
                    <i class="bx bx-alarm-exclamation fs-3 text-white"></i>
                </div>
                <div>
                    <h6 class="mb-0 text-secondary">Overdue Tasks</h6>
                    <h3 class="mb-0 mt-2 fw-bold" id="overdueTasksCount">--</h3>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center">
                <div class="rounded-circle bg-success p-3 me-3" style="width: 60px; height: 60px; display: flex; align-items: center; justify-content: center;">
                    <i class="bx bx-calendar-plus fs-3 text-white"></i>
                </div>
                <div>
                    <h6 class="mb-0 text-secondary">New This Month</h6>
                    <h3 class="mb-0 mt-2 fw-bold" id="newTasksCount">--</h3>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Filter Card -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <h5 class="card-title mb-0">
                <i class="bx bx-filter me-2 text-primary"></i>Search & Filter
            </h5>
            <button class="btn btn-sm btn-link text-decoration-none" type="button" data-bs-toggle="collapse" data-bs-target="#filterCollapse" aria-expanded="true">
                <i class="bx bx-chevron-down"></i>
            </button>
        </div>
        <div class="collapse show" id="filterCollapse">
            <div class="row g-3">
                <div class="col-md-2">
                    <label class="form-label small fw-semibold">Task ID</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bx bx-hash"></i></span>
                        <input type="text" class="form-control border-start-0 ps-0" id="taskIdFilter" placeholder="Task ID">
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-semibold">Task Name</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bx bx-text"></i></span>
                        <input type="text" class="form-control border-start-0 ps-0" id="taskNameFilter" placeholder="Search by name">
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-semibold">Assigned To</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bx bx-user"></i></span>
                        <input type="text" class="form-control border-start-0 ps-0" id="assignedToFilter" placeholder="Search by username">
                    </div>
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-semibold">Status</label>
                    <select class="form-select" id="statusFilter">
                        <option value="">All Statuses</option>
                        @foreach (var status in ViewBag.Statuses)
                        {
                            <option value="@status.Id">@status.Status</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-semibold">Actions</label>
                    <div class="d-flex">
                        <button type="button" class="btn btn-primary me-2 flex-grow-1" id="searchBtn">
                            <i class='bx bx-search me-1'></i>Search
                        </button>
                        <button type="button" class="btn btn-outline-secondary" id="resetFilter">
                            <i class='bx bx-reset'></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Main Card -->
<div class="card border-0 shadow-sm">
    <div class="card-body">
        <!-- Action Bar -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div class="d-flex align-items-center">
                <h5 class="mb-0 me-2">Task List</h5>
                <span class="badge bg-primary rounded-pill" id="tableRecordsCount">0</span>
            </div>
            <a asp-action="Create" class="btn btn-primary d-flex align-items-center">
                <i class='bx bx-plus me-1'></i>Create New Task
            </a>
        </div>
        
        <!-- Table Wrapper -->
        <div class="table-responsive">
            <table id="tasksTable" class="table table-hover align-middle" style="width:100%">
                <thead class="table-light">
                    <tr>
                        <th data-sort="id" class="cursor-pointer">
                            <div class="d-flex align-items-center">
                                ID <i class="bx bx-sort-alt-2 ms-1 text-muted"></i>
                            </div>
                        </th>
                        <th data-sort="name" class="cursor-pointer">
                            <div class="d-flex align-items-center">
                                Task Name <i class="bx bx-sort-alt-2 ms-1 text-muted"></i>
                            </div>
                        </th>
                        <th data-sort="type" class="cursor-pointer">
                            <div class="d-flex align-items-center">
                                Type <i class="bx bx-sort-alt-2 ms-1 text-muted"></i>
                            </div>
                        </th>
                        <th data-sort="status" class="cursor-pointer">
                            <div class="d-flex align-items-center">
                                Status <i class="bx bx-sort-alt-2 ms-1 text-muted"></i>
                            </div>
                        </th>
                        <th data-sort="priority" class="cursor-pointer">
                            <div class="d-flex align-items-center">
                                Priority <i class="bx bx-sort-alt-2 ms-1 text-muted"></i>
                            </div>
                        </th>
                        <th data-sort="assigned" class="cursor-pointer">
                            <div class="d-flex align-items-center">
                                Assigned To <i class="bx bx-sort-alt-2 ms-1 text-muted"></i>
                            </div>
                        </th>
                        <th data-sort="duedate" class="cursor-pointer">
                            <div class="d-flex align-items-center">
                                Due Date <i class="bx bx-sort-alt-2 ms-1 text-muted"></i>
                            </div>
                        </th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Table data will be loaded dynamically -->
                </tbody>
            </table>
            
            <!-- Loading Indicator -->
            <div id="loading-indicator" class="text-center py-5 d-none">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="mt-2">Loading tasks...</p>
            </div>
            
            <!-- Empty State -->
            <div id="empty-state" class="text-center py-5 d-none">
                <i class="bx bx-task text-muted" style="font-size: 4rem;"></i>
                <h5 class="mt-3">No tasks found</h5>
                <p class="text-muted">Try adjusting your search criteria or create a new task</p>
                <a asp-action="Create" class="btn btn-primary mt-2">
                    <i class='bx bx-plus me-1'></i>Create New Task
                </a>
            </div>
        </div>
        
        <!-- Pagination Info and Controls -->
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mt-4">
            <div id="pagination-info" class="text-muted mb-3 mb-md-0">
                Showing 0 to 0 of 0 entries
            </div>
            <div id="pagination-controls"></div>
        </div>
    </div>
</div>

<!-- Custom CSS -->
<style>
    .cursor-pointer { cursor: pointer; }
    .table th { font-weight: 600; }
    .status-badge {
        padding: 5px 10px;
        border-radius: 30px;
        font-size: 12px;
        font-weight: 500;
    }
    .status-completed {
        background-color: rgba(25, 135, 84, 0.1);
        color: rgb(25, 135, 84);
    }
    .status-inprogress {
        background-color: rgba(13, 110, 253, 0.1);
        color: rgb(13, 110, 253);
    }
    .status-pending {
        background-color: rgba(255, 193, 7, 0.1);
        color: rgb(255, 193, 7);
    }
    .status-cancelled {
        background-color: rgba(108, 117, 125, 0.1);
        color: rgb(108, 117, 125);
    }
    .priority-critical {
        background-color: rgba(220, 53, 69, 0.1);
        color: rgb(220, 53, 69);
    }
    .priority-high {
        background-color: rgba(255, 128, 0, 0.1);
        color: rgb(255, 128, 0);
    }
    .priority-normal {
        background-color: rgba(13, 110, 253, 0.1);
        color: rgb(13, 110, 253);
    }
    .priority-low {
        background-color: rgba(108, 117, 125, 0.1);
        color: rgb(108, 117, 125);
    }
    .action-btn {
        padding: 5px;
        margin-right: 5px;
        border-radius: 4px;
    }
    .action-btn:hover {
        background-color: rgba(0, 0, 0, 0.05);
    }
    .overdue {
        color: #dc3545;
        font-weight: 500;
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function () {
            let currentPage = 1;
            const pageSize = 10;
            let sortColumn = 'id';
            let sortDirection = 'asc';
            let isLoading = false;

            function loadData() {
                $('#loading-indicator').removeClass('d-none');
                $('#empty-state').addClass('d-none');
                isLoading = true;
                
                // Build filter object
                const filter = {
                    TaskId: $('#taskIdFilter').val(),
                    TaskName: $('#taskNameFilter').val(),
                    AssignedTo: $('#assignedToFilter').val(),
                    StatusId: $('#statusFilter').val() ? parseInt($('#statusFilter').val()) : null,
                    TypeId: $('#typeFilter').val() ? parseInt($('#typeFilter').val()) : null,
                    PageNumber: currentPage,
                    PageSize: pageSize,
                    SortColumn: sortColumn,
                    SortDirection: sortDirection
                };
                
                // AJAX request
                $.ajax({
                    url: '@Url.Action("GetFilteredData", "Tasks")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(filter),
                    success: function (response) {
                        isLoading = false;
                        $('#loading-indicator').addClass('d-none');
                        
                        if (response.error) {
                            console.error('Error:', response.error);
                            $('#empty-state').removeClass('d-none').find('p').text('Error loading tasks: ' + response.error);
                            return;
                        }
                        
                        // Update stats
                        $('#totalTasksCount').text(response.stats.totalTasks);
                        $('#openTasksCount').text(response.stats.openTasks);
                        $('#overdueTasksCount').text(response.stats.overdueTasks);
                        $('#newTasksCount').text(response.stats.newThisMonth);
                        
                        // Render data
                        renderTasks(response.data);
                        
                        // Update pagination
                        renderPagination(response.totalRecords);
                    },
                    error: function (xhr, status, error) {
                        isLoading = false;
                        $('#loading-indicator').addClass('d-none');
                        console.error('AJAX Error:', error);
                        $('#empty-state').removeClass('d-none').find('p').text('Error loading tasks. Please try again.');
                    }
                });
            }

            function renderTasks(tasks) {
                if (!tasks || tasks.length === 0) {
                    $('#tasksTable tbody').html('<tr><td colspan="8" class="text-center">No tasks found</td></tr>');
                    $('#empty-state').removeClass('d-none');
                    return;
                }
                
                let html = '';
                tasks.forEach(task => {
                    // Format dates
                    const dueDate = task.dateDue ? new Date(task.dateDue).toLocaleDateString() : 'N/A';
                    
                    // Determine CSS classes
                    const dueDateClass = task.isOverdue ? 'text-danger fw-bold' : '';
                    
                    html += `
                        <tr>
                            <td>${task.id}</td>
                            <td>
                                <a href="@Url.Action("Details", "Tasks")/${task.id}" class="fw-medium text-primary">
                                    ${task.name}
                                </a>
                            </td>
                            <td><span class="badge bg-light text-dark">${task.taskTypeName || 'N/A'}</span></td>
                            <td>
                                <span class="status-badge ${getStatusClass(task.taskStatusName)}">
                                    ${task.taskStatusName || 'Unknown'}
                                </span>
                            </td>
                            <td>
                                <span class="status-badge ${getPriorityClass(task.priorityText)}">
                                    ${task.priorityText || 'Normal'}
                                </span>
                            </td>
                            <td><span class="${task.assignedToName || 'Not Assigned'}">${task.assignedToName || 'Not Assigned'}</span></td>
                            <td class="${dueDateClass}">${dueDate}</td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end">
                                    <a href="@Url.Action("Edit", "Tasks")/${task.id}" class="action-btn" title="Edit">
                                        <i class="bx bx-edit text-primary"></i>
                                    </a>
                                    <a href="@Url.Action("Details", "Tasks")/${task.id}" class="action-btn" title="View Details">
                                        <i class="bx bx-detail text-info"></i>
                                    </a>
                                    <a href="@Url.Action("Create", "Tasks")?parentTaskId=${task.id}" class="action-btn" title="Add Sub-Task">
                                        <i class="bx bx-plus-circle text-success"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    `;
                });
                
                $('#tasksTable tbody').html(html);
                $('#tableRecordsCount').text(tasks.length);
            }

            // Helper functions for styling
            function getStatusClass(status) {
                if (!status) return '';
                
                status = status.toLowerCase();
                if (status.includes('complete')) return 'status-completed';
                if (status.includes('progress')) return 'status-inprogress';
                if (status.includes('pending')) return 'status-pending';
                if (status.includes('cancel')) return 'status-cancelled';
                return '';
            }
            
            function getPriorityClass(priority) {
                if (!priority) return '';
                
                priority = priority.toLowerCase();
                if (priority.includes('critical')) return 'priority-critical';
                if (priority.includes('high')) return 'priority-high';
                if (priority.includes('normal')) return 'priority-normal';
                if (priority.includes('low')) return 'priority-low';
                return '';
            }

            function renderPagination(totalRecords) {
                const totalPages = Math.ceil(totalRecords / pageSize);
                let paginationHtml = '';
                
                // Only show pagination if we have enough records
                if (totalPages > 1) {
                    paginationHtml += '<ul class="pagination pagination-sm mb-0">';
                    
                    // Previous button
                    paginationHtml += `
                        <li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
                            <button class="page-link" data-page="${currentPage - 1}" aria-label="Previous">
                                <span aria-hidden="true">&laquo;</span>
                            </button>
                        </li>
                    `;
                    
                    // Page numbers
                    const startPage = Math.max(1, currentPage - 2);
                    const endPage = Math.min(totalPages, startPage + 4);
                    
                    for (let i = startPage; i <= endPage; i++) {
                        paginationHtml += `
                            <li class="page-item ${currentPage === i ? 'active' : ''}">
                                <button class="page-link" data-page="${i}">${i}</button>
                            </li>
                        `;
                    }
                    
                    // Next button
                    paginationHtml += `
                        <li class="page-item ${currentPage === totalPages ? 'disabled' : ''}">
                            <button class="page-link" data-page="${currentPage + 1}" aria-label="Next">
                                <span aria-hidden="true">&raquo;</span>
                            </button>
                        </li>
                    `;
                    
                    paginationHtml += '</ul>';
                }
                
                // Update pagination controls
                $('#pagination-controls').html(paginationHtml);
                
                // Update pagination info text
                const startRecord = totalRecords === 0 ? 0 : (currentPage - 1) * pageSize + 1;
                const endRecord = Math.min(currentPage * pageSize, totalRecords);
                $('#pagination-info').text(`Showing ${startRecord} to ${endRecord} of ${totalRecords} entries`);
                
                // Attach event handlers to the pagination buttons
                $('#pagination-controls button.page-link').click(function() {
                    if (!isLoading) {
                        currentPage = parseInt($(this).data('page'));
                        loadData();
                        
                        // Scroll back to top of table on page change
                        $('html, body').animate({
                            scrollTop: $("#tasksTable").offset().top - 100
                        }, 200);
                    }
                });
            }

            // Search button click handler
            $('#searchBtn').click(function() {
                if (!isLoading) {
                    currentPage = 1; // Reset to first page on new search
                    loadData();
                }
            });
            
            // Reset filter button click handler
            $('#resetFilter').click(function() {
                if (!isLoading) {
                    // Clear all filter inputs
                    $('#taskIdFilter').val('');
                    $('#taskNameFilter').val('');
                    $('#assignedToFilter').val('');
                    $('#statusFilter').val('');
                    $('#typeFilter').val('');
                    
                    // Reset to first page and reload
                    currentPage = 1;
                    loadData();
                }
            });
            
            // Enter key on filter inputs
            $('.card-body input').keypress(function(e) {
                if (e.which === 13 && !isLoading) {
                    currentPage = 1;
                    loadData();
                }
            });

            // Table header sorting
            $('#tasksTable th[data-sort]').click(function() {
                if (isLoading) return;
                
                const newSortColumn = $(this).data('sort');
                
                // Update visual indicators
                $('#tasksTable th i').removeClass('text-primary').addClass('text-muted');
                $(this).find('i').removeClass('text-muted').addClass('text-primary');
                
                if (sortColumn === newSortColumn) {
                    sortDirection = sortDirection === 'asc' ? 'desc' : 'asc';
                    // Update icon
                    if (sortDirection === 'asc') {
                        $(this).find('i').removeClass('bx-sort-down').addClass('bx-sort-up');
                    } else {
                        $(this).find('i').removeClass('bx-sort-up').addClass('bx-sort-down');
                    }
                } else {
                    sortColumn = newSortColumn;
                    sortDirection = 'asc';
                    // Reset and set new icon
                    $('#tasksTable th i').removeClass('bx-sort-up bx-sort-down').addClass('bx-sort-alt-2');
                    $(this).find('i').removeClass('bx-sort-alt-2').addClass('bx-sort-up');
                }
                
                currentPage = 1;
                loadData();
            });

            // Initial load
            loadData();
        });
    </script>
}