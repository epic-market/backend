@model EpicMarket.Data.Models.Tasks

@{
    ViewData["Title"] = "Edit";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Tasks</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a asp-action="Index"><i class="bx bx-home-alt"></i></a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Edit</li>
            </ol>
        </nav>
    </div>
</div>
<hr />
<div class="col-xl-9 mx-auto">
    <div class="card border-top border-0 border-4 border-info">
        <div class="card-body">
            <div class="border p-4 rounded">
                <div class="card-title d-flex align-items-center">
                    <div>
                        <i class="bx bxs-user me-1 font-22 text-info"></i>
                    </div>
                    <h5 class="mb-0 text-info">Tasks</h5>
                </div>
                <hr />
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="ID" />
            <input type="hidden" asp-for="CreateDate" />
            <input type="hidden" asp-for="CreateBy" />
            <input type="hidden" asp-for="ModifiedDate" />
            <input type="hidden" asp-for="ModifiedBy" />
             <input type="hidden" asp-for="DateStarted" />
             <input type="hidden" asp-for="DateCompleted" />
             <input type="hidden" asp-for="SubmittedByPersonID" />
             <input type="hidden" asp-for="DateDue" />
              <input type="hidden" asp-for="DateAssigned" />
                    <input type="hidden" asp-for="IsActive" />

            <div class="row mb-3">
                <label asp-for="PrimaryAssignedToPersonID" class="col-sm-3 col-form-label"></label>
                <div class="col-sm-9">
                    <select asp-for="PrimaryAssignedToPersonID" class="form-control" asp-items="ViewBag.Admin"></select>
                    <span asp-validation-for="PrimaryAssignedToPersonID" class="text-danger"></span>
                </div>
            </div>
            <div class="row mb-3">
                <label asp-for="Name" class="col-sm-3 col-form-label"></label>
                <div class="col-sm-9">
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
            </div>
            <div class="row mb-3">
                <label asp-for="Description" class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                <input asp-for="Description" class="form-control" />
                <span asp-validation-for="Description" class="text-danger"></span>
                            </div>
            </div>
            <div class="row mb-3">
                <label asp-for="TaskTypeID" class="col-sm-3 col-form-label"></label>
                                <div class="col-sm-9">
                <select asp-for="TaskTypeID" class="form-control" asp-items="ViewBag.TaskTypeID"></select>
                <span asp-validation-for="TaskTypeID" class="text-danger"></span>
                                </div>
            </div>
            <div class="row mb-3">
                <label asp-for="ParentID" class="col-sm-3 col-form-label"></label>
                 <div class="col-sm-9">
                <select asp-for="ParentID" class="form-control" asp-items="ViewBag.ParentTaskId">
                <option value="">None</option>
                </select>
                            
                <span asp-validation-for="ParentID" class="text-danger"></span>
                                    </div>
            </div>
            <div class="row mb-3">
                <label asp-for="TaskStatusID" class="col-sm-3 col-form-label"></label>
                                        <div class="col-sm-9">
                <select asp-for="TaskStatusID" class="form-control" asp-items="ViewBag.TaskStatusID"></select>
                <span asp-validation-for="TaskStatusID" class="text-danger"></span>
                                        </div>
            </div>
            <div class="row mb-3">
                <label asp-for="TaskPriorityID" class="col-sm-3 col-form-label"></label>
              <div class="col-sm-9">
                <select asp-for="TaskPriorityID" class="form-control" asp-items="ViewBag.Priority"></select>
                <span asp-validation-for="TaskPriorityID" class="text-danger"></span>
                </div>
            </div>
            <div class="row mb-3">
                <label asp-for="TaskData" class="col-sm-3 col-form-label"></label>
                 <div class="col-sm-9">
                <input asp-for="TaskData" class="form-control" />
                <span asp-validation-for="TaskData" class="text-danger"></span>
                  </div>
            </div>
            <div class="row">
                <label class="col-sm-3 col-form-label"></label>
                <div class="col-sm-9">
                    <button type="submit" class="btn btn-info px-5"> Save</button>
                </div>
                <div>
                    <a asp-action="Index">Back to List</a>
                </div>
            </div>
        </form>
    </div>
</div>

 