@model IEnumerable<EpicMarket.Data.Models.Attachment>

@{
    ViewData["Title"] = "Attachments";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Attachments</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a asp-action="Index"><i class="bx bx-home-alt"></i></a>
                </li>
            </ol>
        </nav>
    </div>
</div>

<div class="d-flex justify-content-end mb-3">
    <a asp-action="Create" class="btn btn-primary px-5"><i class='bx bx-plus me-1'></i>Upload New Attachment</a>
</div>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table id="example" class="table table-striped table-bordered" style="width:100%">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Type</th>
                        <th>File Type</th>
                        <th>Upload Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model) {
                    <tr>
                        <td>@Html.DisplayFor(modelItem => item.Name)</td>
                        <td>@Html.DisplayFor(modelItem => item.DocumentType)</td>
                        <td>@Html.DisplayFor(modelItem => item.DocumentFileType)</td>
                        <td>@Html.DisplayFor(modelItem => item.CreateDate)</td>
                        <td>
                            <div class="d-flex gap-2">
                                <a asp-action="DownloadImage" asp-route-key="@item.DocumentFolderPath/@item.DocumentFile" class="btn btn-sm btn-outline-primary">
                                    <i class="bx bx-download"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.ID" class="btn btn-sm btn-outline-info">
                                    <i class="bx bx-edit"></i>
                                </a>
                                <a asp-action="Details" asp-route-id="@item.ID" class="btn btn-sm btn-outline-secondary">
                                    <i class="bx bx-info-circle"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.ID" class="btn btn-sm btn-outline-danger">
                                    <i class="bx bx-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#example').DataTable({
                "order": [[3, "desc"]] // Sort by upload date (newest first)
            });
        });
    </script>
}