@model EpicMarket.Data.Models.Attachment

@{
    ViewData["Title"] = "Edit";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Attachment</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a asp-action="Index"><i class="bx bx-home-alt"></i></a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Edit</li>
            </ol>
        </nav>
    </div>
</div>
<hr />

<div class="row">
    <div class="col-xl-9 mx-auto">
        <div class="card border-top border-0 border-4 border-info">
            <div class="card-body">
                <div class="border p-4 rounded">
                    <div class="card-title d-flex align-items-center">
                        <div>
                            <i class="bx bxs-user me-1 font-22 text-info"></i>
                        </div>
                        <h5 class="mb-0 text-info">Attachment</h5>
                    </div>
                    <hr />
                    <form asp-action="Edit">
                        <input type="hidden" asp-for="ID" />
                        <input type="hidden" asp-for="CreateDate" />
                        <input type="hidden" asp-for="CreateBy" />
                        <input type="hidden" asp-for="ModifiedDate" />
                        <input type="hidden" asp-for="ModifiedBy" />
                        <input type="hidden" asp-for="IsActive" />
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <div class="row mb-3">
                            <label asp-for="Name" class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <input asp-for="Name" class="form-control" />
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label asp-for="Comment" class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <input asp-for="Comment" class="form-control" />
                                <span asp-validation-for="Comment" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label asp-for="DocumentType" class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <input asp-for="DocumentType" class="form-control" />
                                <span asp-validation-for="DocumentType" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label asp-for="DocumentFileType" class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <input asp-for="DocumentFileType" class="form-control" />
                                <span asp-validation-for="DocumentFileType" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label asp-for="DocumentFolderPath" class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <input asp-for="DocumentFolderPath" class="form-control" />
                                <span asp-validation-for="DocumentFolderPath" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label asp-for="DocumentFile" class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <input asp-for="DocumentFile" class="form-control" />
                                <span asp-validation-for="DocumentFile" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="row">
                            <label class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <button type="submit" class="btn btn-info px-5"> Save</button>
                            </div>
                            <div>
                                <a asp-action="Index">Back to List</a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>



