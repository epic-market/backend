@model EpicMarket.Data.Models.Attachment

@{
    ViewData["Title"] = "Edit";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Attachment</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a asp-action="Index"><i class="bx bx-home-alt"></i></a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Edit</li>
            </ol>
        </nav>
    </div>
</div>
<hr />

<div class="row">
    <div class="col-xl-9 mx-auto">
        <div class="card border-top border-0 border-4 border-info">
            <div class="card-body">
                <div class="border p-4 rounded">
                    <div class="card-title d-flex align-items-center">
                        <div>
                            <i class="bx bxs-user me-1 font-22 text-info"></i>
                        </div>
                        <h5 class="mb-0 text-info">Edit Attachment</h5>
                    </div>
                    <hr />
                    <form asp-action="Edit" enctype="multipart/form-data">
                        <input type="hidden" asp-for="ID" />
                        <input type="hidden" asp-for="CreateDate" />
                        <input type="hidden" asp-for="CreateBy" />
                        <input type="hidden" asp-for="ModifiedDate" />
                        <input type="hidden" asp-for="ModifiedBy" />
                        <input type="hidden" asp-for="IsActive" />
                        <input type="hidden" asp-for="DocumentType" />
                        <input type="hidden" asp-for="DocumentFileType" />
                        <input type="hidden" asp-for="DocumentFolderPath" />
                        <input type="hidden" asp-for="DocumentFile" />
                        <input type="hidden" asp-for="EntityId" />
                        <input type="hidden" asp-for="Name" />
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        
                        <div class="row mb-3">
                            <label asp-for="Name" class="col-sm-3 col-form-label">Name</label>
                            <div class="col-sm-9">
                                <input value="@Model.Name" class="form-control" disabled />
                            </div>
                        </div>
                        
                        <div class="row mb-3">
                            <label asp-for="Comment" class="col-sm-3 col-form-label">Comment</label>
                            <div class="col-sm-9">
                                <textarea asp-for="Comment" class="form-control" rows="3"></textarea>
                                <span asp-validation-for="Comment" class="text-danger"></span>
                            </div>
                        </div>
                        
                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label">Document Type</label>
                            <div class="col-sm-9">
                                <input value="@Model.DocumentType" class="form-control" disabled />
                            </div>
                        </div>
                        
                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label">Current File</label>
                            <div class="col-sm-9">
                                <div class="d-flex align-items-center">
                                    <span class="me-2">@Model.DocumentFile</span>
                                        <a asp-action="DownloadImage" asp-route-key="@Model.DocumentFolderPath/@Model.DocumentFile" class="btn btn-sm btn-outline-primary">
                                        <i class="bx bx-download"></i> Download
                                    </a>
                                </div>
                            </div>
                        </div>
                        
                        <div class="row mb-3">
                            <label for="fileUpload" class="col-sm-3 col-form-label">Replace File</label>
                            <div class="col-sm-9">
                                <input type="file" id="fileUpload" name="fileUpload" class="form-control" />
                                <small class="form-text text-muted">Leave empty to keep the current file. Supported file types: PDF, DOC, DOCX, XLS, XLSX, JPG, PNG, GIF</small>
                            </div>
                        </div>
                        
                        <div class="row">
                            <label class="col-sm-3 col-form-label"></label>
                            <div class="col-sm-9">
                                <button type="submit" class="btn btn-info px-5"><i class="bx bx-save me-1"></i> Save Changes</button>
                                <a asp-action="Index" class="btn btn-secondary ms-2"><i class="bx bx-arrow-back me-1"></i> Back to List</a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}