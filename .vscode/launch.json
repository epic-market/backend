{
    "version": "0.2.0",
    "compounds": [
        {
            "name": "API + MVC",
            "configurations": [
                "EpicMarket.Business.API",
                "EpicMarket.Admin.MVC"
            ]
        }
    ],
    "configurations": [
        {
            "name": "EpicMarket.Business.API",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-api",
            "program": "${workspaceFolder}/EpicMarket.Business.API/bin/Debug/net8.0/EpicMarket.Business.API.dll",
            "args": [],
            "cwd": "${workspaceFolder}/EpicMarket.Business.API",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
                "uriFormat": "%s/swagger"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            }
        },
        {
            "name": "EpicMarket.Admin.MVC",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-mvc",
            "program": "${workspaceFolder}/EpicMarket.Admin.MVC/bin/Debug/net8.0/EpicMarket.Admin.MVC.dll",
            "args": [],
            "cwd": "${workspaceFolder}/EpicMarket.Admin.MVC",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            }
        }
    ]
}